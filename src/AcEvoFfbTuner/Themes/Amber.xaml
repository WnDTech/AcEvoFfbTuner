<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Core background surfaces - warm dark -->
    <SolidColorBrush x:Key="BgDark" Color="#FF110E0A" />
    <SolidColorBrush x:Key="BgPanel" Color="#FF171410" />
    <SolidColorBrush x:Key="BgCard" Color="#FF1E1A15" />
    <SolidColorBrush x:Key="BgInput" Color="#FF24201A" />

    <!-- Accent colors - amber/gold -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFE8A830" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFEFC060" />
    <SolidColorBrush x:Key="AccentDragBrush" Color="#FFF5D890" />
    <SolidColorBrush x:Key="AccentGlow" Color="#33E8A830" />
    <SolidColorBrush x:Key="AccentHoverBg" Color="#33E8A830" />
    <SolidColorBrush x:Key="AccentSelectedBg" Color="#C48A28" />
    <SolidColorBrush x:Key="AccentDimBg" Color="#1AE8A830" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="GreenBrush" Color="#FF5CB86C" />
    <SolidColorBrush x:Key="YellowBrush" Color="#FFE8C840" />
    <SolidColorBrush x:Key="RedBrush" Color="#FFD06050" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFFFF" />

    <!-- Text colors -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFE8E0D8" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#FF908880" />

    <!-- Borders and dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#FF383022" />
    <SolidColorBrush x:Key="DividerBrush" Color="#FF383022" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="PopupBorderBrush" Color="#FF908880" />
    <SolidColorBrush x:Key="PopupBg" Color="#FF1E1A15" />

    <!-- Section accent colors -->
    <SolidColorBrush x:Key="SectionTyreForces" Color="#FFC8A860" />
    <SolidColorBrush x:Key="SectionTyreSlip" Color="#FFA8B85C" />
    <SolidColorBrush x:Key="SectionGripFeel" Color="#FF8CC06C" />
    <SolidColorBrush x:Key="SectionDamping" Color="#FFD4A840" />
    <SolidColorBrush x:Key="SectionDynamic" Color="#FFE8A830" />
    <SolidColorBrush x:Key="SectionTyreFlex" Color="#FFB8A860" />
    <SolidColorBrush x:Key="SectionOutput" Color="#FFE8A830" />
    <SolidColorBrush x:Key="SectionVibration" Color="#FFC89888" />
    <SolidColorBrush x:Key="SectionCurb" Color="#FFC88888" />
    <SolidColorBrush x:Key="SectionOfftrack" Color="#FFB09070" />
    <SolidColorBrush x:Key="SectionLfe" Color="#FFC87868" />
    <SolidColorBrush x:Key="SectionSignal" Color="#FFC8A860" />
    <SolidColorBrush x:Key="SectionCrash" Color="#FFC84A3A" />
    <SolidColorBrush x:Key="SectionWetWeather" Color="#FFA8A868" />

    <!-- Tab control -->
    <SolidColorBrush x:Key="TabHoverBg" Color="#FF24201A" />
    <SolidColorBrush x:Key="TabSelectedBorder" Color="#FFE8A830" />

    <!-- Slider -->
    <SolidColorBrush x:Key="SliderTrackBg" Color="#FF483828" />
    <SolidColorBrush x:Key="SliderThumbStroke" Color="#FFFFFFFF" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF484030" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF908880" />
    <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#FFE8A830" />
    <SolidColorBrush x:Key="ScrollBarTrack" Color="#0FFFFFFF" />

    <!-- Tooltip -->
    <SolidColorBrush x:Key="ToolTipBg" Color="#FF2A2420" />
    <SolidColorBrush x:Key="ToolTipBorder" Color="#FF484030" />
    <SolidColorBrush x:Key="ToolTipText" Color="#FFE8E0D8" />

    <!-- Expander -->
    <SolidColorBrush x:Key="ExpanderArrowBrush" Color="#FF908880" />
</ResourceDictionary>
