<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Core background surfaces - deeper blacks -->
    <SolidColorBrush x:Key="BgDark" Color="#FF0A0A0F" />
    <SolidColorBrush x:Key="BgPanel" Color="#FF0F0F18" />
    <SolidColorBrush x:Key="BgCard" Color="#FF14141E" />
    <SolidColorBrush x:Key="BgInput" Color="#FF191926" />

    <!-- Accent colors - purple -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFB06AE0" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFC488E8" />
    <SolidColorBrush x:Key="AccentDragBrush" Color="#FFD9AAF0" />
    <SolidColorBrush x:Key="AccentGlow" Color="#33B06AE0" />
    <SolidColorBrush x:Key="AccentHoverBg" Color="#33B06AE0" />
    <SolidColorBrush x:Key="AccentSelectedBg" Color="#9148C4" />
    <SolidColorBrush x:Key="AccentDimBg" Color="#1AB06AE0" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="GreenBrush" Color="#FF50C878" />
    <SolidColorBrush x:Key="YellowBrush" Color="#FFE6C340" />
    <SolidColorBrush x:Key="RedBrush" Color="#FFE05555" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFFFF" />

    <!-- Text colors -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFE0DCE8" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#FF88809E" />

    <!-- Borders and dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#FF2A2440" />
    <SolidColorBrush x:Key="DividerBrush" Color="#FF2A2440" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="PopupBorderBrush" Color="#FF88809E" />
    <SolidColorBrush x:Key="PopupBg" Color="#FF14141E" />

    <!-- Section accent colors -->
    <SolidColorBrush x:Key="SectionTyreForces" Color="#FF8E7EE0" />
    <SolidColorBrush x:Key="SectionTyreSlip" Color="#FF7EC4A0" />
    <SolidColorBrush x:Key="SectionGripFeel" Color="#FF88C490" />
    <SolidColorBrush x:Key="SectionDamping" Color="#FFC8B04A" />
    <SolidColorBrush x:Key="SectionDynamic" Color="#FFB06AE0" />
    <SolidColorBrush x:Key="SectionTyreFlex" Color="#FF7E9EE0" />
    <SolidColorBrush x:Key="SectionOutput" Color="#FFB06AE0" />
    <SolidColorBrush x:Key="SectionVibration" Color="#FFC0A0E0" />
    <SolidColorBrush x:Key="SectionCurb" Color="#FFA888D9" />
    <SolidColorBrush x:Key="SectionOfftrack" Color="#FFC09078" />
    <SolidColorBrush x:Key="SectionLfe" Color="#FFD07A7A" />
    <SolidColorBrush x:Key="SectionSignal" Color="#FF8E7EE0" />
    <SolidColorBrush x:Key="SectionCrash" Color="#FFD05050" />
    <SolidColorBrush x:Key="SectionWetWeather" Color="#FF6A8AE0" />

    <!-- Tab control -->
    <SolidColorBrush x:Key="TabHoverBg" Color="#FF191926" />
    <SolidColorBrush x:Key="TabSelectedBorder" Color="#FFB06AE0" />

    <!-- Slider -->
    <SolidColorBrush x:Key="SliderTrackBg" Color="#FF28244A" />
    <SolidColorBrush x:Key="SliderThumbStroke" Color="#FFFFFFFF" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF3A3458" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF88809E" />
    <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#FFB06AE0" />
    <SolidColorBrush x:Key="ScrollBarTrack" Color="#0FFFFFFF" />

    <!-- Tooltip -->
    <SolidColorBrush x:Key="ToolTipBg" Color="#FF1E1A30" />
    <SolidColorBrush x:Key="ToolTipBorder" Color="#FF3A3458" />
    <SolidColorBrush x:Key="ToolTipText" Color="#FFE0DCE8" />

    <!-- Expander -->
    <SolidColorBrush x:Key="ExpanderArrowBrush" Color="#FF88809E" />
</ResourceDictionary>
