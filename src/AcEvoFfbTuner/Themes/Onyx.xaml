<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Core background surfaces -->
    <SolidColorBrush x:Key="BgDark" Color="#FF0F1117" />
    <SolidColorBrush x:Key="BgPanel" Color="#FF161B22" />
    <SolidColorBrush x:Key="BgCard" Color="#FF1C2128" />
    <SolidColorBrush x:Key="BgInput" Color="#FF21262D" />

    <!-- Accent colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFF0883E" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFF0A050" />
    <SolidColorBrush x:Key="AccentDragBrush" Color="#FFFBC4A0" />
    <SolidColorBrush x:Key="AccentGlow" Color="#33E67E22" />
    <SolidColorBrush x:Key="AccentHoverBg" Color="#33E67E22" />
    <SolidColorBrush x:Key="AccentSelectedBg" Color="#F08C5A" />
    <SolidColorBrush x:Key="AccentDimBg" Color="#1AE67E22" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="GreenBrush" Color="#FF00E676" />
    <SolidColorBrush x:Key="YellowBrush" Color="#FFFFD600" />
    <SolidColorBrush x:Key="RedBrush" Color="#FFFF1744" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFFFF" />

    <!-- Text colors -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFE6EDF3" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#FF8B949E" />

    <!-- Borders and dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#FF30363D" />
    <SolidColorBrush x:Key="DividerBrush" Color="#FF30363D" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="PopupBorderBrush" Color="#FF8B949E" />
    <SolidColorBrush x:Key="PopupBg" Color="#FF1C2128" />

    <!-- Section accent colors -->
    <SolidColorBrush x:Key="SectionTyreForces" Color="#FF79C0FF" />
    <SolidColorBrush x:Key="SectionTyreSlip" Color="#FF56D4A0" />
    <SolidColorBrush x:Key="SectionGripFeel" Color="#FF7EE787" />
    <SolidColorBrush x:Key="SectionDamping" Color="#FFE3B341" />
    <SolidColorBrush x:Key="SectionDynamic" Color="#FFF0883E" />
    <SolidColorBrush x:Key="SectionTyreFlex" Color="#FF58A6FF" />
    <SolidColorBrush x:Key="SectionOutput" Color="#FFF0883E" />
    <SolidColorBrush x:Key="SectionVibration" Color="#FFD2A8FF" />
    <SolidColorBrush x:Key="SectionCurb" Color="#FFB388FF" />
    <SolidColorBrush x:Key="SectionOfftrack" Color="#FFCE9178" />
    <SolidColorBrush x:Key="SectionLfe" Color="#FFFF7B72" />
    <SolidColorBrush x:Key="SectionSignal" Color="#FF79C0FF" />
    <SolidColorBrush x:Key="SectionCrash" Color="#FFFF4444" />
    <SolidColorBrush x:Key="SectionWetWeather" Color="#FF4FC3F7" />

    <!-- Tab control -->
    <SolidColorBrush x:Key="TabHoverBg" Color="#FF21262D" />
    <SolidColorBrush x:Key="TabSelectedBorder" Color="#FFF0883E" />

    <!-- Slider -->
    <SolidColorBrush x:Key="SliderTrackBg" Color="#FF333355" />
    <SolidColorBrush x:Key="SliderThumbStroke" Color="#FFFFFFFF" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF484F58" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF8B949E" />
    <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#FFF0883E" />
    <SolidColorBrush x:Key="ScrollBarTrack" Color="#0FFFFFFF" />

    <!-- Tooltip -->
    <SolidColorBrush x:Key="ToolTipBg" Color="#FF2D333B" />
    <SolidColorBrush x:Key="ToolTipBorder" Color="#FF444C56" />
    <SolidColorBrush x:Key="ToolTipText" Color="#FFE6EDF3" />

    <!-- Expander -->
    <SolidColorBrush x:Key="ExpanderArrowBrush" Color="#FF8B949E" />
</ResourceDictionary>
