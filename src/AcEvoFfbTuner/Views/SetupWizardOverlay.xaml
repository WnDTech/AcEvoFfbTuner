<Window x:Class="AcEvoFfbTuner.Views.SetupWizardOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFB Tuner — Setup Wizard"
        Width="520"
        Height="740"
        MinWidth="380"
        MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="OnLoaded"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="WizardButton" TargetType="Button">
            <Setter Property="Background" Value="#FF333355" />
            <Setter Property="Foreground" Value="#FFE6EDF3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE6EDF3" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" Padding="1"
            Background="#55F0883E"
            MouseDown="Window_MouseDown"
            MouseWheel="Window_MouseWheel">

        <Border x:Name="ContentBorder" CornerRadius="7" Background="#DD0D0D0D">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══ HEADER + PROGRESS ═══ -->
                <Border Grid.Row="0" Background="#FF161B22" Padding="12,8" MouseDown="Window_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SETUP WIZARD" FontSize="18" FontWeight="Black" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="StepProgressText" Text="1 / 8" FontSize="14" Foreground="#FFB0B0B0" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="2" x:Name="BtnClose" Content="✕" FontSize="14" Width="28" Height="28"
                                Background="#44FF4444" Foreground="White" BorderThickness="0" Click="OnCloseWizard"
                                ToolTip="Close wizard (changes are discarded)" />
                    </Grid>
                </Border>

                <!-- ═══ PROGRESS BAR + TITLE + PHASE BADGE ═══ -->
                <Border Grid.Row="1" Background="#FF111122" Padding="12,6">
                    <StackPanel>
                        <ProgressBar x:Name="ProgressBar" Minimum="1" Maximum="4" Value="1" Height="14" Foreground="#FF4CAF50" Background="#FF2A2A40" BorderThickness="0" Margin="0,0,0,6" />
                        <TextBlock x:Name="StepTitleText" Text="Step 1: Welcome &amp; Safety" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                        <Border x:Name="PhaseBadgeBorder" Background="#FF1A1C23" CornerRadius="4" Padding="6,3" Margin="0,4,0,0" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PhaseBadge" Grid.Column="0" Text="PHASE" FontSize="11" FontWeight="Black" Foreground="Black" Margin="0,0,8,0" />
                                <TextBlock x:Name="PhaseInstruction" Grid.Column="1" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#FFE6EDF3" VerticalAlignment="Center" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ SAFETY BANNER (shown on force-adjusting steps for strong wheelbases) ═══ -->
                <Border x:Name="SafetyBanner" Grid.Row="1" Background="#CC552200" BorderBrush="#FFFF1744"
                        BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="12,42,12,0"
                        Visibility="Collapsed" VerticalAlignment="Top" Panel.ZIndex="10">
                    <StackPanel>
                        <TextBlock x:Name="SafetyTitle" Text="&#x26A0; STRONG WHEELBASE DETECTED" FontSize="13"
                                   FontWeight="Black" Foreground="#FFFF1744" HorizontalAlignment="Center" />
                        <TextBlock x:Name="SafetyText" TextWrapping="Wrap" FontSize="12" Foreground="#FFFFD600"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0">
                            HOLD THE WHEEL FIRMLY during adjustments. Keep hands and face clear of moving parts.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ═══ CONTENT SCROLL (Step Panels) ═══ -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

<!-- STEP 0: Welcome & Safety -->
                        <StackPanel x:Name="PanelStep0">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"
                                       Text="Welcome! This wizard will guide you through setting up your FFB profile step by step. You can keep your game running — the overlay updates live telemetry as you adjust." />
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Close other wheel software (Pit House, G HUB, Fanatec, etc.)" />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Set in-game FFB to 0 in " /><Run Text="{Binding GameDisplayName, Mode=OneWay}" /><Run Text=", then restart the game" />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Select a car, any track, Practice mode" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border x:Name="Step0SafetyBox" Background="#332211" CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="Step0SafetyText" TextWrapping="Wrap" FontSize="14" Foreground="#FFFF1744" FontWeight="Bold">
                                    &#x26A0; Your wheelbase is rated at <Run x:Name="Step0TorqueText" Text="0" /> Nm — this can produce injurious forces.
                                    Always HOLD THE WHEEL FIRMLY when the app is running and force adjustments are being made.
                                </TextBlock>
                            </Border>
                            <TextBlock x:Name="Step0Status" Text="Checking device connection..." FontSize="18" Foreground="#FFFFD600" Margin="0,4" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- STEP 1: Wheel Centering -->
                        <StackPanel x:Name="PanelStep1" Visibility="Collapsed">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"
                                       Text="These three channels make up the core FFB feel. Mz (self-aligning torque) is the most important — it tells you what the front tires are doing." />
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Mz (Self-Align)" /><Run Text=" — the main steering force. Higher = more feel of front grip." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Fx (Longitudinal)" /><Run Text=" — adds weight transfer feel under braking/acceleration." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Fy (Lateral)" /><Run Text=" — adds cornering load feel (can mask Mz, use sparingly)." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <DockPanel Margin="0,4">
                                <CheckBox x:Name="ChkMzEnabled" IsChecked="True" VerticalAlignment="Center" Margin="0,0,4,0" Checked="OnMzEnabledChanged" Unchecked="OnMzEnabledChanged" />
                                <TextBlock Text="Mz (Self-Align)" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderMzGain" Minimum="-2" Maximum="6" TickFrequency="0.05" Value="0.42" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnMzGainChanged" />
                                <TextBlock x:Name="LblMzGain" Text="0.42" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <CheckBox x:Name="ChkFxEnabled" IsChecked="True" VerticalAlignment="Center" Margin="0,0,4,0" Checked="OnFxEnabledChanged" Unchecked="OnFxEnabledChanged" />
                                <TextBlock Text="Fx (Longitudinal)" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderFxGain" Minimum="-2" Maximum="6" TickFrequency="0.05" Value="0.15" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnFxGainChanged" />
                                <TextBlock x:Name="LblFxGain" Text="0.15" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <CheckBox x:Name="ChkFyEnabled" IsChecked="True" VerticalAlignment="Center" Margin="0,0,4,0" Checked="OnFyEnabledChanged" Unchecked="OnFyEnabledChanged" />
                                <TextBlock Text="Fy (Lateral)" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderFyGain" Minimum="-2" Maximum="6" TickFrequency="0.05" Value="0.20" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnFyGainChanged" />
                                <TextBlock x:Name="LblFyGain" Text="0.20" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <CheckBox x:Name="ChkFyInverted" IsChecked="True" VerticalAlignment="Center" Margin="0,0,4,0"
                                          Checked="OnFyInvertedChanged" Unchecked="OnFyInvertedChanged" />
                                <TextBlock Text="Invert Lateral Force" Width="180" VerticalAlignment="Center" FontSize="13"
                                           ToolTip="Flips lateral (cornering) force sign. The wheel pulls sideways under braking due to lateral force — toggling this reverses the direction." />
                            </DockPanel>
                            <TextBlock x:Name="Step2Status" Text="" FontSize="18" Foreground="#FFFFD600" Margin="0,4" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- STEP 2 (PanelStep2): Drive & Calibrate -->
                        <StackPanel x:Name="PanelStep2" Visibility="Collapsed">
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap" Foreground="#FFFFD600">
                                        <Run FontWeight="Bold" Text="Drive through a few corners" /><Run Text=" — the wizard will ask you about the centering feel." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Polarity question (shown after some driving) -->
                            <Border x:Name="PolarityQuestionPanel" Background="#FF332211" CornerRadius="4" Padding="12,10" Margin="0,0,0,8" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Did the wheel pull away from center when you turned?" 
                                               FontSize="16" Foreground="#FFFFD600" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="BtnPolarityYes" Content="Yes — fix it" Width="140" Height="38"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnPolarityYes" Margin="0,0,10,0" />
                                        <Button x:Name="BtnPolarityNo" Content="No — it felt normal" Width="170" Height="38"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnPolarityNo" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Braking pull question (shown after polarity is settled) -->
                            <Border x:Name="BrakingQuestionPanel" Background="#FF332211" CornerRadius="4" Padding="12,10" Margin="0,0,0,8" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="During straight-line braking, which way did the wheel pull?" 
                                               FontSize="16" Foreground="#FFFFD600" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="BtnBrakingLeft" Content="← Pulled left" Width="130" Height="38"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnBrakingLeft" Margin="0,0,8,0" />
                                        <Button x:Name="BtnBrakingRight" Content="Pulled right →" Width="140" Height="38"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnBrakingRight" Margin="0,0,8,0" />
                                        <Button x:Name="BtnBrakingNone" Content="No pull" Width="110" Height="38"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnBrakingNone" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Progress indicator -->
                            <Border Background="#FF1A2233" CornerRadius="4" Padding="10,8" Margin="0,0,0,8" MinHeight="60">
                                <TextBlock x:Name="Step3Status" Text="Drive to 20+ km/h and steer through a corner..." 
                                           FontSize="18" Foreground="#FFFFD600" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <!-- STEP 3 (PanelStep3): Intensity Preference -->
                        <StackPanel x:Name="PanelStep3" Visibility="Collapsed">
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap" Foreground="#FFE6EDF3">
                                        <Run FontWeight="Bold" Text="How should this car feel?" /><Run Text=" Adjust the force strength to match the car type." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Preset buttons -->
                            <Border Background="#FF1A2233" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock FontSize="13" Foreground="#FFCCCCCC" Margin="0,0,0,4" Text="Quick presets:" />
                                    <WrapPanel>
                                        <Button Content="Light / Road Car (65%)" Width="170" Height="32" FontSize="12"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnIntensityPresetLight" Margin="0,0,6,4" />
                                        <Button Content="Balanced / Race Car (85%)" Width="190" Height="32" FontSize="12"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnIntensityPresetBalanced" Margin="0,0,6,4" />
                                        <Button Content="Max Dynamic Detail (100%)" Width="190" Height="32" FontSize="12"
                                                Background="#FF444444" Foreground="White" BorderThickness="0"
                                                Click="OnIntensityPresetMax" Margin="0,0,0,4" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Intensity slider -->
                            <Border Background="#FF1A2233" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="Force Strength" FontSize="14" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                                        <TextBlock x:Name="LblIntensityPercent" Text="100%" Width="55" FontSize="14" 
                                                   Foreground="#FFFFD600" DockPanel.Dock="Right" TextAlignment="Right" />
                                    </DockPanel>
                                    <Slider x:Name="SliderIntensity" Minimum="50" Maximum="120" TickFrequency="1" Value="100"
                                            Width="300" HorizontalAlignment="Left"
                                            ValueChanged="OnIntensitySliderChanged" />
                                    <WrapPanel Margin="0,2,0,0">
                                        <TextBlock Text=" 50%" FontSize="11" Foreground="#FF888888" Width="70" />
                                        <TextBlock Text="100%" FontSize="11" Foreground="#FF888888" Width="70" HorizontalAlignment="Center" />
                                        <TextBlock Text="120%" FontSize="11" Foreground="#FF888888" Width="70" HorizontalAlignment="Right" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#FF1A2233" CornerRadius="4" Padding="10,8" Margin="0,0,0,6" MinHeight="50">
                                <TextBlock x:Name="Step3IntensityStatus" Text="Adjust the slider or tap a preset — feel the change at the wheel" 
                                           FontSize="18" Foreground="#FFFFD600" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

<!-- STEP 4: Damping & Friction -->
                        <StackPanel x:Name="PanelStep4" Visibility="Collapsed">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"
                                       Text="Drive through some corners at increasing speed. Adjust damping so the wheel builds resistance progressively — heavier at high speed, light when slow." />
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Speed Damping" /><Run Text=" controls high-speed gyroscopic feel. Too loose at high speed? Increase it." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Friction" /><Run Text=" adds a scratchy/buzzy feel. Decrease if too rough, increase if too numb." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Speed Damping" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderDamping" Minimum="0" Maximum="25" TickFrequency="0.1" Value="10" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnDampingChanged" />
                                <TextBlock x:Name="LblDamping" Text="10.0" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Friction" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderFriction" Minimum="0" Maximum="0.3" TickFrequency="0.01" Value="0.05" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnFrictionChanged" />
                                <TextBlock x:Name="LblFriction" Text="0.050" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <TextBlock x:Name="Step5Status" Text="" FontSize="18" Foreground="#FFFFD600" Margin="0,4" TextWrapping="Wrap" />
                        </StackPanel>

<!-- STEP 5: Core Tyre Forces -->
                        <StackPanel x:Name="PanelStep5" Visibility="Collapsed">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"
                                       Text="Hit some kerbs and brake hard. You should feel distinct texture from kerbs and the ABS pulsing through the wheel." />
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Curb Gain" /><Run Text=" — kerb/rumble strip feel through the wheel." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Road Gain" /><Run Text=" — road surface texture feel (suspension-driven)." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="Slip Gain" /><Run Text=" — tire slip texture when losing grip." />
                                    </TextBlock>
                                    <TextBlock FontSize="14" Margin="0,1" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="#FFF0883E" Text="ABS Gain" /><Run Text=" — ABS pulsation feel under hard braking." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Master Vib" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderVibMaster" Minimum="0" Maximum="2.0" TickFrequency="0.05" Value="0.5" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnVibMasterGainChanged" />
                                <TextBlock x:Name="LblVibMaster" Text="0.50" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Curb Gain" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderKerbGain" Minimum="0" Maximum="3.0" TickFrequency="0.05" Value="1.0" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnKerbGainChanged" />
                                <TextBlock x:Name="LblKerbGain" Text="1.00" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Road Gain" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderRoadGain" Minimum="0" Maximum="3.0" TickFrequency="0.05" Value="0.5" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnRoadGainChanged" />
                                <TextBlock x:Name="LblRoadGain" Text="0.50" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="Slip Gain" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderSlipGain" Minimum="0" Maximum="3.0" TickFrequency="0.05" Value="0.8" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnSlipGainChanged" />
                                <TextBlock x:Name="LblSlipGain" Text="0.80" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="ABS Gain" Width="110" VerticalAlignment="Center" FontSize="14" />
                                <Slider x:Name="SliderAbsGain" Minimum="0" Maximum="3.0" TickFrequency="0.05" Value="1.0" Width="200"
                                        VerticalAlignment="Center" ValueChanged="OnAbsGainChanged" />
                                <TextBlock x:Name="LblAbsGain" Text="1.00" Width="50" VerticalAlignment="Center" FontSize="14" Margin="4,0" Foreground="#FFFFD600" />
                            </DockPanel>
                            <TextBlock x:Name="Step6Status" Text="" FontSize="18" Foreground="#FFFFD600" Margin="0,4" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- STEP 6: Review & Confirm -->
                        <StackPanel x:Name="PanelStep6" Visibility="Collapsed">
                            <Border Background="#FF1A2233" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="#FFFFD600" Margin="0,0,0,4"
                                            Text="Try a corner. How does it feel?" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FFCCCCCC" Margin="0,0,0,4"
                                            Text="Drive through a turn and adjust the sliders below to your preference:" />

                                    <!-- Master Gain -->
                                    <TextBlock FontSize="13" Foreground="#FF66BB6A" Margin="0,6,0,0" Text="When turning, are the forces strong enough?" />
                                    <DockPanel LastChildFill="True" Margin="0,2,0,0">
                                        <TextBlock Text="Force Strength" FontSize="12" Foreground="#FFCCCCCC" VerticalAlignment="Center" Margin="0,0,6,0" MinWidth="90" />
                                        <TextBlock x:Name="ReviewMasterGain" Text="1.00" Width="50" FontSize="14" VerticalAlignment="Center" Foreground="#FFFFD600" DockPanel.Dock="Right" TextAlignment="Right" Margin="4,0" />
                                        <Button x:Name="BtnReviewResetMaster" Content="R" Width="24" Height="24" FontSize="11"
                                                Background="#FF332211" Foreground="#FFFFD600" BorderThickness="0"
                                                Click="OnReviewResetMasterGain" Margin="4,0" DockPanel.Dock="Right" />
                                        <Slider x:Name="SliderReviewMasterGain" Minimum="0.1" Maximum="5.0" TickFrequency="0.1" Value="1.0"
                                                ValueChanged="OnReviewMasterGainChanged" VerticalAlignment="Center" />
                                    </DockPanel>

                                    <!-- Mz Front Gain -->
                                    <TextBlock FontSize="13" Foreground="#FF66BB6A" Margin="0,6,0,0" Text="Does the wheel center naturally?" />
                                    <DockPanel LastChildFill="True" Margin="0,2,0,0">
                                        <TextBlock Text="Centering Force" FontSize="12" Foreground="#FFCCCCCC" VerticalAlignment="Center" Margin="0,0,6,0" MinWidth="90" />
                                        <TextBlock x:Name="ReviewMzGain" Text="0.50" Width="50" FontSize="14" VerticalAlignment="Center" Foreground="#FFFFD600" DockPanel.Dock="Right" TextAlignment="Right" Margin="4,0" />
                                        <Slider x:Name="SliderReviewMzGain" Minimum="-2.0" Maximum="6.0" TickFrequency="0.05" Value="0.5"
                                                ValueChanged="OnReviewMzGainChanged" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- Summary of all values -->
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="#FF888888" Margin="0,0,0,4" Text="All settings for reference:" />
                                    <TextBlock FontSize="12" Margin="0,1" Foreground="#FF66BB6A">
                                        <Run FontWeight="Bold" Text="Wheel Centering" />
                                        <Run Text=" - CS: " /><Run x:Name="ReviewCenterSuppress" Text="0.0�" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  |  SR: " /><Run x:Name="ReviewSlewRate" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,1" Foreground="#FF66BB6A">
                                        <Run FontWeight="Bold" Text="Channels" />
                                        <Run Text=" - Fx: " /><Run x:Name="ReviewFxGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  Fy: " /><Run x:Name="ReviewFyGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  LatInv: " /><Run x:Name="ReviewFyInv" Text="Off" Foreground="#FFFFD600" FontSize="12" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,1" Foreground="#FF66BB6A">
                                        <Run FontWeight="Bold" Text="Output / Damping" />
                                        <Run Text=" - Out: " /><Run x:Name="ReviewOutputGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  Damp: " /><Run x:Name="ReviewDamping" Text="0.0" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  Fric: " /><Run x:Name="ReviewFriction" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,1" Foreground="#FF66BB6A">
                                        <Run FontWeight="Bold" Text="Vibrations" />
                                        <Run Text=" - Kerb: " /><Run x:Name="ReviewKerbGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  Road: " /><Run x:Name="ReviewRoadGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  Slip: " /><Run x:Name="ReviewSlipGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                        <Run Text="  ABS: " /><Run x:Name="ReviewAbsGain" Text="0.00" Foreground="#FFFFD600" FontSize="12" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Background="#FF332211" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FFFFD600"
                                        Text="Drive and adjust the sliders above. Click Next when it feels good." />
                            </Border>
                            <TextBlock x:Name="Step7Status" Text="" FontSize="18" Foreground="#FFFFD600" Margin="0,4" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- STEP 7: Save Profile -->
                        <StackPanel x:Name="PanelStep7" Visibility="Collapsed">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"
                                       Text="You're done! Your settings are LIVE right now. Give them a name and choose how this profile should be applied." />
                            <Border Background="#FF1A3A1A" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock FontSize="15" Foreground="#FF66BB6A" FontWeight="Bold" Margin="0,1">
                                        <Run Text="&#x2713; Centering direction calibrated" />
                                    </TextBlock>
                                    <TextBlock FontSize="15" Foreground="#FF66BB6A" FontWeight="Bold" Margin="0,1">
                                        <Run Text="&#x2713; Force strength calibrated" />
                                    </TextBlock>
                                    <TextBlock FontSize="15" Foreground="#FF66BB6A" FontWeight="Bold" Margin="0,1">
                                        <Run Text="&#x2713; Intensity preference applied" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Profile Name -->
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile Name:" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtProfileName"
                                             FontSize="14" Padding="6,4" Background="#FF21262D"
                                             Foreground="#FFE6EDF3" BorderBrush="#FF30363D" BorderThickness="1"
                                             Text="My Setup v1" />
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Give your profile a descriptive name"
                                               FontSize="11" Foreground="#FF8B949E" Margin="0,4,0,0" />
                                </Grid>
                            </Border>

                            <!-- Scope Selection -->
                            <Border Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Profile Scope:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <RadioButton x:Name="ScopeGeneral" GroupName="ProfileScope" Content="&#x1F310; General — works for any game, car, or track" FontSize="13" Margin="0,2" IsChecked="True" />
                                    <RadioButton x:Name="ScopePerGame" GroupName="ProfileScope" Content="&#x1F3AE; Per Game — auto-loads for this game only" FontSize="13" Margin="0,2" />
                                    <RadioButton x:Name="ScopePerCar" GroupName="ProfileScope" Content="&#x1F697; Per Car — auto-loads for this car model" FontSize="13" Margin="0,2" />
                                    <RadioButton x:Name="ScopePerTrack" GroupName="ProfileScope" Content="&#x1F3C1; Per Track — auto-loads for this track" FontSize="13" Margin="0,2" />
                                    <RadioButton x:Name="ScopePerCarAndTrack" GroupName="ProfileScope" Content="&#x1F3C1;&#x1F697; Per Car + Track — auto-loads for this specific combo" FontSize="13" Margin="0,2" />
                                </StackPanel>
                            </Border>

                            <!-- Detected Info -->
                            <Border x:Name="ScopeDetectedBox" Background="#FF111122" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <TextBlock x:Name="ScopeDetectedText" FontSize="12" Foreground="#FF8B949E" TextWrapping="Wrap" />
                            </Border>

                            <Border Background="#FF332211" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#FFFFD600">
                                    <Run FontWeight="Bold" Text="Your changes are LIVE but NOT saved yet." />
                                    <Run Text=" Click 'Save &amp; Finish' below to persist them, or 'Back' to keep adjusting." />
                                </TextBlock>
                            </Border>

                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FF8B949E" Margin="0,4"
                                       Text="You can re-run this wizard at any time from the home screen." />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- ═══ FOOTER ═══ -->
                <Border x:Name="FooterBar" Grid.Row="3" Background="#FF161B22" CornerRadius="0,0,7,7" Padding="10,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock x:Name="FooterStatus" FontSize="13" Foreground="#FF666666" VerticalAlignment="Center">
                                <Run Text="Drag to move  |  Scroll to resize" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnBack" Style="{StaticResource WizardButton}" Content="Back" Click="OnBack" Margin="0,0,8,0" />
                            <Button x:Name="BtnNext" Style="{StaticResource WizardButton}" Content="Next" Click="OnNext" Background="#FF445566" />
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>


