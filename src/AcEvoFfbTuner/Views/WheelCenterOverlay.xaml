<Window x:Class="AcEvoFfbTuner.Views.WheelCenterOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wheel Center"
        Width="220"
        Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="OnLoaded"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF333355" />
            <Setter Property="Foreground" Value="#FFE6EDF3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE6EDF3" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" Padding="1"
            Background="#55E67E22"
            MouseLeftButtonDown="OnDragMove"
            MouseWheel="OnMouseWheel">

        <Border x:Name="ContentBorder" CornerRadius="7" Background="#DD0D0D0D">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="HeaderBar" Grid.Row="0" Background="#FF161B22" CornerRadius="7,7,0,0" Padding="10,6"
                        MouseLeftButtonDown="OnDragMove">
                    <Grid>
                        <TextBlock Text="WHEEL CENTER" FontSize="13" FontWeight="Black"
                                   Foreground="#FFF0883E" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnTransparency" ToolTip="Toggle transparency"
                                    Width="26" Height="26" FontSize="14" Padding="0" Margin="0,0,4,0"
                                    Click="ToggleTransparency">
                                <TextBlock x:Name="TransparencyIcon" Text="OPQ" FontSize="11" FontWeight="Bold" Foreground="#FFE6EDF3" />
                            </Button>
                            <Button x:Name="BtnClose" ToolTip="Close"
                                    Width="26" Height="26" FontSize="14" Padding="0"
                                    Background="#FF552222" Click="CloseOverlay">
                                <TextBlock Text="X" FontWeight="Bold" Foreground="#FFE6EDF3" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#FF0D1117" Padding="10" Margin="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Viewbox Grid.Row="0" Stretch="Uniform" Margin="4">
                            <Canvas x:Name="GaugeCanvas" Width="160" Height="160">
                                <Ellipse x:Name="OuterRing" Width="156" Height="156"
                                         Canvas.Left="2" Canvas.Top="2"
                                         Stroke="#FF30363D" StrokeThickness="3" Fill="Transparent" />
                                <Ellipse x:Name="InnerRing" Width="140" Height="140"
                                         Canvas.Left="10" Canvas.Top="10"
                                         Stroke="#FF21262D" StrokeThickness="1" Fill="Transparent" />
                                <Ellipse x:Name="CenterDot" Width="6" Height="6"
                                         Canvas.Left="77" Canvas.Top="77"
                                         Fill="#FFF0883E" />
                                <Line x:Name="MarkerLine" X1="80" Y1="80" X2="80" Y2="16"
                                      Stroke="#FFE6EDF3" StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line x:Name="MarkerLineOpposite" X1="80" Y1="80" X2="80" Y2="144"
                                      Stroke="#FF30363D" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Ellipse x:Name="IndicatorDot" Width="12" Height="12"
                                         Canvas.Left="74" Canvas.Top="6"
                                         Fill="#FF00E676" />
                                <Line x:Name="CenterLine" X1="80" Y1="80" X2="80" Y2="6"
                                      Stroke="#FFFFFF" StrokeThickness="0.5" Opacity="0.15" />
                                <Line x:Name="CenterLineRev" X1="80" Y1="80" X2="80" Y2="154"
                                      Stroke="#FFFFFF" StrokeThickness="0.5" Opacity="0.15" />
                            </Canvas>
                        </Viewbox>

                        <TextBlock x:Name="AngleText" Grid.Row="1"
                                   Text="0°" FontSize="28" FontWeight="Bold"
                                   Foreground="#FF00E676"
                                   HorizontalAlignment="Center" />
                    </Grid>
                </Border>

                <Border x:Name="FooterBar" Grid.Row="2" Background="#FF161B22" CornerRadius="0,0,7,7" Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" Foreground="#FF666666" VerticalAlignment="Center"
                                   Text="Drag | Scroll to resize" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="2" x:Name="StatusLabel" FontSize="11" Foreground="#FF8B949E"
                                   VerticalAlignment="Center" Text="Physical wheel" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
