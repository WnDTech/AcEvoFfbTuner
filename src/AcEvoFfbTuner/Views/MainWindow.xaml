                                        </DockPanel>
                                        <TextBlock Text="Target output level" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- VIBRATION -->
