            <TabItem Header="Profiles">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                        <TextBlock Text="PROFILES" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                        <TextBlock Text="Manage your FFB profiles for different cars and wheel setups" FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                        <TextBlock Text="Current Profile" Style="{StaticResource SubSectionHeader}" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Active Profile" Width="100" VerticalAlignment="Center" FontSize="13" />
                                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                              DisplayMemberPath="Name" Width="280" HorizontalAlignment="Left" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Actions" Style="{StaticResource SubSectionHeader}" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                            <StackPanel>
                                <Button Content="Save Current Profile" Command="{Binding SaveCurrentProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                                <Button Content="Save As New Profile..." Command="{Binding SaveAsNewProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                                <Button Content="Rename Profile" Command="{Binding RenameProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" HorizontalAlignment="Left" />
                                <Button Content="Delete Profile" Command="{Binding DeleteProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Import / Export" Style="{StaticResource SubSectionHeader}" Margin="0,12,0,0" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Profile" Command="{Binding ExportProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Import Profile" Command="{Binding ImportProfileCommand}" Margin="8,4,0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="LED Effects">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="LED EFFECTS" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                        <TextBlock Text="Currently supported: Moza and Fanatec wheel bases. Other brands coming soon." FontSize="13" Foreground="#FF888888" Margin="0,0,0,4" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0">

                            <!-- LED BRIGHTNESS -->
                            <TextBlock Text="BRIGHTNESS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Brightness" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedBrightness, StringFormat='{}{0}%'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LedBrightness}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="LED brightness for SDK-controlled wheels" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- FLASH SETTINGS -->
                            <TextBlock Text="FLASH EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedShiftLimiterFlashEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Shift / Limiter Flash" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="All LEDs flash rapidly at redline or rev limiter" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedAbsFlashEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="ABS Flash (First &amp; Last LED)" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="Flashes the first and last LED when ABS is active" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedFlagIndicatorsEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Race Flag Indicators" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="Show race flags (yellow, red, blue, etc.) on LEDs" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Flash Speed" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedFlashRate, StringFormat='{}{0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LedFlashRate}" Minimum="2" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Lower = faster flash (2 = very fast, 60 = slow)" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- COLOR SCHEME -->
                            <TextBlock Text="COLOR SCHEME" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Color Preset" Style="{StaticResource SubSectionHeader}" />
                                    <TextBlock Text="For wheels with RGB LED support (Fanatec, Moza via SDK)" Style="{StaticResource SliderDescription}" Margin="0,0,0,8" />
                                    <ComboBox SelectedIndex="{Binding LedColorSchemeIndex}" Width="200" FontSize="13" Padding="6,4" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Traffic Light (Green/Yellow/Red)" />
                                        <ComboBoxItem Content="Blue Gradient" />
                                        <ComboBoxItem Content="Red Hot" />
                                        <ComboBoxItem Content="Monochrome" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>
                                    <TextBlock TextWrapping="Wrap" Foreground="#FF888888" FontSize="11" Margin="0,8,0,0">
                                        <Run Text="Note: ES wheels have static LED colors. Color settings" /><LineBreak/>
                                        <Run Text="apply to wheels with per-LED RGB control (Fanatec, Moza SDK)." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="2">

                            <!-- RPM THRESHOLDS -->
                            <TextBlock Text="RPM THRESHOLDS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Preset" Style="{StaticResource SubSectionHeader}" />
                                    <ComboBox SelectedIndex="{Binding LedRpmPresetIndex}" Width="200" FontSize="13" Padding="6,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Default (50-100%)" />
                                        <ComboBoxItem Content="Early (30-100%)" />
                                        <ComboBoxItem Content="Late (70-100%)" />
                                        <ComboBoxItem Content="Linear (10-100%)" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>

                                    <TextBlock Text="Individual RPM Thresholds (% of redline)" Style="{StaticResource SubSectionHeader}" Margin="0,6,0,4" />
                                    <TextBlock Text="Each LED lights up when RPM reaches its threshold" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 1" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FF00CE00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold1, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold1}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 2" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FF00CE00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold2, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold2}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 3" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FF00CE00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold3, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold3}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 4" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFFCC00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold4, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold4}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 5" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFFCC00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold5, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold5}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 6" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFFCC00" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold6, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold6}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 7" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFF6600" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold7, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold7}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 8" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFF6600" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold8, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold8}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 9" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFF0606" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold9, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold9}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="LED 10" Width="60" VerticalAlignment="Center" FontSize="12" Foreground="#FFFF0606" FontWeight="Bold" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedRpmThreshold10, StringFormat='{}{0}%'}" Width="45" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" DockPanel.Dock="Right" />
                                            <Slider Value="{Binding LedRpmThreshold10}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>

                                    <TextBlock Text="Tip: Select a preset first, then switch to Custom to fine-tune" Style="{StaticResource SliderDescription}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Settings" DockPanel.Dock="Right">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="SETTINGS" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                            <TextBlock Text="Configure devices and button assignments." FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                            <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                            <TextBlock Text="Wheel Snapshot Button" Style="{StaticResource SubSectionHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Button:" FontSize="13" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding SnapshotButtonNames}" SelectedIndex="{Binding SnapshotButtonComboIndex}" FontSize="12" Padding="6,4" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Assign" Command="{Binding AssignSnapshotButtonCommand}" Padding="10,4" FontSize="11" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <TextBlock Text="{Binding SnapshotAssignStatus}" FontSize="11" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding SnapshotAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                                    <TextBlock Text="Press while driving to auto-save a telemetry snapshot" FontSize="11" Foreground="#FF666666" />
                                    <TextBlock x:Name="ProfButtonsDetected" Text="" FontSize="11" Foreground="#FFFFD600" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Uses the same device as your FFB wheel. Select a button that's easy to reach while driving." Style="{StaticResource SliderDescription}" Margin="0,0,0,16" />

                            <TextBlock Text="Panic Stop Button" Style="{StaticResource SubSectionHeader}" Margin="0,8,0,2" />
                            <TextBlock Text="Assign a button on a SEPARATE device (e.g. a button box) as a hardware panic stop." FontSize="12" Foreground="#FF888888" Margin="0,0,0,10" TextWrapping="Wrap" />

                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Device:" FontSize="13" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding PanicDevices}" SelectedItem="{Binding SelectedPanicDevice}" FontSize="12" Padding="6,4" Margin="0,0,10,0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshDevicesCommand}" Padding="10,4" FontSize="11" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Button:" FontSize="13" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding PanicButtonNames}" SelectedIndex="{Binding PanicButtonComboIndex}" FontSize="12" Padding="6,4" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Assign" Command="{Binding AssignPanicButtonCommand}" Padding="10,4" FontSize="11" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <TextBlock Text="{Binding PanicAssignStatus}" FontSize="11" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding PanicAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                                    <TextBlock Text="When pressed, immediately zeros all FFB output" FontSize="11" Foreground="#FF666666" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#443B00" CornerRadius="4" Padding="10,6" Margin="0,6,0,16">
                                <TextBlock Text="The panic device is opened in non-exclusive mode, so it won't conflict with the game or your FFB wheel." FontSize="11" Foreground="#FFFFAB00" TextWrapping="Wrap" />
                            </Border>

                        </StackPanel>

                        <!-- RIGHT COLUMN -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="STARTUP EFFECT" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                            <TextBlock Text="Customize the splash screen and startup sound." FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                            <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                            <TextBlock Text="Startup Effect" Style="{StaticResource SubSectionHeader}" Margin="0,0,0,2" />

                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <CheckBox Content="Show splash screen on startup" IsChecked="{Binding SplashScreenEnabled}"
                                              FontSize="13" Foreground="#FFE0E0E0" Margin="0,0,0,12" />

                                    <TextBlock Text="Audio Output Device" FontSize="12" Foreground="#FFCCCCCC" Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AudioOutputDevices}"
                                                  SelectedItem="{Binding SelectedAudioOutputDevice}"
                                                  FontSize="12" Padding="6,4" Margin="0,0,10,0" />
                                        <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRecordingDevicesCommand}"
                                                Padding="10,4" FontSize="11" Style="{StaticResource OutlinedButton}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="&#xE120;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding StartRecordingCommand}"
                                                Visibility="{Binding IsRecording, Converter={StaticResource InvertBoolToVis}}"
                                                Padding="10,6" FontSize="14" Margin="0,0,6,0"
                                                Background="#FF00C853" Foreground="White" BorderThickness="0"
                                                ToolTip="Start Recording" />
                                        <Button Grid.Column="1" Content="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding StopRecordingCommand}"
                                                Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"
                                                Padding="10,6" FontSize="14" Margin="0,0,6,0"
                                                Background="#FFFF1744" Foreground="White" BorderThickness="0"
                                                ToolTip="Stop Recording" />
                                        <Button Grid.Column="2" Content="Preview" Command="{Binding PreviewStartupSoundCommand}"
                                                Padding="10,6" FontSize="11" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0" />
                                        <Button Grid.Column="3" Content="Browse" Command="{Binding BrowseStartupSoundCommand}"
                                                Padding="10,6" FontSize="11" Style="{StaticResource OutlinedButton}" />
                                    </Grid>

                                    <TextBlock Text="{Binding RecordingStatus}" FontSize="11" Foreground="#FFAAAAAA" Margin="0,0,0,6" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CustomStartupSoundPath, TargetNullValue='Using default engine sound', FallbackValue='Using default engine sound'}"
                                                   FontSize="11" Foreground="#FF888888" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Clear" Command="{Binding ClearStartupSoundCommand}"
                                                Padding="8,2" FontSize="10" Style="{StaticResource OutlinedButton}"
                                                Visibility="{Binding CustomStartupSoundPath, Converter={StaticResource NullToVis}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Records audio from your selected output device (speakers/headphones). Start recording, then play the game engine sound you want to capture. Or use Browse to pick an existing audio file." Style="{StaticResource SliderDescription}" Margin="0,0,0,16" />

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Debug">
                <DockPanel Background="#FF151525">
                    <Button DockPanel.Dock="Top" Content="Copy All to Clipboard" Margin="16,12,16,8"
                            Padding="12,6" FontSize="12" HorizontalAlignment="Left"
                            Background="#FF333355" Foreground="#FFE0E0E0" BorderThickness="0"
                            Click="CopyDebugToClipboard" />
                    <ScrollViewer Padding="16">
                        <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="13"
                                 Text="{Binding DebugSnapshot, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#FF1A1A2E" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Fill" Value="#FF00E676" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Foreground="#FFAAAAAA" />
                <TextBlock Grid.Column="2" Text="{Binding DeviceName}" VerticalAlignment="Center" FontSize="12" Margin="16,0" Foreground="#FFAAAAAA" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Foreground" Value="#FF00E676" />
                                    <Setter Property="Text" Value="Game: Connected" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="False">
                                    <Setter Property="Text" Value="Game: Disconnected" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Column="4" Text="{Binding PacketsPerSecond, StringFormat='{}{0} pkt/s'}" VerticalAlignment="Center" FontSize="12" Margin="8,0" Foreground="#FFAAAAAA" />

                <Border Grid.Column="5" Width="1" Background="#FF444466" Margin="12,2" />

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CheckForUpdatesCommand}" Cursor="Hand" VerticalAlignment="Center" FontSize="11" Padding="8,4" Margin="0,0,4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <TextBlock Text="&#x1F504;" FontSize="{TemplateBinding FontSize}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF888888" />
                                <Setter Property="Text" Value="{Binding UpdateStatusText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFD600" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Command="{Binding DownloadAndInstallUpdateCommand}" Cursor="Hand" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Padding="10,4" Margin="0,0,8,0"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="UpdateBtnBorder" Background="#33FFD600" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding LatestVersionText, StringFormat='Install {0}'}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="UpdateBtnBorder" Property="Background" Value="#55FFD600" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Border Grid.Column="7" Width="1" Background="#FF444466" Margin="4,2" />

                <Button Grid.Column="8" Content="&#x2764; Donate" Click="OnDonateClick" Cursor="Hand" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Padding="12,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <TextBlock Text="{TemplateBinding Button.Content}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#FFE67E22" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
