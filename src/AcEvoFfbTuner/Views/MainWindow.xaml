                                <TextBlock Text="WINDOW" FontSize="12" Foreground="#FF888888" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Text="Scrolling 30-second" FontSize="12" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" />
                                <TextBlock x:Name="ProfSampleRate" Text="~30 Hz sample rate" FontSize="12" Foreground="#FF999999" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FF151525" CornerRadius="6">
                            <Grid>
                                <Canvas x:Name="ProfilerCanvas" ClipToBounds="True" />
                                <Canvas x:Name="ProfilerOverlayCanvas" ClipToBounds="True" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Background="#FF22223A" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MzFront" FontSize="13" Foreground="#FF4CAF50" FontFamily="Consolas" VerticalAlignment="Center" />
                            <Rectangle Grid.Column="1" x:Name="BarMz" Fill="#804CAF50" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" x:Name="BarMzVal" Text="--" FontSize="13" Foreground="#FF4CAF50" FontFamily="Consolas" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="FxFront" FontSize="13" Foreground="#FF8BC34A" FontFamily="Consolas" VerticalAlignment="Center" />
                            <Rectangle Grid.Column="4" x:Name="BarFx" Fill="#808BC34A" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" x:Name="BarFxVal" Text="--" FontSize="13" Foreground="#FF8BC34A" FontFamily="Consolas" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="FyFront" FontSize="13" Foreground="#FFCDDC39" FontFamily="Consolas" VerticalAlignment="Center" />
                            <Rectangle Grid.Column="7" x:Name="BarFy" Fill="#80CDDC39" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="8" x:Name="BarFyVal" Text="--" FontSize="13" Foreground="#FFCDDC39" FontFamily="Consolas" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Profiles">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                        <TextBlock Text="PROFILES" FontSize="24" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                        <TextBlock Text="Manage your FFB profiles for different cars and wheel setups" FontSize="15" Foreground="#FF888888" Margin="0,0,0,16" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                        <TextBlock Text="Current Profile" Style="{StaticResource SubSectionHeader}" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="Active Profile" Width="100" VerticalAlignment="Center" FontSize="15" />
                                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                              DisplayMemberPath="Name" Width="280" HorizontalAlignment="Left" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Actions" Style="{StaticResource SubSectionHeader}" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                            <StackPanel>
                                <Button Content="Save Current Profile" Command="{Binding SaveCurrentProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                                <Button Content="Save As New Profile..." Command="{Binding SaveAsNewProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                                <Button Content="Rename Profile" Command="{Binding RenameProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" HorizontalAlignment="Left" />
                                <Button Content="Delete Profile" Command="{Binding DeleteProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Import / Export" Style="{StaticResource SubSectionHeader}" Margin="0,12,0,0" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Profile" Command="{Binding ExportProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Import Profile" Command="{Binding ImportProfileCommand}" Margin="8,4,0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="LED Effects">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="LED EFFECTS" FontSize="24" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding LedSupportedInfo}" FontSize="15" Foreground="#FF888888" Margin="0,0,0,4" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0">

                            <!-- LED BRIGHTNESS -->
                            <StackPanel Visibility="{Binding LedBrightnessVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="BRIGHTNESS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <controls:LabeledSlider Value="{Binding LedBrightness, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="Brightness" StringFormat="{}{0}" Suffix="%"
                                        Description="LED brightness (SDK-connected wheels only)"
                                        SectionColor="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>
                            </StackPanel>

                            <!-- FLASH SETTINGS -->
                            <TextBlock Text="FLASH EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedShiftLimiterFlashEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Shift / Limiter Flash" FontSize="15" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="All LEDs flash rapidly at redline or rev limiter" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedAbsFlashEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="ABS Flash (First &amp; Last LED)" FontSize="15" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="Flashes the first and last LED when ABS is active" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <StackPanel Visibility="{Binding LedFlagIndicatorsVisible, Converter={StaticResource BoolToVis}}">
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding LedFlagIndicatorsEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Race Flag Indicators" FontSize="15" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="Show race flags (yellow, red, blue, etc.) on LEDs" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />
                                    </StackPanel>

                                    <controls:LabeledSlider Value="{Binding LedFlashRate, Mode=TwoWay}" Minimum="2" Maximum="60" TickFrequency="1"
                                        Label="Flash Speed" StringFormat="{}{0}"
                                        Description="Lower = faster flash (2 = very fast, 60 = slow)"
                                        SectionColor="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- COLOR SCHEME -->
                            <StackPanel Visibility="{Binding LedColorSchemeVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="COLOR SCHEME" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Color Preset" Style="{StaticResource SubSectionHeader}" />
                                    <TextBlock Text="For wheels with per-LED RGB control" Style="{StaticResource SliderDescription}" Margin="0,0,0,8" />
                                    <ComboBox SelectedIndex="{Binding LedColorSchemeIndex}" Width="200" FontSize="15" Padding="6,4" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Traffic Light (Green/Yellow/Red)" />
                                        <ComboBoxItem Content="Blue Gradient" />
                                        <ComboBoxItem Content="Red Hot" />
                                        <ComboBoxItem Content="Monochrome" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="2">

                            <!-- RPM THRESHOLDS -->
                            <TextBlock Text="RPM THRESHOLDS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Preset" Style="{StaticResource SubSectionHeader}" />
                                    <ComboBox SelectedIndex="{Binding LedRpmPresetIndex}" Width="200" FontSize="15" Padding="6,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Default (50-100%)" />
                                        <ComboBoxItem Content="Early (30-100%)" />
                                        <ComboBoxItem Content="Late (70-100%)" />
                                        <ComboBoxItem Content="Linear (10-100%)" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>

                                    <TextBlock Text="Individual RPM Thresholds (% of redline)" Style="{StaticResource SubSectionHeader}" Margin="0,6,0,4" />
                                    <TextBlock Text="Each LED lights up when RPM reaches its threshold" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold1, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 1" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold1Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold2, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 2" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold2Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold3, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 3" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold3Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold4, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 4" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold4Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold5, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 5" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold5Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold6, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 6" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold6Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold7, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 7" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold7Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold8, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 8" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold8Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold9, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 9" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold9Visible, Converter={StaticResource BoolToVis}}" />
                                    <controls:LabeledSlider Value="{Binding LedRpmThreshold10, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="LED 10" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                        SectionColor="{StaticResource AccentBrush}"
                                        Visibility="{Binding LedRpmThreshold10Visible, Converter={StaticResource BoolToVis}}" />

                                    <TextBlock Text="Tip: Select a preset first, then switch to Custom to fine-tune" Style="{StaticResource SliderDescription}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Settings" DockPanel.Dock="Right">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="SETTINGS" FontSize="24" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                            <TextBlock Text="Configure devices and button assignments." FontSize="15" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                            <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                            <TextBlock Text="Wheel Snapshot Button" Style="{StaticResource SubSectionHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Button:" FontSize="15" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding SnapshotButtonNames}" SelectedIndex="{Binding SnapshotButtonComboIndex}" FontSize="14" Padding="6,4" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Assign" Command="{Binding AssignSnapshotButtonCommand}" Padding="10,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <TextBlock Text="{Binding SnapshotAssignStatus}" FontSize="14" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding SnapshotAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                                    <TextBlock Text="Press while driving to auto-save a telemetry snapshot" FontSize="14" Foreground="#FF666666" />
                                    <TextBlock x:Name="ProfButtonsDetected" Text="" FontSize="14" Foreground="#FFFFD600" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Uses the same device as your FFB wheel. Select a button that's easy to reach while driving." Style="{StaticResource SliderDescription}" Margin="0,0,0,16" />

                            <TextBlock Text="Panic Stop Button" Style="{StaticResource SubSectionHeader}" Margin="0,8,0,2" />
                            <TextBlock Text="Assign a button on a SEPARATE device (e.g. a button box) as a hardware panic stop." FontSize="14" Foreground="#FF888888" Margin="0,0,0,10" TextWrapping="Wrap" />

                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Device:" FontSize="15" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding PanicDevices}" SelectedItem="{Binding SelectedPanicDevice}" FontSize="14" Padding="6,4" Margin="0,0,10,0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshDevicesCommand}" Padding="10,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Button:" FontSize="15" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding PanicButtonNames}" SelectedIndex="{Binding PanicButtonComboIndex}" FontSize="14" Padding="6,4" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Assign" Command="{Binding AssignPanicButtonCommand}" Padding="10,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                    </Grid>
                                    <TextBlock Text="{Binding PanicAssignStatus}" FontSize="14" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding PanicAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                                    <TextBlock Text="When pressed, immediately zeros all FFB output" FontSize="14" Foreground="#FF666666" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#443B00" CornerRadius="4" Padding="10,6" Margin="0,6,0,16">
                                <TextBlock Text="The panic device is opened in non-exclusive mode, so it won't conflict with the game or your FFB wheel." FontSize="14" Foreground="#FFFFAB00" TextWrapping="Wrap" />
                            </Border>

                        </StackPanel>

                        <!-- RIGHT COLUMN -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="STARTUP EFFECT" FontSize="24" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,0,4" />
                            <TextBlock Text="Customize the splash screen and startup sound." FontSize="15" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                            <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                            <TextBlock Text="Startup Effect" Style="{StaticResource SubSectionHeader}" Margin="0,0,0,2" />

                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4,0,6">
                                <StackPanel>
                                    <CheckBox Content="Show splash screen on startup" IsChecked="{Binding SplashScreenEnabled}"
                                              FontSize="15" Foreground="#FFE0E0E0" Margin="0,0,0,12" />

                                    <TextBlock Text="Audio Output Device" FontSize="14" Foreground="#FFCCCCCC" Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AudioOutputDevices}"
                                                  SelectedItem="{Binding SelectedAudioOutputDevice}"
                                                  FontSize="14" Padding="6,4" Margin="0,0,10,0" />
                                        <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRecordingDevicesCommand}"
                                                Padding="10,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="&#xE120;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding StartRecordingCommand}"
                                                Visibility="{Binding IsRecording, Converter={StaticResource InvertBoolToVis}}"
                                                Padding="10,6" FontSize="16" Margin="0,0,6,0"
                                                Background="#FF00C853" Foreground="White" BorderThickness="0"
                                                ToolTip="Start Recording" />
                                        <Button Grid.Column="1" Content="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding StopRecordingCommand}"
                                                Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"
                                                Padding="10,6" FontSize="16" Margin="0,0,6,0"
                                                Background="#FFFF1744" Foreground="White" BorderThickness="0"
                                                ToolTip="Stop Recording" />
                                        <Button Grid.Column="2" Content="Preview" Command="{Binding PreviewStartupSoundCommand}"
                                                Padding="10,6" FontSize="14" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0" />
                                        <Button Grid.Column="3" Content="Browse" Command="{Binding BrowseStartupSoundCommand}"
                                                Padding="10,6" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                    </Grid>

                                    <TextBlock Text="{Binding RecordingStatus}" FontSize="14" Foreground="#FFAAAAAA" Margin="0,0,0,6" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CustomStartupSoundPath, TargetNullValue='Using default engine sound', FallbackValue='Using default engine sound'}"
                                                   FontSize="14" Foreground="#FF888888" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Clear" Command="{Binding ClearStartupSoundCommand}"
                                                Padding="8,2" FontSize="13" Style="{StaticResource OutlinedButton}"
                                                Visibility="{Binding CustomStartupSoundPath, Converter={StaticResource NullToVis}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Records audio from your selected output device (speakers/headphones). Start recording, then play the game engine sound you want to capture. Or use Browse to pick an existing audio file." Style="{StaticResource SliderDescription}" Margin="0,0,0,16" />

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Debug">
                <DockPanel Background="#FF151525">
                    <Button DockPanel.Dock="Top" Content="Copy All to Clipboard" Margin="16,12,16,8"
                            Padding="12,6" FontSize="14" HorizontalAlignment="Left"
                            Background="#FF333355" Foreground="#FFE0E0E0" BorderThickness="0"
                            Click="CopyDebugToClipboard" />
                    <ScrollViewer Padding="16">
                        <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="15"
                                 Text="{Binding DebugSnapshot, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- Game FFB Active Warning Banner -->
        <Border Grid.Row="2" VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#CC552200" BorderBrush="#FFE67E22" BorderThickness="1"
                CornerRadius="6" Padding="20,12" Margin="0,12,0,0"
                Visibility="{Binding ShowGameFfbWarning, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="100">
            <StackPanel>
                <TextBlock Text="IN-GAME FFB IS STILL ACTIVE" FontSize="18" FontWeight="Black" Foreground="#FFE67E22" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#FFE0E0E0" MaxWidth="700" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8">
                    <Run Text="AC EVO's Force Feedback is still enabled. Open the game's FFB settings and set the " /><Run FontWeight="Bold" Text="FFB Gain slider to 0" /><Run Text=", then " /><Run FontWeight="Bold" Foreground="#FFFF1744" Text="restart the game" /><Run Text=" for it to take effect. This app replaces the game's FFB entirely — if both are active they will fight for exclusive control of your wheel." />
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FFFFAB00" MaxWidth="700" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10">
                    <Run FontStyle="Italic" Text="Changes to FFB settings in AC EVO require a game restart to apply. If you've already set FFB to 0 and restarted, you can safely dismiss this." />
                </TextBlock>
                <Button Content="DISMISS" Command="{Binding DismissGameFfbWarningCommand}"
                        HorizontalAlignment="Center" Padding="24,6" FontSize="14" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#FF1A1A2E" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Fill" Value="#FF00E676" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="14" Foreground="#FFAAAAAA" />
                <TextBlock Grid.Column="2" Text="{Binding DeviceName}" VerticalAlignment="Center" FontSize="14" Margin="16,0" Foreground="#FFAAAAAA" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="14" Margin="8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Foreground" Value="#FF00E676" />
                                    <Setter Property="Text" Value="Game: Connected" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="False">
                                    <Setter Property="Text" Value="Game: Disconnected" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Column="4" Text="{Binding PacketsPerSecond, StringFormat='{}{0} pkt/s'}" VerticalAlignment="Center" FontSize="14" Margin="8,0" Foreground="#FFAAAAAA" />

                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Transparent" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScreenRecording}" Value="True">
                                        <Setter Property="Fill" Value="#FFE53935" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Transparent" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScreenRecording}" Value="True">
                                        <Setter Property="Foreground" Value="#FFE53935" />
                                        <Setter Property="Text" Value="REC" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="5" Width="1" Background="#FF444466" Margin="12,2" />

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CheckForUpdatesCommand}" Cursor="Hand" VerticalAlignment="Center" FontSize="14" Padding="8,4" Margin="0,0,4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <TextBlock Text="&#x1F504;" FontSize="{TemplateBinding FontSize}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF888888" />
                                <Setter Property="Text" Value="{Binding UpdateStatusText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#FFFFD600" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Command="{Binding DownloadAndInstallUpdateCommand}" Cursor="Hand" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Padding="10,4" Margin="0,0,8,0"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="UpdateBtnBorder" Background="#33FFD600" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding LatestVersionText, StringFormat='Install {0}'}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="UpdateBtnBorder" Property="Background" Value="#55FFD600" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button Grid.Column="7" Content="What's New" Click="OnWhatsNewClick" Cursor="Hand" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Padding="10,4" Margin="0,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="WhatsNewBtnBorder" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <TextBlock Text="{TemplateBinding Button.Content}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="#FF4FC3F7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="WhatsNewBtnBorder" Property="Background" Value="#1A4FC3F7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Border Grid.Column="8" Width="1" Background="#FF444466" Margin="4,2" />

                <Button Grid.Column="9" Content="&#x2764; Donate" Click="OnDonateClick" Cursor="Hand" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Padding="12,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <TextBlock Text="{TemplateBinding Button.Content}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#FFE67E22" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
