                                    <Button Content="Import" Command="{Binding ImportProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
