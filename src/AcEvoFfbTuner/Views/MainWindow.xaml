<Window x:Class="AcEvoFfbTuner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
        xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
        xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
        xmlns:local="clr-namespace:AcEvoFfbTuner.Views"
        xmlns:pages="clr-namespace:AcEvoFfbTuner.Views.Pages"
        Title="AC Evo FFB Tuner" Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/wheel.ico"
        Background="{StaticResource BgDark}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Shift+I" Command="{x:Static local:MainWindow.OpenIconPreviewCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR (single row) ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="16,8"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo + Version -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="20" FontWeight="Black" Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="FFB TUNER" FontSize="20" FontWeight="Light" Foreground="{StaticResource TextBrush}" VerticalAlignment="Bottom" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="13" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1" />
                </StackPanel>

                <!-- Connection Pill -->
                <Button Grid.Column="2" x:Name="ConnectionPill" Click="OnConnectionPillClick"
                        Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PillBd" Background="{StaticResource BgInput}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="14" Padding="14,6" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#FF555555" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#FF79C0FF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="14" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
                                                <Setter Property="Text" Value="No device" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                        <Setter Property="Text" Value="{Binding DeviceName}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text=" &#x25BE;" FontSize="10" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PillBd" Property="Background" Value="#FF30363D" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Device Popup -->
                <Popup x:Name="DevicePopup" PlacementTarget="{Binding ElementName=ConnectionPill}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       PopupAnimation="Slide" Width="280" Opened="OnDevicePopupOpened">
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="12"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="SELECT DEVICE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right" Content="&#x21BB;" FontSize="14"
                                        Click="OnDeviceRefreshClick" Cursor="Hand"
                                        Background="Transparent" Foreground="{StaticResource TextDimBrush}"
                                        BorderThickness="0" Padding="4,0" VerticalAlignment="Center" />
                            </DockPanel>
                            <ListBox x:Name="DeviceList" ItemsSource="{Binding AvailableDevices}"
                                     SelectionChanged="OnDeviceListSelectionChanged"
                                     MaxHeight="220" BorderThickness="0" Background="Transparent"
                                     Foreground="{StaticResource TextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#FF555555" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFfbCapable}" Value="True">
                                                                <Setter Property="Fill" Value="#FF79C0FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding ProductName}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF30363D" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF30363D" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <TextBlock x:Name="DeviceEmptyText" Text="No devices found" FontSize="12"
                                       Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center"
                                       Margin="0,12,0,8" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Profile Pill + Save -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ProfilePill" Click="OnProfilePillClick"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="PillBd" Background="{StaticResource BgInput}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="14,6" SnapsToDevicePixels="True">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue='No profile', TargetNullValue='No profile'}"
                                                   FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBuiltInProfileSelected}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Text" Value="(built-in)" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text=" &#x25BE;" FontSize="10" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="PillBd" Property="Background" Value="#FF30363D" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="ProfileSaveBtn" Command="{Binding SaveCurrentProfileCommand}"
                            Cursor="Hand" Margin="4,0,0,0" ToolTip="Save profile">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="SaveBd" Background="{StaticResource BgInput}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="10,6" SnapsToDevicePixels="True">
                                    <TextBlock Text="Save" FontSize="13" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="SaveBd" Property="Background" Value="#FF30363D" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Profile Popup -->
                <Popup x:Name="ProfilePopup" PlacementTarget="{Binding ElementName=ProfilePill}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                       PopupAnimation="Slide" Width="300" Opened="OnProfilePopupOpened">
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="12"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="SELECT PROFILE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right" Content="Save As..."
                                        Command="{Binding SaveAsNewProfileCommand}"
                                        FontSize="11" Padding="8,3" Cursor="Hand" VerticalAlignment="Center"
                                        Style="{StaticResource OutlinedButton}" />
                            </DockPanel>
                            <ListBox x:Name="ProfileList" ItemsSource="{Binding Profiles}"
                                     SelectedItem="{Binding SelectedProfile}"
                                     SelectionChanged="OnProfileListSelectionChanged"
                                     MaxHeight="260" BorderThickness="0" Background="Transparent"
                                     Foreground="{StaticResource TextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                <Setter Property="Fill" Value="#FF555555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF30363D" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF30363D" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <TextBlock x:Name="ProfileEmptyText" Text="No profiles found" FontSize="12"
                                       Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center"
                                       Margin="0,12,0,8" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- START / STOP + PANIC -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding IsRunning}" Command="{Binding ToggleTelemetryCommand}"
                                  Margin="0,0,8,0" x:Name="StartStopToggle">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="START" />
                                <Setter Property="Background" Value="#FF2E7D32" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#FF4CAF50" />
                                <Setter Property="Padding" Value="24,6" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Content" Value="STOP" />
                                        <Setter Property="Background" Value="#FFF0883E" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderBrush" Value="#FFFF9800" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button Content="PANIC" Command="{Binding PanicStopCommand}" Style="{StaticResource PanicButton}" Padding="16,6" FontSize="14" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:SidebarControl x:Name="Sidebar" Grid.Column="0" />

            <Grid Grid.Column="1" x:Name="ContentArea">
                <pages:HomePage x:Name="HomePageCtrl" Visibility="Collapsed" />
                <pages:FfbTuningPage x:Name="FfbTuningPageCtrl" Visibility="Visible" />
                <pages:EqualizerPage x:Name="EqualizerPageCtrl" Visibility="Collapsed" />
                <pages:TrackMapPage x:Name="TrackMapPageCtrl" Visibility="Collapsed" />
                <pages:TelemetryPage x:Name="TelemetryPageCtrl" Visibility="Collapsed" />
                <pages:DevicesPage x:Name="DevicesPageCtrl" Visibility="Collapsed" />
                <pages:ProfilesPage x:Name="ProfilesPageCtrl" Visibility="Collapsed" />
                <pages:SettingsPage x:Name="SettingsPageCtrl" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- Game FFB Active Warning Banner -->
        <Border Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#CC552200" BorderBrush="#FFF0883E" BorderThickness="1"
                CornerRadius="6" Padding="20,12" Margin="0,12,0,0"
                Visibility="{Binding ShowGameFfbWarning, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="100">
            <StackPanel>
                <TextBlock Text="IN-GAME FFB IS STILL ACTIVE" FontSize="18" FontWeight="Black" Foreground="#FFF0883E" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#FFE6EDF3" MaxWidth="700" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8">
                    <Run Text="AC EVO's Force Feedback is still enabled. Open the game's FFB settings and set the " /><Run FontWeight="Bold" Text="FFB Gain slider to 0" /><Run Text=", then " /><Run FontWeight="Bold" Foreground="#FFFF1744" Text="restart the game" /><Run Text=" for it to take effect. This app replaces the game's FFB entirely — if both are active they will fight for exclusive control of your wheel." />
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FFFFAB00" MaxWidth="700" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10">
                    <Run FontStyle="Italic" Text="Changes to FFB settings in AC EVO require a game restart to apply. If you've already set FFB to 0 and restarted, you can safely dismiss this." />
                </TextBlock>
                <Button Content="DISMISS" Command="{Binding DismissGameFfbWarningCommand}"
                        HorizontalAlignment="Center" Padding="24,6" FontSize="14" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="12,4"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Status indicators -->
                <Grid Grid.Row="0" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Game Status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF555555" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                            <Setter Property="Fill" Value="#FF7EE787" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="13" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF555555" />
                                    <Setter Property="Text" Value="Game: Off" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#FF7EE787" />
                                            <Setter Property="Text" Value="Game: Connected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2" />

                    <!-- Packets/sec -->
                    <TextBlock Grid.Column="2" Text="{Binding PacketsPerSecond, StringFormat='{}{0} pkt/s'}"
                               FontSize="13" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="12,0" />

                    <!-- Force Output -->
                    <TextBlock Grid.Column="3" Text="{Binding CurrentForceOutput, StringFormat='{}{0:F3} Nm'}"
                               FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" FontWeight="Medium" Margin="0,0,12,0" />

                    <!-- Status Text -->
                    <TextBlock Grid.Column="4" Text="{Binding StatusText}" FontSize="13"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding StatusText, Converter={StaticResource NotEmptyToVis}}" />

                    <!-- REC Indicator -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,4,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecording}" Value="True">
                                            <Setter Property="Fill" Value="#FFE53935" />
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenRecording}" Value="True">
                                            <Setter Property="Foreground" Value="#FFE53935" />
                                            <Setter Property="Text" Value="REC" />
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Spacer -->

                    <!-- Update Status -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock FontSize="13" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding UpdateStatusText}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFD600" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding DownloadAndInstallUpdateCommand}" Cursor="Hand" VerticalAlignment="Center"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="UpdateBtnBorder" Background="#33FFD600" CornerRadius="4" Padding="10,3" SnapsToDevicePixels="True">
                                        <TextBlock Text="{Binding LatestVersionText, StringFormat='Install {0}'}" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="UpdateBtnBorder" Property="Background" Value="#55FFD600" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="8" Width="1" Background="{StaticResource BorderBrush}" Margin="4,2" />

                    <!-- Donate -->
                    <Button Grid.Column="9" Click="OnDonateClick" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4" Padding="10,3" SnapsToDevicePixels="True">
                                    <TextBlock Text="&#x2764; Donate" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FFF0883E" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Row 1: Active Features + Haptic Test -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Active:" FontSize="12" Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ItemsControl ItemsSource="{Binding ActiveFeatures}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,4,0">
                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#FF79C0FF" VerticalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Separator -->
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,0" Height="16" VerticalAlignment="Center" />

                    <!-- Haptic Test Button -->
                    <Button Command="{Binding TestHapticsCommand}" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="HapticBtnBorder" Background="#1A79C0FF" CornerRadius="4" Padding="10,3" SnapsToDevicePixels="True">
                                    <TextBlock x:Name="HapticBtnText" Text="Haptic Test" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#FF79C0FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HapticBtnBorder" Property="Background" Value="#3379C0FF" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsHapticTestRunning}" Value="True">
                                        <Setter TargetName="HapticBtnText" Property="Text" Value="Testing..." />
                                        <Setter TargetName="HapticBtnBorder" Property="Background" Value="#33FFD600" />
                                        <Setter TargetName="HapticBtnText" Property="Foreground" Value="#FFFFD600" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
