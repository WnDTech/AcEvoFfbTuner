                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="All LEDs flash rapidly at redline or rev limiter" Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
