<Window x:Class="AcEvoFfbTuner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
        xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
        xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
        Title="AC Evo FFB Tuner" Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/wheel.ico"
        Background="#FF0D0D0D"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#FF1A1A2E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="24" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,8,0" />
                    <TextBlock Text="FFB TUNER" FontSize="24" FontWeight="Light" Foreground="#FFE0E0E0" VerticalAlignment="Bottom" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="15" Foreground="#FF888888" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="ProductName" Width="220" Margin="8,0" />
                    <Button Content="Connect" Command="{Binding ConnectDeviceCommand}" Margin="4,0" />
                    <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" Margin="4,0" Style="{StaticResource OutlinedButton}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Profile:" FontSize="14" Foreground="#FF888888" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" Width="260" Margin="4,0" />
                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" Margin="4,0" Padding="12,4" FontSize="12" ToolTip="Save current profile" />
                    <Button Content="Save As..." Command="{Binding SaveAsNewProfileCommand}" Margin="4,0" Padding="12,4" FontSize="12" Style="{StaticResource OutlinedButton}" ToolTip="Save as a new profile" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="1" Background="#FF14142A" Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding IsRunning}" Command="{Binding ToggleTelemetryCommand}"
                                  Margin="0,0,8,0" x:Name="StartStopToggle" MinHeight="40">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="START" />
                                <Setter Property="Background" Value="#FF2E7D32" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#FF4CAF50" />
                                <Setter Property="Padding" Value="28,10" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <TextBlock x:Name="BtnText" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Content" Value="STOP" />
                                        <Setter Property="Background" Value="#FFE67E22" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderBrush" Value="#FFFF9800" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button Content="AUTO SETUP"
                            Command="{Binding AutoSetupCommand}"
                            IsEnabled="{Binding IsAutoSetupAvailable}"
                            Margin="4,0" MinHeight="40" Padding="16,8"
                            FontSize="13" FontWeight="Bold" Cursor="Hand"
                            ToolTip="Auto-configure all FFB settings for your connected wheelbase">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF1565C0" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="#FF42A5F5" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF1976D2" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF333333" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF555555" />
                                                    <Setter Property="Foreground" Value="#FF888888" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <ToggleButton IsChecked="{Binding IsLiveAutoTuneEnabled}"
                                  Command="{Binding ToggleLiveAutoTuneCommand}"
                                  Margin="0,0,8,0" MinHeight="40" Padding="16,8"
                                  FontSize="13" FontWeight="Bold" Cursor="Hand"
                                  ToolTip="Enable live auto-tuning to prevent oscillation while driving">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="LIVE TUNE" />
                                <Setter Property="Background" Value="#FF1A237E" />
                                <Setter Property="Foreground" Value="#FF90CAF9" />
                                <Setter Property="BorderBrush" Value="#FF5C6BC0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <TextBlock x:Name="BtnText" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF283593" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveAutoTuneEnabled}" Value="True">
                                        <Setter Property="Background" Value="#FF4FC3F7" />
                                        <Setter Property="Foreground" Value="#FF0D0D0D" />
                                        <Setter Property="BorderBrush" Value="#FF81D4FA" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button Content="PANIC" Command="{Binding PanicStopCommand}" Margin="0,0,4,0" Style="{StaticResource PanicButton}" MinHeight="40" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AutoSetupStatus}" FontSize="12" Foreground="#FF4FC3F7" VerticalAlignment="Center" Margin="8,0" />
                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveAutoTuneEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="LIVE" Foreground="#FF4FC3F7" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LiveCorrectionsCount, StringFormat='{}{0} corrections'}" FontSize="11" Foreground="#FF888888" Margin="6,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LastCorrectionText}" FontSize="11" Foreground="#FFAAAAAA" Margin="8,0,0,0" VerticalAlignment="Center" MaxWidth="350" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Send Diagnostics to Dev" Command="{Binding SendDiagnosticPackCommand}"
                            Padding="14,4" FontSize="14" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSendingDiagnosticPack}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="Sending..." FontSize="14" Foreground="#FFE67E22" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSendingDiagnosticPack}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding DiagnosticPackStatus}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Foreground" Value="#FFAAAAAA" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiagnosticPackStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" IsItemsHost="True" LastChildFill="False" />
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Testing Guide">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="840" HorizontalAlignment="Center">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="TESTER SETUP GUIDE" FontSize="26" FontWeight="Black" Foreground="#FFE67E22" VerticalAlignment="Center" Margin="0,0,16,0" />
                            <Button Content="Pop Out Overlay" Click="OpenGuideOverlay" Padding="12,4" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Text="— draggable overlay for single-screen users" FontSize="14" Foreground="#FF888888" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Follow these steps in order. Your profile, track map, and telemetry data are all captured automatically when you send diagnostics." FontSize="16" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                        <!-- STEP 1: CLOSE OTHER APPS -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="CLOSE OTHER APPS FIRST" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Close Moza Pit House, Logitech G HUB, Fanatec driver, SimHub, vJoy — any app that controls your wheel's FFB" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" This app needs exclusive access to your wheel's force feedback to work correctly" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" If Connect fails in Step 3, come back and check you closed everything" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1B3A1B" CornerRadius="4" Padding="12,6" Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="#FF66BB6A">
                                        <Run FontStyle="Italic" Text="Your pedals still work fine — they use standard Windows HID drivers, not the wheel base software. FFB/haptic pedals (Simucube ActivePedal, etc.) are separate devices and won't be affected." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 2: IN-GAME SETUP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SET UP AC EVO" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Car:" FontSize="16" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,6,0,2" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                    <TextBlock Text="BMW M4 GT3" FontSize="17" Foreground="#FF00E676" FontWeight="Bold" />
                                </Border>

                                <TextBlock Text="Track:" FontSize="16" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,4,0,2" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                    <TextBlock TextWrapping="Wrap" FontSize="16" Foreground="#FFFFD600">
                                        <Run Text="Pick ANY track" FontWeight="Bold" /><Run Text=" you know well — the more varied the better. Different corners expose different FFB issues." />
                                    </TextBlock>
                                </Border>

                                <TextBlock Text="Session Settings:" FontSize="16" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,4,0,4" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Mode: Single Player &#x2192; Practice" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Weather: Static &#x2192; Clear" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Track Grip: Optimal" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Start the session and get on track" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="FFB Settings:" FontSize="16" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,10,0,4" />
                                <Border Background="#FF3B1B1B" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFF1744" FontWeight="Bold" Text="&#x26A0;" /><Run Text=" Open the game's " /><Run FontWeight="Bold" Text="Settings &#x2192; Controls &#x2192; Force Feedback" /><Run Text=" and set " /><Run FontWeight="Bold" Foreground="#FFFFD600" Text="FFB Gain to 0" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFFF1744" Margin="0,4,0,0" TextWrapping="Wrap" FontWeight="Bold">
                                            <Run Text="&#x26A0; You must restart AC EVO for the FFB change to take effect." />
                                        </TextBlock>
                                        <TextBlock FontSize="15" Foreground="#FFFF8A65" Margin="0,4,0,0" TextWrapping="Wrap">
                                            <Run FontStyle="Italic" Text="This app replaces the game's FFB completely. If both are active, they will fight for control of your wheel, causing connection failures or erratic forces." />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 3: FFB TUNER SETUP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SET UP FFB TUNER" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Select your wheel from the dropdown at the top of the app" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Click " /><Run FontWeight="Bold" Text="Connect" /><Run Text=" — you should see the button turn green" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Click " /><Run FontWeight="Bold" Text="Load Profile" /><Run Text=" and select the test profile provided (e.g. &quot;BMW GT3&quot;)" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="d." /><Run Text=" Click " /><Run FontWeight="Bold" Text="START" /><Run Text=" to begin processing FFB" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#443B00" CornerRadius="4" Padding="12,6" Margin="0,10,0,0">
                                    <TextBlock Text="Make sure AC EVO is running and you're in the car BEFORE clicking START." FontSize="15" Foreground="#FFFFAB00" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 4: TRACK MAP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="RECORD THE TRACK MAP" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Go to the " /><Run FontWeight="Bold" Text="Track Map" /><Run Text=" tab" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Click " /><Run FontWeight="Bold" Text="Record Lap" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Drive one clean, steady lap — no cutting, no spins, no off-track" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="d." /><Run Text=" After crossing the start/finish line, click " /><Run FontWeight="Bold" Text="Complete &amp; Save" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1B3A1B" CornerRadius="4" Padding="12,6" Margin="0,10,0,0">
                                    <TextBlock Text="The track map is essential — it's included in the diagnostic pack and tells the dev exactly where issues occur on track." FontSize="15" Foreground="#FF66BB6A" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 5: DRIVE -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="5" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="DRIVE 3&#x2013;5 LAPS" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Drive normally but push hard. Try to cover:" FontSize="16" Foreground="#FFE0E0E0" Margin="0,4,0,8" TextWrapping="Wrap" />

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Heavy braking zones" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Fast sweeping corners" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Slow tight hairpins" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Kerb strikes" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Momentary off-track / grass" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Oversteer / understeer moments" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Watch for these issues:" FontSize="16" Foreground="#FFE0E0E0" FontWeight="Bold" Margin="0,10,0,6" TextWrapping="Wrap" />

                                <Border Background="#2A1A1A" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel snaps suddenly in one direction" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel oscillates rapidly back and forth" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Force pushes same direction you're steering" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel feels completely dead / numb" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Force bounces back after turning" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1A1A2E" CornerRadius="4" Padding="12,6" Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="#FFFFD600">
                                        <Run Text="Tip: Set up a wheel button as a snapshot trigger (Telemetry Profiler tab) — press it the exact moment something feels wrong to capture detailed data at that point." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 6: SEND DIAGNOSTICS -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="6" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SEND DIAGNOSTICS" FontSize="19" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Click the " /><Run FontWeight="Bold" Text="Send Diagnostics to Dev" /><Run Text=" button at the top of the app" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Describe what you felt in the feedback box (e.g. &quot;wheel snaps right on turn-in at high speed&quot;)" />
                                        </TextBlock>
                                        <TextBlock FontSize="16" Foreground="#FFE0E0E0" Margin="0,3" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Wait for the status bar to show " /><Run FontWeight="Bold" Foreground="#FF00E676" Text="Diagnostic pack sent" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1B3A1B" CornerRadius="4" Padding="12,6" Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="#FF66BB6A">
                                        <Run Text="This automatically saves and sends your current profile, track map, telemetry snapshot, and any manual snapshots. You'll be asked to describe any issues before it sends." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- QUICK REFERENCE -->
                        <Border Background="#FF1A1A2E" CornerRadius="6" Padding="16,14" Margin="0,8,0,16">
                            <StackPanel>
                                <TextBlock Text="QUICK REFERENCE" FontSize="17" FontWeight="Bold" Foreground="#FF00BCD4" Margin="0,0,0,8" />
                                <TextBlock FontSize="15" Foreground="#FFAAAAAA" FontFamily="Consolas" TextWrapping="Wrap" LineHeight="20">
                                    <Run Text="Close:" Foreground="#FF888888" /><Run Text=" Pit House, G HUB, Fanatec driver, SimHub" /><LineBreak />
                                    <Run Text="Car:" Foreground="#FF888888" /><Run Text=" BMW M4 GT3" /><LineBreak />
                                    <Run Text="Track:" Foreground="#FF888888" /><Run Text=" Any track (pick one you know)" /><LineBreak />
                                    <Run Text="Mode:" Foreground="#FF888888" /><Run Text=" Single Player / Practice" /><LineBreak />
                                    <Run Text="Weather:" Foreground="#FF888888" /><Run Text=" Static / Clear" /><LineBreak />
                                    <Run Text="Grip:" Foreground="#FF888888" /><Run Text=" Optimal" /><LineBreak />
                                    <Run Text="Laps:" Foreground="#FF888888" /><Run Text=" 1 map lap + 3-5 hot laps" /><LineBreak />
                                    <Run Text="Send:" Foreground="#FF888888" /><Run Text=" Click 'Send Diagnostics to Dev' when done" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Wheelbase FFB Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Tyre Related Settings -->
                        <StackPanel Grid.Column="0">

                            <!-- TYRE FORCES -->
                            <TextBlock Text="TYRE FORCES" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>

                                    <TextBlock Text="Front Axle" Style="{StaticResource SubSectionHeader}" />
                                    <controls:LabeledSlider Value="{Binding MzFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                        Label="Mz (Self-Align)" StringFormat="{}{0:F3}"
                                        Description="Main steering feel — the force that pulls the wheel back to center. Higher = stronger self-centering. Scaled by Mz Scale below."
                                        ShowCheckBox="True" IsChecked="{Binding MzFrontEnabled}"
                                        SectionColor="{StaticResource SectionTyreForces}" />
                                    <controls:LabeledSlider Value="{Binding FxFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                        Label="Fx (Longitudinal)" StringFormat="{}{0:F3}"
                                        Description="Braking and acceleration forces through the wheel. Scaled by Fx Scale below."
                                        ShowCheckBox="True" IsChecked="{Binding FxFrontEnabled}"
                                        SectionColor="{StaticResource SectionTyreForces}" />
                                    <controls:LabeledSlider Value="{Binding FyFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                        Label="Fy (Lateral)" StringFormat="{}{0:F3}"
                                        Description="Cornering loads — adds weight feel during turns. Suppressed near center (see Center Blend in Advanced). Scaled by Fy Scale below."
                                        ShowCheckBox="True" IsChecked="{Binding FyFrontEnabled}"
                                        SectionColor="{StaticResource SectionTyreForces}" />

                                    <TextBlock Text="Normalization Scales" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <controls:LabeledSlider Value="{Binding MzScale, Mode=TwoWay}" Minimum="1" Maximum="500" TickFrequency="0.5"
                                        Label="Mz Scale (Aligning)" StringFormat="{}{0:F3}" IsLogarithmic="True"
                                        Description="Divides raw Mz values to normalize them. Lower = stronger Mz feel. If steering feels weak, try lowering this. Affects both front and rear Mz."
                                        SectionColor="{StaticResource SectionTyreForces}" />
                                    <controls:LabeledSlider Value="{Binding FxScale, Mode=TwoWay}" Minimum="100" Maximum="20000" TickFrequency="100"
                                        Label="Fx Scale (Longitudinal)" StringFormat="{}{0:F0}" IsLogarithmic="True"
                                        Description="Divides raw Fx values to normalize them. Lower = stronger braking/acceleration feel. Affects both front and rear Fx."
                                        SectionColor="{StaticResource SectionTyreForces}" />
                                    <controls:LabeledSlider Value="{Binding FyScale, Mode=TwoWay}" Minimum="100" Maximum="20000" TickFrequency="100"
                                        Label="Fy Scale (Lateral)" StringFormat="{}{0:F0}" IsLogarithmic="True"
                                        Description="Divides raw Fy values to normalize them. Lower = stronger cornering feel. Affects both front and rear Fy."
                                        SectionColor="{StaticResource SectionTyreForces}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Tyre Settings">
                                        <StackPanel>
                                            <TextBlock Text="Rear Axle" Style="{StaticResource SubSectionHeader}" Margin="0,4,0,2" />
                                            <controls:LabeledSlider Value="{Binding MzRearGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                                Label="Mz Rear" StringFormat="{}{0:F3}"
                                                Description="Rear self-aligning torque — usually left off. Can add subtle rear-end feel but may increase noise. Uses same Mz Scale as front."
                                                ShowCheckBox="True" IsChecked="{Binding MzRearEnabled}"
                                                SectionColor="{StaticResource SectionTyreForces}" />
                                            <controls:LabeledSlider Value="{Binding FxRearGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                                Label="Fx Rear" StringFormat="{}{0:F3}"
                                                Description="Rear braking/acceleration feel. Uses the same Fx Scale as front."
                                                ShowCheckBox="True" IsChecked="{Binding FxRearEnabled}"
                                                SectionColor="{StaticResource SectionTyreForces}" />
                                            <controls:LabeledSlider Value="{Binding FyRearGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                                                Label="Fy Rear" StringFormat="{}{0:F3}"
                                                Description="Rear cornering force. Uses the same Fy Scale as front. Also affected by Center Blend."
                                                ShowCheckBox="True" IsChecked="{Binding FyRearEnabled}"
                                                SectionColor="{StaticResource SectionTyreForces}" />

                                            <TextBlock Text="Other" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                            <controls:LabeledSlider Value="{Binding FinalFfGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.1"
                                                Label="Game FFB Output" StringFormat="{}{0:F3}"
                                                Description="The game's built-in FFB signal. In Replace mode it's added on top of custom channels; in Overlay mode it's the base. See Mix Mode in Output &amp; Processing."
                                                ShowCheckBox="True" IsChecked="{Binding FinalFfEnabled}"
                                                SectionColor="{StaticResource SectionTyreForces}" />
                                            <controls:LabeledSlider Value="{Binding WheelLoadWeighting, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                                Label="Wheel Load Weighting" StringFormat="{}{0:F3}"
                                                Description="How much actual tire load affects force mixing. 0 = simple average, 1 = load-proportional (heavily-loaded tires contribute more)."
                                                SectionColor="{StaticResource SectionTyreForces}" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- TYRE SLIP -->
                            <TextBlock Text="TYRE SLIP" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <controls:LabeledSlider Value="{Binding SlipRatioGain, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                        Label="Slip Ratio Gain" StringFormat="{}{0:F3}"
                                        Description="Adds extra force during wheelspin or wheel lock-up. Needs Slip Threshold set correctly. Works together with Slip Angle Gain."
                                        SectionColor="{StaticResource SectionTyreSlip}" />
                                    <controls:LabeledSlider Value="{Binding SlipAngleGain, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                        Label="Slip Angle Gain" StringFormat="{}{0:F3}"
                                        Description="Adds extra force when tires slide sideways (oversteer). Needs Slip Threshold set correctly. Works together with Slip Ratio Gain."
                                        SectionColor="{StaticResource SectionTyreSlip}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Slip Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding SlipThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                                Label="Slip Threshold" StringFormat="{}{0:F3}"
                                                Description="Minimum slip level before the slip enhancer activates. Lower = more sensitive. Affects both Slip Ratio and Slip Angle."
                                                SectionColor="{StaticResource SectionTyreSlip}" />
                                            <DockPanel Margin="0,6">
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                    <CheckBox IsChecked="{Binding SlipUseFrontOnly}" Margin="0,0,12,0" />
                                                    <TextBlock Text="Front Wheels Only" FontSize="15" />
                                                </StackPanel>
                                            </DockPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- TIRE GRIP FEEL -->
                            <TextBlock Text="TIRE GRIP FEEL" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Feel the tires approaching and exceeding their grip limit. Front scrub gives a grainy texture as front tires reach peak. Rear slip warns you when the back end is stepping out." FontSize="13" Foreground="#FF888888" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    <controls:LabeledSlider Value="{Binding ScrubGain, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                        Label="Front Tire Scrub" StringFormat="{}{0:F3}"
                                        Description="High-frequency grain (30-50Hz) as front tires approach grip limit. Simulates rubber tearing at the contact patch before the Mz torque drops. 0 = off, 0.15 = subtle, 0.5 = strong."
                                        SectionColor="{StaticResource SectionGripFeel}" />
                                    <controls:LabeledSlider Value="{Binding RearSlipGain, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                        Label="Rear Slip Warning" StringFormat="{}{0:F3}"
                                        Description="Low-frequency rumble (12-25Hz) when rear tires lose grip. Detects rear slip angle and yaw acceleration for early oversteer warning. Distinctly different feel from front scrub. 0 = off, 0.25 = default, 0.5 = strong."
                                        SectionColor="{StaticResource SectionGripFeel}" />
                                </StackPanel>
                            </Border>

                            <!-- DAMPING & FRICTION -->
                            <TextBlock Text="DAMPING &amp; FRICTION" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <controls:LabeledSlider Value="{Binding SpeedDamping, Mode=TwoWay}" Minimum="0" Maximum="25" TickFrequency="0.001"
                                        Label="Speed Damping" StringFormat="{}{0:F3}"
                                        Description="Viscous damping — adds resistance that increases with car speed. Higher = heavier steering at speed. Scaled by Damping Speed Ref."
                                        SectionColor="{StaticResource SectionDamping}" />
                                    <controls:LabeledSlider Value="{Binding FrictionLevel, Mode=TwoWay}" Minimum="0" Maximum="20" TickFrequency="0.001"
                                        Label="Friction" StringFormat="{}{0:F3}"
                                        Description="Constant friction resistance when turning the wheel (Coulomb model). Higher = heavier, more resistant feel. Opposes steering motion regardless of speed."
                                        SectionColor="{StaticResource SectionDamping}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Damping Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding InertiaWeight, Mode=TwoWay}" Minimum="0" Maximum="20" TickFrequency="0.1"
                                                Label="Inertia" StringFormat="{}{0:F3}"
                                                Description="Simulates steering inertia — resists rapid direction changes based on angular acceleration. Increases with car speed."
                                                SectionColor="{StaticResource SectionDamping}" />
                                            <controls:LabeledSlider Value="{Binding DampingSpeedReference, Mode=TwoWay}" Minimum="50" Maximum="500" TickFrequency="5"
                                                Label="Damping Speed Ref (km/h)" StringFormat="{}{0:F0}"
                                                Description="Speed where speed-based damping reaches full strength. Lower = damping kicks in sooner. Affects Speed Damping and Inertia."
                                                SectionColor="{StaticResource SectionDamping}" />

                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- DYNAMIC EFFECTS -->
                            <TextBlock Text="DYNAMIC EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <controls:LabeledSlider Value="{Binding CorneringForce, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                        Label="Cornering Force" StringFormat="{}{0:F3}"
                                        Description="Adds force based on lateral G-forces during cornering. Gives a sense of how hard the car is turning. Combined with other Dynamic Effects."
                                        SectionColor="{StaticResource SectionDynamic}" />
                                    <controls:LabeledSlider Value="{Binding RoadFeel, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                        Label="Road Feel" StringFormat="{}{0:F3}"
                                        Description="Adds force from suspension compression changes (bumps, kerbs). Only detects rapid changes, not steady-state. Combined with other Dynamic Effects."
                                        SectionColor="{StaticResource SectionDynamic}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Dynamic Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding AccelerationBrakingForce, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                                Label="Accel/Braking Force" StringFormat="{}{0:F3}"
                                                Description="Adds force from forward/backward G-forces. Feel weight transfer under braking and acceleration. Combined with other Dynamic Effects."
                                                SectionColor="{StaticResource SectionDynamic}" />
                                            <controls:LabeledSlider Value="{Binding CarRotationForce, Mode=TwoWay}" Minimum="0" Maximum="5" TickFrequency="0.01"
                                                Label="Car Rotation Force" StringFormat="{}{0:F3}"
                                                Description="Adds force based on how fast the car is rotating (yaw rate). Helps feel slides and transitions. Combined with other Dynamic Effects."
                                                SectionColor="{StaticResource SectionDynamic}" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column: Output & Processing -->
                        <StackPanel Grid.Column="2">

                            <!-- OUTPUT & PROCESSING -->
                            <TextBlock Text="OUTPUT &amp; PROCESSING" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Mix Mode" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton Content="Replace" GroupName="MixMode" Margin="0,0,20,0" FontSize="15">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Replace" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                        <RadioButton Content="Overlay" GroupName="MixMode" FontSize="15">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Overlay" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </StackPanel>

                                    <TextBlock Text="Signal" Style="{StaticResource SubSectionHeader}" />
                                    <controls:LabeledSlider Value="{Binding OutputGain, Mode=TwoWay}" Minimum="0" Maximum="20" TickFrequency="0.001"
                                        Label="Output Gain" DisplayText="{Binding OutputGainNmText}" ValueWidth="100"
                                        Description="Master output strength — the final multiplier before the force limiter. Together with Max Force Limit and Wheel Max Torque, sets your peak Nm."
                                        SectionColor="{StaticResource SectionOutput}" />
                                    <controls:LabeledSlider Value="{Binding ForceSensitivity, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1"
                                        Label="Force Sensitivity" StringFormat="{}{0:F0}" IsLogarithmic="True"
                                        Description="Inverse sensitivity — higher values = weaker overall forces. This is the first gain stage affecting everything downstream. Works with Force Scale."
                                        SectionColor="{StaticResource SectionOutput}" />
                                    <controls:LabeledSlider Value="{Binding MaxForceLimit, Mode=TwoWay}" Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                                        Label="Max Force Limit" DisplayText="{Binding MaxForceLimitNmText}" ValueWidth="100"
                                        Description="Soft limiter — forces above this are gently rounded off instead of hard-clipping. Lower = less peak force but more consistent feel. Shows as Nm with your Wheel Max Torque."
                                        SectionColor="{StaticResource SectionOutput}" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding SignCorrectionEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Sign Correction (Self-Align)" FontSize="15" />
                                        </StackPanel>
                                    </DockPanel>
                                        <TextBlock Text="Forces forces near center to oppose steering direction (self-centering). Uses Center Suppress degrees. See Advanced for tuning." Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding ForceInvertEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Invert Force Direction" FontSize="15" />
                                        </StackPanel>
                                    </DockPanel>
                                        <TextBlock Text="Flips all forces at the wheel. Toggle this if the wheel pushes the wrong way during turns." Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Output Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding ForceScale, Mode=TwoWay}" Minimum="0.01" Maximum="20" TickFrequency="0.01"
                                                Label="Force Scale" StringFormat="{}{0:F3}" IsLogarithmic="True"
                                                Description="Divides the mixed channel signal to normalize it. Higher = weaker signal entering compression. Works together with Force Sensitivity."
                                                SectionColor="{StaticResource SectionOutput}" />

                                            <controls:LabeledSlider Value="{Binding SteeringLockDegrees, Mode=TwoWay}" Minimum="180" Maximum="1080" TickFrequency="10"
                                                Label="Steering Lock (deg)" StringFormat="{}{0}" IsLogarithmic="True"
                                                Description="Your wheel's total rotation in degrees (e.g. 900 = 450° each way). Used to scale steering angle for processing. Use Auto-Detect to set automatically."
                                                SectionColor="{StaticResource SectionOutput}" />
                                            <controls:LabeledSlider Value="{Binding WheelMaxTorqueNm, Mode=TwoWay}" Minimum="1" Maximum="25" TickFrequency="0.5"
                                                Label="Wheel Max Torque (Nm)" LabelWidth="185" StringFormat="{}{0:F3}"
                                                Description="Your wheelbase's maximum torque in Nm — used only for the Nm display. 5.5 = Moza R5, 9 = R9, 15 = R15, 25 = R25."
                                                SectionColor="{StaticResource SectionOutput}" />

                                            <TextBlock Text="Response Curve" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <ComboBox SelectedIndex="{Binding SelectedLutPresetIndex}" Width="160" FontSize="15" Padding="6,4">
                                                    <ComboBoxItem Content="Linear" />
                                                    <ComboBoxItem Content="Soft Center" />
                                                    <ComboBoxItem Content="Progressive" />
                                                    <ComboBoxItem Content="Dead Zone" />
                                                </ComboBox>
                                                <Button Content="Apply" Command="{Binding ApplyLutPresetCommand}" Margin="12,0,0,0" Padding="20,6" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- AUTO-GAIN -->
                            <Expander Style="{StaticResource SectionExpander}" Header="AUTO-GAIN" IsExpanded="False">
                                <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                    <StackPanel>
                                        <DockPanel Margin="0,6">
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding AutoGainEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Enable Auto-Gain" FontSize="15" />
                                            </StackPanel>
                                        </DockPanel>
                                        <controls:LabeledSlider Value="{Binding AutoGainScale, Mode=TwoWay}" Minimum="0.1" Maximum="5" TickFrequency="0.01"
                                            Label="Auto-Gain Scale" StringFormat="{}{0:F3}"
                                            Description="Target level when Auto-Gain is active. Higher = stronger auto-compensation so different cars feel similar. Only effective when Auto-Gain is enabled above."
                                            SectionColor="{StaticResource SectionOutput}" />
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- VIBRATION -->
                            <TextBlock Text="VIBRATION" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <controls:LabeledSlider Value="{Binding VibrationMasterGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                        Label="Master" StringFormat="{}{0:F3}"
                                        Description="Master volume for all vibration effects. Scales Curb, Slip, Road, and ABS together."
                                        SectionColor="{StaticResource SectionVibration}" />
                                    <controls:LabeledSlider Value="{Binding CurbGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                        Label="Curb" StringFormat="{}{0:F3}"
                                        Description="Kerb strike vibration intensity. Also scales suspension-derived kerb bumps in the main force."
                                        SectionColor="{StaticResource SectionVibration}" />
                                    <controls:LabeledSlider Value="{Binding SlipGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                        Label="Slip" StringFormat="{}{0:F3}"
                                        Description="Tire slip vibration intensity. Scaled by Master below."
                                        SectionColor="{StaticResource SectionVibration}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Vibration Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding RoadGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                                Label="Road" StringFormat="{}{0:F3}"
                                                Description="Road surface vibration intensity. Also scales suspension-derived road texture in the main force."
                                                SectionColor="{StaticResource SectionVibration}" />
                                            <controls:LabeledSlider Value="{Binding AbsGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                                Label="ABS" StringFormat="{}{0:F3}"
                                                Description="ABS pulse vibration intensity. Also adds pulses to the main steering force when ABS activates."
                                                SectionColor="{StaticResource SectionVibration}" />
                                            <controls:LabeledSlider Value="{Binding SuspensionRoadGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.01"
                                                Label="Suspension Road" StringFormat="{}{0:F3}"
                                                Description="Suspension-derived road texture gain for the main force channel. Works with Road and Curb vibration gains."
                                                SectionColor="{StaticResource SectionVibration}" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- LFE LOW-FREQUENCY EFFECTS -->
                            <TextBlock Text="LFE — LOW-FREQUENCY EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="iRacing-style low-frequency rumble. Generates deep oscillations from suspension travel and speed, felt as chassis road texture on strong wheel bases (Moza R9+)." FontSize="13" Foreground="#FF888888" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    <DockPanel Margin="0,6">
                                        <TextBlock Text="Enable LFE" Width="160" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" DockPanel.Dock="Left" />
                                        <CheckBox IsChecked="{Binding LfeEnabled}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <controls:LabeledSlider Value="{Binding LfeGain, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                        Label="LFE Gain" StringFormat="{}{0:F3}"
                                        Description="Overall intensity of the low-frequency effect mixed into the main force."
                                        SectionColor="{StaticResource SectionLfe}" />
                                    <controls:LabeledSlider Value="{Binding LfeFrequency, Mode=TwoWay}" Minimum="3" Maximum="30" TickFrequency="0.5"
                                        Label="Frequency" StringFormat="{}{0:F1}" Suffix=" Hz"
                                        Description="Base rumble frequency in Hz. Lower = deeper thump, higher = faster buzz."
                                        SectionColor="{StaticResource SectionLfe}" />
                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed LFE Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding LfeSuspensionDrive, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                                Label="Suspension Drive" StringFormat="{}{0:F3}"
                                                Description="How much suspension travel drives the LFE envelope. Higher = more reactive to bumps."
                                                SectionColor="{StaticResource SectionLfe}" />
                                            <controls:LabeledSlider Value="{Binding LfeSpeedScaling, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                                Label="Speed Scaling" StringFormat="{}{0:F3}"
                                                Description="How much vehicle speed modulates LFE frequency. Higher = faster rumble at speed."
                                                SectionColor="{StaticResource SectionLfe}" />
                                            <controls:LabeledSlider Value="{Binding LfeRpmDrive, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                                Label="RPM Drive" StringFormat="{}{0:F3}"
                                                Description="How much engine RPM drives the LFE intensity and frequency. Higher = more engine vibration rumble at high RPM."
                                                SectionColor="{StaticResource SectionLfe}" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="SIGNAL PROCESSING" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Signal Processing" Style="{StaticResource SubSectionHeader}" />
                                    <controls:LabeledSlider Value="{Binding MaxSlewRate, Mode=TwoWay}" Minimum="0.03" Maximum="0.50" TickFrequency="0.001"
                                        Label="Max Slew Rate" LabelWidth="185" StringFormat="{}{0:F4}"
                                        Description="Maximum force change per frame. Lower = smoother/slower transitions, higher = snappier response. Also auto-scales down at low and very high speed."
                                        SectionColor="{StaticResource SectionSignal}" />

                                    <TextBlock Text="Center Feel" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <controls:LabeledSlider Value="{Binding CenterSuppressionDegrees, Mode=TwoWay}" Minimum="0" Maximum="30" TickFrequency="0.1"
                                        Label="Center Suppress (deg)" LabelWidth="185" StringFormat="{}{0:F3}"
                                        Description="Steering angle zone near center where forces are faded to zero (quadratic ramp). Wider = larger dead-feel zone. Only active when Sign Correction is enabled."
                                        SectionColor="{StaticResource SectionSignal}" />

                                    <Expander Style="{StaticResource SectionExpander}" Header="Detailed Signal Settings">
                                        <StackPanel>
                                            <controls:LabeledSlider Value="{Binding NoiseFloor, Mode=TwoWay}" Minimum="0" Maximum="0.05" TickFrequency="0.0005"
                                                Label="Noise Floor" LabelWidth="185" StringFormat="{}{0:F4}"
                                                Description="Forces below this are silenced. Eliminates tiny vibrations when the wheel should be still. Higher = quieter center but may lose fine detail. Also affects Hysteresis triggering."
                                                SectionColor="{StaticResource SectionSignal}" />

                                            <controls:LabeledSlider Value="{Binding CenterKneePower, Mode=TwoWay}" Minimum="0.5" Maximum="3.0" TickFrequency="0.01"
                                                Label="Center Knee Power" LabelWidth="185" StringFormat="{}{0:F3}"
                                                Description="Shapes how forces ramp up from zero. 1.0 = normal, higher = lighter at center with sharper force onset. Interacts with Compression Power."
                                                SectionColor="{StaticResource SectionSignal}" />
                                            <controls:LabeledSlider Value="{Binding CenterBlendDegrees, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                                                Label="Center Blend (deg)" LabelWidth="185" StringFormat="{}{0:F3}"
                                                Description="Steering angle where Fy (cornering force) is suppressed near center. Prevents Fy buzz at straight-ahead. Higher = wider clean zone but less mid-corner detail. Affects front and rear Fy."
                                                SectionColor="{StaticResource SectionSignal}" />

                                            <TextBlock Text="Damping Tuning" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                            <controls:LabeledSlider Value="{Binding SteerVelocityReference, Mode=TwoWay}" Minimum="1" Maximum="50" TickFrequency="1"
                                                Label="Steer Vel Reference" LabelWidth="185" StringFormat="{}{0:F0}"
                                                Description="Reference speed for steering velocity normalization. Higher = less damping response to fast inputs, lower = damping activates with slower wheel movement. Affects all damping forces."
                                                SectionColor="{StaticResource SectionSignal}" />
                                            <controls:LabeledSlider Value="{Binding VelocityDeadzone, Mode=TwoWay}" Minimum="0" Maximum="0.5" TickFrequency="0.01"
                                                Label="Velocity Deadzone" LabelWidth="185" StringFormat="{}{0:F3}"
                                                Description="Minimum steering speed for damping to activate. Higher = damping only during fast turns. Helps prevent center bounce-back. Affects all damping forces."
                                                SectionColor="{StaticResource SectionSignal}" />

                                            <TextBlock Text="Smoothing" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                            <controls:LabeledSlider Value="{Binding LowSpeedSmoothKmh, Mode=TwoWay}" Minimum="0" Maximum="100" TickFrequency="1"
                                                Label="Low Speed Smooth (km/h)" LabelWidth="185" StringFormat="{}{0:F0}"
                                                Description="Speed below which all channel smoothing is increased. Higher = smoother low-speed feel but less detail in slow corners. Affects all force channels (Mz, Fx, Fy)."
                                                SectionColor="{StaticResource SectionSignal}" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Effect Equalizer">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Margin="16,8">
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="FFB EFFECT EQUALIZER" Style="{StaticResource GroupHeader}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Enable" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <CheckBox IsChecked="{Binding EqEnabled}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="10-band parametric EQ for the FFB force signal. Boost or cut frequency ranges to shape how forces feel through the wheel." FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />

                        <Border Background="#FF22223A" CornerRadius="8" Padding="12,16" Margin="0,0,0,12">
                            <Grid x:Name="EqSliderGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Band 0: Steering Weight (2 Hz) -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="STEER&#x0A;WEIGHT" FontSize="13" FontWeight="Bold" Foreground="#FF90CAF9" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="2 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider0" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand0Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel0" Text="{Binding EqBand0Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF90CAF9" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Heavy resistance,&#x0A;parking effort" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 1: Weight Transfer (4 Hz) -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="WEIGHT&#x0A;TRANSFER" FontSize="13" FontWeight="Bold" Foreground="#FF4FC3F7" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="4 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider1" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand1Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel1" Text="{Binding EqBand1Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF4FC3F7" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Body roll, brake&#x0A;dive, accel squat" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 2: Self-Align Torque (8 Hz) -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="SELF&#x0A;ALIGN" FontSize="13" FontWeight="Bold" Foreground="#FF4DB6AC" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="8 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider2" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand2Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel2" Text="{Binding EqBand2Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF4DB6AC" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Self-centering,&#x0A;grip balance feel" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 3: Steering Precision (12 Hz) -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="STEERING&#x0A;PRECISION" FontSize="13" FontWeight="Bold" Foreground="#FF66BB6A" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="12 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider3" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand3Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel3" Text="{Binding EqBand3Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF66BB6A" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Line tracking,&#x0A;small corrections" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 4: Turn-In Response (18 Hz) -->
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="TURN-IN&#x0A;RESPONSE" FontSize="13" FontWeight="Bold" Foreground="#FF9CCC65" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="18 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider4" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand4Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel4" Text="{Binding EqBand4Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF9CCC65" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Initial bite,&#x0A;direction change" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 5: Road Texture (25 Hz) -->
                                <StackPanel Grid.Column="5" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="ROAD&#x0A;TEXTURE" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="25 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider5" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand5Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel5" Text="{Binding EqBand5Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Tarmac grain,&#x0A;surface roughness" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 6: Bump Detail (35 Hz) -->
                                <StackPanel Grid.Column="6" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="BUMP&#x0A;DETAIL" FontSize="13" FontWeight="Bold" Foreground="#FFFFB74D" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="35 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider6" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand6Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel6" Text="{Binding EqBand6Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFFB74D" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Patches, seams,&#x0A;road features" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 7: Kerb Strike (50 Hz) -->
                                <StackPanel Grid.Column="7" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="KERB&#x0A;STRIKE" FontSize="13" FontWeight="Bold" Foreground="#FFFF9800" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="50 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider7" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand7Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel7" Text="{Binding EqBand7Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFF9800" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Kerb hits, potholes,&#x0A;sharp impacts" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 8: Chatter (70 Hz) -->
                                <StackPanel Grid.Column="8" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="WHEEL&#x0A;CHATTER" FontSize="13" FontWeight="Bold" Foreground="#FFEF5350" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="70 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider8" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand8Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel8" Text="{Binding EqBand8Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFEF5350" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="Rapid vibration,&#x0A;wheel buzz" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Band 9: Fine Buzz (100 Hz) -->
                                <StackPanel Grid.Column="9" HorizontalAlignment="Center" Margin="2,0">
                                    <TextBlock Text="ABS/TC&#x0A;PULSES" FontSize="13" FontWeight="Bold" Foreground="#FFCE93D8" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                                    <TextBlock Text="100 Hz" FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Slider x:Name="EqSlider9" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand9Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="160" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                                    <TextBlock x:Name="EqValueLabel9" Text="{Binding EqBand9Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFCE93D8" HorizontalAlignment="Center" Margin="0,2,0,4" />
                                    <TextBlock Text="ABS/TC pulsing,&#x0A;finest vibration" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>

                                <!-- Connecting curve overlay -->
                                <Canvas x:Name="EqCurveCanvas" Grid.ColumnSpan="10" IsHitTestVisible="False" />
                            </Grid>
                        </Border>

                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8" Margin="0,4,0,0">
                            <TextBlock Text="Tip: Start flat (0 dB), then boost/cut one band at a time while driving. The EQ shapes the final force signal right before it reaches the wheel. 10-band parametric at ~333 Hz sample rate." FontSize="12" Foreground="#FF888888" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Pedal FFB Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PEDAL FORCE FEEDBACK" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Placeholder — pedal-specific FFB controls will be added here." FontSize="14" Foreground="#FF999999" Margin="0,4" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Track Map">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF22223A" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Button Content="Pop Out Map" Click="OpenTrackMapPopout" Padding="12,4" FontSize="14" FontWeight="Bold" Margin="0,0,6,0" />
                                <Button Content="Record Lap" Command="{Binding StartTrackMapRecordingCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding StopTrackMapRecordingCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Complete &amp; Save" Command="{Binding CompleteAndSaveTrackMapCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Export" Command="{Binding ExportTrackProfileCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Import" Command="{Binding ImportTrackProfileCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Clear" Command="{Binding ClearTrackMapCommand}" Padding="12,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Background="#FF444466" Margin="8,0" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Ellipse Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                                    <Setter Property="Fill" Value="#FFE67E22" />
                                                </DataTrigger>
