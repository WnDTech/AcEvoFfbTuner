                                <StackPanel>
                                    <Border Background="#443B00" CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
                                        <TextBlock Text="WARNING: These parameters can adversely affect the FFB experience if not used correctly. Modify with caution." FontSize="11" Foreground="#FFFFAB00" TextWrapping="Wrap" />
