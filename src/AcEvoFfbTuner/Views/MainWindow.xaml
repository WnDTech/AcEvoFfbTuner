                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="10" Height="10" Fill="#FF00BCD4" Margin="0,0,6,0" VerticalAlignment="Center" />
