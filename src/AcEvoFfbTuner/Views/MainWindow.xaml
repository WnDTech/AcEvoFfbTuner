                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Track Map">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF22223A" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Button Content="Record Lap" Command="{Binding StartTrackMapRecordingCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding StopTrackMapRecordingCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Complete &amp; Save" Command="{Binding CompleteAndSaveTrackMapCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Export" Command="{Binding ExportTrackProfileCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Import" Command="{Binding ImportTrackProfileCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Clear" Command="{Binding ClearTrackMapCommand}" Padding="12,4" FontSize="12" Style="{StaticResource OutlinedButton}" />
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Background="#FF444466" Margin="8,0" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Ellipse Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                                    <Setter Property="Fill" Value="#FFFF4500" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                                    <Setter Property="Fill" Value="#FF00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="11" Foreground="#FFAAAAAA" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="No Map" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                                    <Setter Property="Text" Value="Recording..." />
                                                    <Setter Property="Foreground" Value="#FFFF4500" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                                    <Setter Property="Text" Value="Map Ready" />
                                                    <Setter Property="Foreground" Value="#FF00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="4" Width="1" Background="#FF444466" Margin="8,0" />

                            <StackPanel Grid.Column="5" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Track" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding DetectedTrackName, FallbackValue='--'}" FontSize="11" FontWeight="Bold" Foreground="#FF00E676" MaxWidth="120" />
                            </StackPanel>

                            <StackPanel Grid.Column="6" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Progress" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapProgress" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" />
                            </StackPanel>
                            <StackPanel Grid.Column="7" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Dist from Center" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapDistance" Text="-- m" FontSize="14" FontWeight="Bold" Foreground="#FF00BCD4" />
                            </StackPanel>
                            <StackPanel Grid.Column="8" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Track Status" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapOnTrack" Text="--" FontSize="14" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnTrackMap}" Value="True">
                                                    <Setter Property="Text" Value="ON TRACK" />
                                                    <Setter Property="Foreground" Value="#FF00E676" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOnTrackMap}" Value="False">
                                                    <Setter Property="Text" Value="OFF TRACK" />
                                                    <Setter Property="Foreground" Value="#FFFF4500" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                             <StackPanel Grid.Column="9" Margin="8,0" VerticalAlignment="Center">
                                 <TextBlock Text="Waypoints" FontSize="9" Foreground="#FF888888" />
                                 <TextBlock x:Name="TrackMapWaypoints" Text="--" FontSize="14" Foreground="#FFE0E0E0" />
                             </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FF22223A" CornerRadius="6" Padding="6,3" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Corner" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapCorner" Text="--" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Sector" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapSector" Text="--" FontSize="13" FontWeight="Bold" Foreground="#FF00BCD4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Corners" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding CornerCount, FallbackValue=0}" FontSize="13" Foreground="#FFE0E0E0" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Laps" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding CompletedLapCount, FallbackValue=0}" FontSize="13" Foreground="#FFE0E0E0" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="6,0,12,0" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInPit}" Value="True">
                                                    <Setter Property="Fill" Value="#FFFFD600" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text=" PIT" FontSize="10" Foreground="#FF888888" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="6" Margin="6,0,6,0" VerticalAlignment="Center">
                                 <CheckBox Content="Heatmap" IsChecked="{Binding ShowForceHeatmap}" Foreground="#FFAAAAAA" FontSize="11" />
                             </StackPanel>
                             <StackPanel Grid.Column="7" Margin="6,0,6,0" VerticalAlignment="Center">
                                 <CheckBox Content="Edges" IsChecked="{Binding ShowTrackEdges}" Foreground="#FFAAAAAA" FontSize="11" />
                             </StackPanel>
                            <StackPanel Grid.Column="5" Margin="6,0,6,0" VerticalAlignment="Center" Visibility="{Binding IsTrackMapAvailable, Converter={StaticResource BoolToVis}}">
                                 <CheckBox Content="Diagnostics" IsChecked="{Binding ShowDiagnostics}" Foreground="#FFFF8A65" FontSize="11" />
                             </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="#FF151525" CornerRadius="6">
                        <Canvas x:Name="TrackMapCanvas" ClipToBounds="True" />
                    </Border>

                    <Border Grid.Row="3" Background="#FF1A1A2E" CornerRadius="4" Padding="8,4" Margin="0,4,0,0"
                            Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="FFB DIAGNOSTIC LEGEND" FontSize="10" Foreground="#FF888888" FontWeight="Bold" Margin="0,0,0,4" />
                            <UniformGrid Columns="3">
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <Ellipse Width="10" Height="10" Fill="#FF00E676" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Expected" FontWeight="Bold" Foreground="#FF00E676" /><Run Text=" - Normal corner forces" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <Ellipse Width="10" Height="10" Fill="#FFFFD600" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Notable" FontWeight="Bold" Foreground="#FFFFD600" /><Run Text=" - Event, not suspicious" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,2">
                                    <Ellipse Width="10" Height="10" Fill="#FFFF0000" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Suspicious" FontWeight="Bold" Foreground="#FFFF0000" /><Run Text=" - Possible code issue" />
                                    </TextBlock>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock FontSize="9" Foreground="#FF777777" Margin="0,3,0,0" TextWrapping="Wrap">
                                <Run Text="Expected:" FontWeight="Bold" /> Snap at corner entry/exit, understeer/oversteer forces, braking weight transfer.
                                <LineBreak />
                                <Run Text="Suspicious:" FontWeight="Bold" /> Snap on a straight, oscillation with no steering input, force pushing same direction as wheel.
                                <LineBreak />
                                <Run Text="Verdict:" FontWeight="Bold" /> If most dots are green and cluster at corners, it's your driving. If red dots appear on straights, check FFB code.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Background="#FF1A1A2E" CornerRadius="4" Padding="8,4" Margin="0,4,0,0"
                            Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Apply Profile Changes" Command="{Binding ApplyRecommendationsCommand}"
                                    Padding="10,4" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Top"
                                    Background="#FF2E7D32" Foreground="#FFE0E0E0" BorderThickness="0" />
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding DiagnosticCoverage, FallbackValue='Coverage: 0%'}" FontSize="10" Foreground="#FF00BCD4" FontWeight="Bold" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding DiagnosticSummary, FallbackValue=''}" FontSize="9" Foreground="#FFAAAAAA" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </DockPanel>
                                <TextBlock Text="RECOMMENDATIONS" FontSize="10" Foreground="#FF00E676" FontWeight="Bold" Margin="0,0,0,2" Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}" />
                                <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="11"
                                         Text="{Binding RecommendationsText, Mode=OneWay}"
                                         TextWrapping="Wrap" MaxHeight="100"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="5" Background="#FF22223A" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="X:" FontSize="11" Foreground="#FF888888" Margin="0,0,4,0" />
                                    <TextBlock x:Name="TrackMapCarX" Text="--" FontSize="12" Foreground="#FFE0E0E0" FontFamily="Consolas" Margin="0,0,16,0" />
                                    <TextBlock Text="Z:" FontSize="11" Foreground="#FF888888" Margin="0,0,4,0" />
                                    <TextBlock x:Name="TrackMapCarZ" Text="--" FontSize="12" Foreground="#FFE0E0E0" FontFamily="Consolas" Margin="0,0,16,0" />
                                    <TextBlock Text="Sector Stats:" FontSize="11" Foreground="#FF888888" Margin="0,0,4,0" />
                                    <TextBlock x:Name="TrackMapSectorStats" Text="--" FontSize="12" Foreground="#FFE0E0E0" FontFamily="Consolas" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding DiagnosticVerdict, FallbackValue=''}" FontSize="11" Foreground="#FFFF4500" FontWeight="Bold" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0" Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Last Event:" FontSize="10" Foreground="#FF888888" Margin="0,0,4,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding LastEventInfo, FallbackValue=''}" FontSize="10" Foreground="#FFFF8A65" FontFamily="Consolas" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="600" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Debug">
                <DockPanel Background="#FF151525">
                    <Button DockPanel.Dock="Top" Content="Copy All to Clipboard" Margin="16,12,16,8"
                            Padding="12,6" FontSize="12" HorizontalAlignment="Left"
                            Background="#FF333355" Foreground="#FFE0E0E0" BorderThickness="0"
                            Click="CopyDebugToClipboard" />
                    <ScrollViewer Padding="16">
                        <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="13"
                                 Text="{Binding DebugSnapshot, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
            <TabItem Header="Calibration">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="WHEEL CALIBRATION" FontSize="22" FontWeight="Black" Foreground="#FFFF4500" Margin="0,0,0,4" />
                        <TextBlock Text="Find your wheel's force baseline before tuning FFB" FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                        <TextBlock Text="Step 1: Find your minimum perceptible force" FontSize="16" FontWeight="Bold" Foreground="#FFFF4500" Margin="0,0,0,8" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" Margin="0,0,0,12" LineHeight="20">
                                    Slowly drag the slider right until you FIRST feel the wheel resist. Note that value.
                                </TextBlock>
                                <DockPanel Margin="0,6">
                                    <TextBlock Text="Test Force" Width="100" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding TestForceLevel, StringFormat='{}{0:F2}'}" Width="60" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#FFFF4500" DockPanel.Dock="Right" />
                                    <Slider Value="{Binding TestForceLevel}" Minimum="-1.0" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Send Force" Command="{Binding SendTestForceCommand}" Padding="16,6" Margin="0,0,8,0" />
                                    <Button Content="Stop" Command="{Binding StopTestForceCommand}" Padding="16,6" Margin="0,0,8,0" Style="{StaticResource OutlinedButton}" />
                                    <Button Content="PANIC" Command="{Binding PanicStopCommand}" Padding="16,6" Style="{StaticResource PanicButton}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Step 2: Structured test plan" FontSize="16" FontWeight="Bold" Foreground="#FFFF4500" Margin="0,0,0,8" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" LineHeight="22" Margin="0,0,0,0">
                                    With the telemetry STARTED and game running, do these specific tests and report what you feel:<LineBreak/><LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">A. Static in garage:</Run> Does the wheel feel completely still? (should be zero)<LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">B. Drive straight at 50 km/h:</Run> Does the wheel self-center gently? How strong 1-10?<LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">C. Drive straight at 150 km/h:</Run> Same - how strong? Does it feel different from 50?<LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">D. Gentle curve at 80 km/h:</Run> Can you feel the force build as you turn? 1-10?<LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">E. Hard cornering:</Run> Does it clip/notch or stay smooth? Does the wheel go notchy?<LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF00E676">F. Slalom/quick left-right:</Run> Does the wheel feel laggy, oscillate, or track naturally?<LineBreak/><LineBreak/>
                                    For each test, note the Force Output, Speed, and Clipping values shown in the Visualization tab.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Step 3: What the values mean" FontSize="16" FontWeight="Bold" Foreground="#FFFF4500" Margin="0,0,0,8" />
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" LineHeight="22">
                                    <Run Foreground="#FFFF4500" FontWeight="Bold">Force Output 0.0-0.3</Run> = Too weak, increase OutputGain or decrease MzScale<LineBreak/>
                                    <Run Foreground="#FFFF4500" FontWeight="Bold">Force Output 0.3-0.7</Run> = Good range for most driving<LineBreak/>
                                    <Run Foreground="#FFFF4500" FontWeight="Bold">Force Output 0.7-1.0</Run> = Strong, only under hard cornering<LineBreak/>
                                    <Run Foreground="#FFFF4500" FontWeight="Bold">CLIPPING = True</Run> = Wheel can't produce more force, reduce gains<LineBreak/><LineBreak/>
                                    <Run Foreground="#FF00E676" FontWeight="Bold">Test Force slider:</Run> 0.10 = barely perceptible, 0.50 = moderate, 1.00 = max your wheel can do.
                                    If 1.00 doesn't feel very strong, your wheel may need higher OutputGain.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FF1A1A2E" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Fill" Value="#FF00E676" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Foreground="#FFAAAAAA" />
                <TextBlock Grid.Column="2" Text="{Binding DeviceName}" VerticalAlignment="Center" FontSize="12" Margin="16,0" Foreground="#FFAAAAAA" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF555555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                    <Setter Property="Foreground" Value="#FF00E676" />
                                    <Setter Property="Text" Value="Game: Connected" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGameConnected}" Value="False">
                                    <Setter Property="Text" Value="Game: Disconnected" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Column="4" Text="{Binding PacketsPerSecond, StringFormat='{}{0} pkt/s'}" VerticalAlignment="Center" FontSize="12" Margin="8,0" Foreground="#FFAAAAAA" />
            </Grid>
        </Border>
    </Grid>
</Window>
