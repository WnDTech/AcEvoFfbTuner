                                        <TextBlock Text="Normalization divisor for steer velocity — affects damping sensitivity" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Velocity Deadzone" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding VelocityDeadzone, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding VelocityDeadzone}" Minimum="0" Maximum="0.5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Steer velocity below which damping zeroes — affects center bounce-back" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>

                                    <TextBlock Text="Smoothing" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Smooth (km/h)" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedSmoothKmh, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedSmoothKmh}" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed below which channel smoothing is increased — affects pit lane feel" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- PROFILES -->
                            <TextBlock Text="PROFILES" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" Margin="0,4" Padding="16,6" />
