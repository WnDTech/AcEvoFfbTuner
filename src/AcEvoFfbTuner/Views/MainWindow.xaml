                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Brightness" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LedBrightness, StringFormat='{}{0}%'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LedBrightness}" Minimum="5" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="LED brightness for SDK-controlled wheels" Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- FLASH SETTINGS -->
                            <TextBlock Text="FLASH EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
