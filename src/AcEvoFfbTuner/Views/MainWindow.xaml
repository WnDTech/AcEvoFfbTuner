<Window x:Class="AcEvoFfbTuner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
        xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
        Title="AC Evo FFB Tuner" Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/wheel.ico"
        Background="#FF0D0D0D"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#FF1A1A2E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" Margin="0,0,8,0" />
                    <TextBlock Text="FFB TUNER" FontSize="22" FontWeight="Light" Foreground="#FFE0E0E0" VerticalAlignment="Bottom" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="13" Foreground="#FF888888" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="ProductName" Width="220" Margin="8,0" />
                    <Button Content="Connect" Command="{Binding ConnectDeviceCommand}" Margin="4,0" />
                    <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" Margin="4,0" Style="{StaticResource OutlinedButton}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Profile:" FontSize="12" Foreground="#FF888888" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" Width="320" Margin="4,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="1" Background="#FF14142A" Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding IsRunning}" Command="{Binding ToggleTelemetryCommand}"
                                  Margin="0,0,4,0" x:Name="StartStopToggle">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="START" />
                                <Setter Property="Background" Value="#FF2A2A45" />
                                <Setter Property="Foreground" Value="#FFE0E0E0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="#FF555555" />
                                <Setter Property="Padding" Value="20,6" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Content" Value="STOP" />
                                        <Setter Property="Background" Value="#FFE67E22" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button Content="PANIC" Command="{Binding PanicStopCommand}" Margin="4,0" Style="{StaticResource PanicButton}" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Button Content="Send Diagnostics to Dev" Command="{Binding SendDiagnosticPackCommand}"
                            Padding="14,4" FontSize="11" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSendingDiagnosticPack}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="Sending..." FontSize="11" Foreground="#FFE67E22" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSendingDiagnosticPack}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" IsItemsHost="True" LastChildFill="False" />
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Testing Guide">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="800" HorizontalAlignment="Center">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="TESTER SETUP GUIDE" FontSize="22" FontWeight="Black" Foreground="#FFE67E22" VerticalAlignment="Center" Margin="0,0,16,0" />
                            <Button Content="Pop Out Overlay" Click="OpenGuideOverlay" Padding="12,4" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Text="— draggable overlay for single-screen users" FontSize="11" Foreground="#FF888888" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Follow these steps in order. Your profile, track map, and telemetry data are all captured automatically when you send diagnostics." FontSize="13" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap" />
                        <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

                        <!-- STEP 1: IN-GAME SETUP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                                        <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SET UP AC EVO" FontSize="16" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Car:" FontSize="13" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,6,0,2" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                    <TextBlock Text="BMW M4 GT3" FontSize="14" Foreground="#FF00E676" FontWeight="Bold" />
                                </Border>

                                <TextBlock Text="Track:" FontSize="13" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,4,0,2" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FFFFD600">
                                        <Run Text="Pick ANY track" FontWeight="Bold" /><Run Text=" you know well — the more varied the better. Different tracks expose different FFB issues." />
                                    </TextBlock>
                                </Border>

                                <TextBlock Text="Session Settings:" FontSize="13" FontWeight="Bold" Foreground="#FFE0E0E0" Margin="0,4,0,4" />
                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,6">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Mode: Single Player &#x2192; Practice" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Weather: Static &#x2192; Clear" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Track Grip: Optimal" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text="  Start the session and get on track" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 2: FFB TUNER SETUP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                                        <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SET UP FFB TUNER" FontSize="16" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Select your wheel from the dropdown at the top" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Click" /><Run Text=" Connect" FontWeight="Bold" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Select the test profile from the dropdown (e.g. &quot;BMW GT3&quot;)" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="d." /><Run Text=" Click" /><Run Text=" START" FontWeight="Bold" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#443B00" CornerRadius="4" Padding="10,6" Margin="0,10,0,0">
                                    <TextBlock Text="Make sure AC EVO is running and you're in the car BEFORE clicking START." FontSize="11" Foreground="#FFFFAB00" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 3: TRACK MAP -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                                        <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="RECORD THE TRACK MAP" FontSize="16" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Go to the" /><Run Text=" Track Map" FontWeight="Bold" /><Run Text=" tab" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Click" /><Run Text=" Record Lap" FontWeight="Bold" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Drive one clean, steady lap — no cutting, no spins" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="d." /><Run Text=" After crossing the start/finish line, click" /><Run Text=" Complete &amp; Save" FontWeight="Bold" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1B3A1B" CornerRadius="4" Padding="10,6" Margin="0,10,0,0">
                                    <TextBlock Text="The track map is essential — it's included in the diagnostic pack and tells the dev exactly where issues occur on track." FontSize="11" Foreground="#FF66BB6A" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 4: DRIVE -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                                        <TextBlock Text="4" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="DRIVE 3&#x2013;5 LAPS" FontSize="16" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Drive normally but push hard. Try to cover:" FontSize="13" Foreground="#FFE0E0E0" Margin="0,4,0,8" TextWrapping="Wrap" />

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Heavy braking zones" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Fast sweeping corners" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Slow tight hairpins" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Kerb strikes" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Momentary off-track / grass" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FF00E676" Text="&#x2022;" /><Run Text=" Oversteer / understeer moments" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Watch for these issues:" FontSize="13" Foreground="#FFE0E0E0" FontWeight="Bold" Margin="0,10,0,6" TextWrapping="Wrap" />

                                <Border Background="#2A1A1A" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel snaps suddenly in one direction" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel oscillates rapidly back and forth" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Force pushes same direction you're steering" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Wheel feels completely dead / numb" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2">
                                            <Run Foreground="#FFFF0000" Text="&#x26A0;" /><Run Text=" Force bounces back after turning" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1A1A2E" CornerRadius="4" Padding="10,6" Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFFFD600">
                                        <Run Text="Optional: If you set up a wheel snapshot button (Telemetry Profiler tab), press it when something feels wrong — this captures extra data at that exact moment." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STEP 5: SEND DIAGNOSTICS -->
                        <Border Background="#FF22223A" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFE67E22" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                                        <TextBlock Text="5" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SEND DIAGNOSTICS" FontSize="16" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Click the" /><Run Text=" Send Diagnostics to Dev" FontWeight="Bold" /><Run Text=" button at the top of the app" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Describe what you felt in the feedback box that appears" />
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#FFE0E0E0" Margin="0,2" TextWrapping="Wrap">
                                            <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Wait for the status bar to show " /><Run FontWeight="Bold" Text="Diagnostic pack sent" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1B3A1B" CornerRadius="4" Padding="10,6" Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF66BB6A">
                                        <Run Text="This automatically saves and sends your current profile, track map, telemetry snapshot, and any manual snapshots. You'll be asked to describe any issues before it sends." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- QUICK REFERENCE -->
                        <Border Background="#FF1A1A2E" CornerRadius="6" Padding="16,14" Margin="0,8,0,16">
                            <StackPanel>
                                <TextBlock Text="QUICK REFERENCE" FontSize="14" FontWeight="Bold" Foreground="#FF00BCD4" Margin="0,0,0,8" />
                                <TextBlock FontSize="12" Foreground="#FFAAAAAA" FontFamily="Consolas" TextWrapping="Wrap" LineHeight="18">
                                    <Run Text="Car:" Foreground="#FF888888" /><Run Text=" BMW M4 GT3" /><LineBreak />
                                    <Run Text="Track:" Foreground="#FF888888" /><Run Text=" Any track (pick one you know)" /><LineBreak />
                                    <Run Text="Mode:" Foreground="#FF888888" /><Run Text=" Single Player / Practice" /><LineBreak />
                                    <Run Text="Weather:" Foreground="#FF888888" /><Run Text=" Static / Clear" /><LineBreak />
                                    <Run Text="Grip:" Foreground="#FF888888" /><Run Text=" Optimal" /><LineBreak />
                                    <Run Text="Laps:" Foreground="#FF888888" /><Run Text=" 1 map lap + 3-5 hot laps" /><LineBreak />
                                    <Run Text="Send:" Foreground="#FF888888" /><Run Text=" Click 'Send Diagnostics to Dev' when done" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="FFB Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Tyre Related Settings -->
                        <StackPanel Grid.Column="0">

                            <!-- TYRE FORCES -->
                            <TextBlock Text="TYRE FORCES" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>

                                    <TextBlock Text="Front Axle" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding MzFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Mz (Self-Align)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MzFrontGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Main steering feel — the force that pulls the wheel back to center. Higher = stronger self-centering. Scaled by Mz Scale below." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FxFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fx (Longitudinal)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FxFrontGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Braking and acceleration forces through the wheel. Scaled by Fx Scale below." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FyFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fy (Lateral)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FyFrontGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Cornering loads — adds weight feel during turns. Suppressed near center (see Center Blend in Advanced). Scaled by Fy Scale below." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Text="Rear Axle" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding MzRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Mz Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MzRearGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Rear self-aligning torque — usually left off. Can add subtle rear-end feel but may increase noise. Uses same Mz Scale as front." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FxRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fx Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FxRearGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Rear braking/acceleration feel. Uses the same Fx Scale as front." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FyRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fy Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FyRearGain, StringFormat='{}{0:F2}'}" Width="58" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Rear cornering force. Uses the same Fy Scale as front. Also affected by Center Blend." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Text="Other" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FinalFfEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Game FFB Output" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FinalFfGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FinalFfGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="The game's built-in FFB signal. In Replace mode it's added on top of custom channels; in Overlay mode it's the base. See Mix Mode in Output &amp; Processing." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Wheel Load Weighting" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding WheelLoadWeighting, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding WheelLoadWeighting}" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="How much actual tire load affects force mixing. 0 = simple average, 1 = load-proportional (heavily-loaded tires contribute more)." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Text="Normalization Scales" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Mz Scale (Aligning)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding MzScale, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzScale}" Minimum="1" Maximum="500" TickFrequency="0.5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Divides raw Mz values to normalize them. Lower = stronger Mz feel. If steering feels weak, try lowering this. Affects both front and rear Mz." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Fx Scale (Longitudinal)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FxScale, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxScale}" Minimum="100" Maximum="20000" TickFrequency="100" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Divides raw Fx values to normalize them. Lower = stronger braking/acceleration feel. Affects both front and rear Fx." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Fy Scale (Lateral)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FyScale, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyScale}" Minimum="100" Maximum="20000" TickFrequency="100" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Divides raw Fy values to normalize them. Lower = stronger cornering feel. Affects both front and rear Fy." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- TYRE SLIP -->
                            <TextBlock Text="TYRE SLIP" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Ratio Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipRatioGain, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipRatioGain}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds extra force during wheelspin or wheel lock-up. Needs Slip Threshold set correctly. Works together with Slip Angle Gain." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Angle Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipAngleGain, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipAngleGain}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds extra force when tires slide sideways (oversteer). Needs Slip Threshold set correctly. Works together with Slip Ratio Gain." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Threshold" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipThreshold, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipThreshold}" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Minimum slip level before the slip enhancer activates. Lower = more sensitive. Affects both Slip Ratio and Slip Angle." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding SlipUseFrontOnly}" Margin="0,0,12,0" />
                                            <TextBlock Text="Front Wheels Only" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- DAMPING & FRICTION -->
                            <TextBlock Text="DAMPING &amp; FRICTION" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Speed Damping" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SpeedDamping, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SpeedDamping}" Minimum="0" Maximum="25" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Viscous damping — adds resistance that increases with car speed. Higher = heavier steering at speed. Scaled by Damping Speed Ref." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Friction" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FrictionLevel, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FrictionLevel}" Minimum="0" Maximum="20" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Constant friction resistance when turning the wheel. Higher = heavier, more resistant feel. Boosted at low speed (see Low Speed Damp Boost)." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Inertia" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding InertiaWeight, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding InertiaWeight}" Minimum="0" Maximum="20" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Simulates steering weight — resists rapid direction changes. Increases with car speed. Boosted at low speed (see Low Speed Damp Boost)." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Damping Speed Ref (km/h)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding DampingSpeedReference, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding DampingSpeedReference}" Minimum="50" Maximum="500" TickFrequency="5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed where speed-based damping reaches full strength. Lower = damping kicks in sooner. Affects Speed Damping and Inertia." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Damp Boost" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedDampingBoost, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedDampingBoost}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Multiplier for all damping forces at low speed. Prevents wheel wandering when stationary. Fades in below Low Speed Threshold." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Threshold" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedThreshold, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedThreshold}" Minimum="0" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed (km/h) below which damping boost is fully active. At 0 km/h boost is max, fading to normal at this speed. Works with Low Speed Damp Boost." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DYNAMIC EFFECTS -->
                            <TextBlock Text="DYNAMIC EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Cornering Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CorneringForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CorneringForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds force based on lateral G-forces during cornering. Gives a sense of how hard the car is turning. Combined with other Dynamic Effects." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Accel/Braking Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding AccelerationBrakingForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding AccelerationBrakingForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds force from forward/backward G-forces. Feel weight transfer under braking and acceleration. Combined with other Dynamic Effects." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Road Feel" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding RoadFeel, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding RoadFeel}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds force from suspension compression changes (bumps, kerbs). Only detects rapid changes, not steady-state. Combined with other Dynamic Effects." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Car Rotation Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CarRotationForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CarRotationForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Adds force based on how fast the car is rotating (yaw rate). Helps feel slides and transitions. Combined with other Dynamic Effects." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column: Output & Processing -->
                        <StackPanel Grid.Column="2">

                            <!-- OUTPUT & PROCESSING -->
                            <TextBlock Text="OUTPUT &amp; PROCESSING" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Mix Mode" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton Content="Replace" GroupName="MixMode" Margin="0,0,20,0" FontSize="13">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Replace" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                        <RadioButton Content="Overlay" GroupName="MixMode" FontSize="13">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Overlay" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </StackPanel>

                                    <TextBlock Text="Signal" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Output Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding OutputGainNmText}" Width="120" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" TextAlignment="Right" />
                                            <Slider Value="{Binding OutputGain}" Minimum="0" Maximum="20" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Master output strength — the final multiplier before the force limiter. Together with Max Force Limit and Wheel Max Torque, sets your peak Nm." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Force Sensitivity" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding ForceSensitivity, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding ForceSensitivity}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Inverse sensitivity — higher values = weaker overall forces. This is the first gain stage affecting everything downstream. Works with Force Scale." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Max Force Limit" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding MaxForceLimitNmText}" Width="120" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" TextAlignment="Right" />
                                            <Slider Value="{Binding MaxForceLimit}" Minimum="0.1" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Soft limiter — forces above this are gently rounded off instead of hard-clipping. Lower = less peak force but more consistent feel. Shows as Nm with your Wheel Max Torque." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Force Scale" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding ForceScale, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding ForceScale}" Minimum="0.01" Maximum="20" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Divides the mixed channel signal to normalize it. Higher = weaker signal entering compression. Works together with Force Sensitivity." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Compression Power" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CompressionPower, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CompressionPower}" Minimum="0.1" Maximum="5.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Compression curve shape. 1.0 = mild, 3.0+ = aggressive. Higher values boost light forces but cap peaks. Reduces the need for a low Max Force Limit." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Steering Lock (deg)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SteeringLockDegrees, StringFormat='{}{0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SteeringLockDegrees}" Minimum="180" Maximum="1080" TickFrequency="10" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Your wheel's total rotation in degrees (e.g. 900 = 450° each way). Used to scale steering angle for processing. Use Auto-Detect to set automatically." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Wheel Max Torque (Nm)" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding WheelMaxTorqueNm, StringFormat='{}{0:F1}'}" Width="40" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="4,0,0,0" />
                                            <Slider Value="{Binding WheelMaxTorqueNm}" Minimum="1" Maximum="25" TickFrequency="0.5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Your wheelbase's maximum torque in Nm — used only for the Nm display. 5.5 = Moza R5, 9 = R9, 15 = R15, 25 = R25." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding SignCorrectionEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Sign Correction (Self-Align)" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                        <TextBlock Text="Forces forces near center to oppose steering direction (self-centering). Uses Center Suppress degrees. See Advanced for tuning." Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding ForceInvertEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Invert Force Direction" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                        <TextBlock Text="Flips all forces at the wheel. Toggle this if the wheel pushes the wrong way during turns." Style="{StaticResource SliderDescription}" Margin="0,0,0,6" />

                                    <TextBlock Text="Response Curve" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ComboBox SelectedIndex="{Binding SelectedLutPresetIndex}" Width="160" FontSize="13" Padding="6,4">
                                            <ComboBoxItem Content="Linear" />
                                            <ComboBoxItem Content="Soft Center" />
                                            <ComboBoxItem Content="Progressive" />
                                            <ComboBoxItem Content="Dead Zone" />
                                        </ComboBox>
                                        <Button Content="Apply" Command="{Binding ApplyLutPresetCommand}" Margin="12,0,0,0" Padding="20,6" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- AUTO-GAIN -->
                            <TextBlock Text="AUTO-GAIN" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding AutoGainEnabled}" Margin="0,0,12,0" />
                                            <TextBlock Text="Enable Auto-Gain" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Auto-Gain Scale" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding AutoGainScale, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding AutoGainScale}" Minimum="0.1" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Target level when Auto-Gain is active. Higher = stronger auto-compensation so different cars feel similar. Only effective when Auto-Gain is enabled above." Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- VIBRATION -->
                            <TextBlock Text="VIBRATION" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Curb" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CurbGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CurbGain}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Kerb strike vibration intensity. Also scales suspension-derived kerb bumps in the main force." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipGain}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Tire slip vibration intensity. Scaled by Master below." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Road" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding RoadGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding RoadGain}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Road surface vibration intensity. Also scales suspension-derived road texture in the main force." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="ABS" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding AbsGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding AbsGain}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="ABS pulse vibration intensity. Also adds pulses to the main steering force when ABS activates." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Master" Width="140" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding VibrationMasterGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding VibrationMasterGain}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Master volume for all vibration effects. Scales Curb, Slip, Road, and ABS together." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ADVANCED -->
                            <TextBlock Text="ADVANCED" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <Border Background="#443B00" CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
                                        <TextBlock Text="WARNING: These parameters can adversely affect the FFB experience if not used correctly. Modify with caution." FontSize="11" Foreground="#FFFFAB00" TextWrapping="Wrap" />
                                    </Border>

                                    <TextBlock Text="Signal Processing" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Max Slew Rate" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding MaxSlewRate, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MaxSlewRate}" Minimum="0.01" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Maximum force change per frame. Lower = smoother/slower transitions, higher = snappier response. Also auto-scales down at low and very high speed." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Noise Floor" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding NoiseFloor, StringFormat='{}{0:F3}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding NoiseFloor}" Minimum="0" Maximum="0.05" TickFrequency="0.001" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Forces below this are silenced. Eliminates tiny vibrations when the wheel should be still. Higher = quieter center but may lose fine detail. Also affects Hysteresis triggering." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Hysteresis Threshold" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding HysteresisThreshold, StringFormat='{}{0:F3}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding HysteresisThreshold}" Minimum="0" Maximum="0.1" TickFrequency="0.001" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Minimum force change to move the output. Prevents micro-jitter from reaching the wheel. Higher = smoother but can feel sticky. Works with Hysteresis Watchdog and Noise Floor." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Hysteresis Watchdog" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding HysteresisWatchdogFrames, StringFormat='{}{0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding HysteresisWatchdogFrames}" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Frames before a held force is force-updated. Prevents the wheel getting stuck on one value. Only relevant when Hysteresis Threshold is above zero." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>

                                    <TextBlock Text="Center Feel" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Center Suppress (deg)" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CenterSuppressionDegrees, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CenterSuppressionDegrees}" Minimum="0" Maximum="30" TickFrequency="0.5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Steering angle zone near center where forces are faded to zero. Wider = larger dead-feel zone. Only active when Sign Correction is enabled. Grows wider at high speed." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Center Knee Power" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CenterKneePower, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CenterKneePower}" Minimum="0.5" Maximum="3.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Shapes how forces ramp up from zero. 1.0 = normal, higher = lighter at center with sharper force onset. Interacts with Compression Power." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Center Blend (deg)" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CenterBlendDegrees, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CenterBlendDegrees}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Steering angle where Fy (cornering force) is suppressed near center. Prevents Fy buzz at straight-ahead. Higher = wider clean zone but less mid-corner detail. Affects front and rear Fy." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>

                                    <TextBlock Text="Damping Tuning" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Steer Vel Reference" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SteerVelocityReference, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SteerVelocityReference}" Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Reference speed for steering velocity normalization. Higher = less damping response to fast inputs, lower = damping activates with slower wheel movement. Affects all damping forces." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Velocity Deadzone" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding VelocityDeadzone, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding VelocityDeadzone}" Minimum="0" Maximum="0.5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Minimum steering speed for damping to activate. Higher = damping only during fast turns. Helps prevent center bounce-back. Affects all damping forces." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>

                                    <TextBlock Text="Smoothing" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Smooth (km/h)" Width="165" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedSmoothKmh, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedSmoothKmh}" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed below which all channel smoothing is increased. Higher = smoother low-speed feel but less detail in slow corners. Affects all force channels (Mz, Fx, Fy)." Style="{StaticResource SliderDescription}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Track Map">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF22223A" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Button Content="Record Lap" Command="{Binding StartTrackMapRecordingCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding StopTrackMapRecordingCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Complete &amp; Save" Command="{Binding CompleteAndSaveTrackMapCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Export" Command="{Binding ExportTrackProfileCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Import" Command="{Binding ImportTrackProfileCommand}" Padding="12,4" FontSize="12" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                                <Button Content="Clear" Command="{Binding ClearTrackMapCommand}" Padding="12,4" FontSize="12" Style="{StaticResource OutlinedButton}" />
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Background="#FF444466" Margin="8,0" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Ellipse Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                                    <Setter Property="Fill" Value="#FFE67E22" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                                    <Setter Property="Fill" Value="#FF00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="11" Foreground="#FFAAAAAA" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="No Map" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                                    <Setter Property="Text" Value="Recording..." />
                                                    <Setter Property="Foreground" Value="#FFE67E22" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                                    <Setter Property="Text" Value="Map Ready" />
                                                    <Setter Property="Foreground" Value="#FF00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="4" Width="1" Background="#FF444466" Margin="8,0" />

                            <StackPanel Grid.Column="5" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Track" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding DetectedTrackName, FallbackValue='--'}" FontSize="11" FontWeight="Bold" Foreground="#FF00E676" MaxWidth="120" />
                            </StackPanel>

                            <StackPanel Grid.Column="6" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Progress" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapProgress" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" />
                            </StackPanel>
                            <StackPanel Grid.Column="7" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Dist from Center" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapDistance" Text="-- m" FontSize="14" FontWeight="Bold" Foreground="#FF00BCD4" />
                            </StackPanel>
                            <StackPanel Grid.Column="8" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="Track Status" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapOnTrack" Text="--" FontSize="14" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnTrackMap}" Value="True">
                                                    <Setter Property="Text" Value="ON TRACK" />
                                                    <Setter Property="Foreground" Value="#FF00E676" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOnTrackMap}" Value="False">
                                                    <Setter Property="Text" Value="OFF TRACK" />
                                                    <Setter Property="Foreground" Value="#FFE67E22" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                             <StackPanel Grid.Column="9" Margin="8,0" VerticalAlignment="Center">
                                 <TextBlock Text="Waypoints" FontSize="9" Foreground="#FF888888" />
                                 <TextBlock x:Name="TrackMapWaypoints" Text="--" FontSize="14" Foreground="#FFE0E0E0" />
                             </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FF22223A" CornerRadius="6" Padding="6,3" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Corner" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapCorner" Text="--" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Sector" FontSize="9" Foreground="#FF888888" />
                                <TextBlock x:Name="TrackMapSector" Text="--" FontSize="13" FontWeight="Bold" Foreground="#FF00BCD4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Corners" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding CornerCount, FallbackValue=0}" FontSize="13" Foreground="#FFE0E0E0" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="6,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Laps" FontSize="9" Foreground="#FF888888" />
                                <TextBlock Text="{Binding CompletedLapCount, FallbackValue=0}" FontSize="13" Foreground="#FFE0E0E0" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="6,0,12,0" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInPit}" Value="True">
                                                    <Setter Property="Fill" Value="#FFFFD600" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text=" PIT" FontSize="10" Foreground="#FF888888" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="6" Margin="6,0,6,0" VerticalAlignment="Center">
                                 <CheckBox Content="Heatmap" IsChecked="{Binding ShowForceHeatmap}" Foreground="#FFAAAAAA" FontSize="11" />
                             </StackPanel>
                             <StackPanel Grid.Column="7" Margin="6,0,6,0" VerticalAlignment="Center">
                                 <CheckBox Content="Edges" IsChecked="{Binding ShowTrackEdges}" Foreground="#FFAAAAAA" FontSize="11" />
                             </StackPanel>
                            <StackPanel Grid.Column="5" Margin="6,0,6,0" VerticalAlignment="Center" Visibility="{Binding IsTrackMapAvailable, Converter={StaticResource BoolToVis}}">
                                 <CheckBox Content="Diagnostics" IsChecked="{Binding ShowDiagnostics}" Foreground="#FFFF8A65" FontSize="11" />
                             </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FF1A1A2E" CornerRadius="4" Padding="10,8" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="FFB DIAGNOSTICS" FontSize="11" Foreground="#FF00E676" FontWeight="Bold" Margin="0,0,0,8" />

                                <TextBlock Text="LEGEND" FontSize="9" Foreground="#FF888888" FontWeight="Bold" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="10" Height="10" Fill="#FF00E676" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Expected" FontWeight="Bold" Foreground="#FF00E676" /><Run Text=" - Normal forces" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="10" Height="10" Fill="#FFFFD600" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Notable" FontWeight="Bold" Foreground="#FFFFD600" /><Run Text=" - Event, not susp." />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="10" Height="10" Fill="#FFFF0000" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FFE0E0E0" VerticalAlignment="Center">
                                        <Run Text="Suspicious" FontWeight="Bold" Foreground="#FFFF0000" /><Run Text=" - Code issue?" />
                                    </TextBlock>
                                </StackPanel>

                                <Border Background="#FF333355" Height="1" Margin="0,4,0,8" />

                                <TextBlock Text="INTERPRETATION" FontSize="9" Foreground="#FF888888" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock FontSize="9" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14">
                                    <Run Text="Expected:" FontWeight="Bold" Foreground="#FF00E676" />
                                    <Run Text=" Snap at corner entry/exit, understeer/oversteer, braking weight transfer." />
                                </TextBlock>
                                <TextBlock FontSize="9" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" Margin="0,3,0,0">
                                    <Run Text="Suspicious:" FontWeight="Bold" Foreground="#FFFF0000" />
                                    <Run Text=" Snap on a straight, oscillation with no steering, force pushing same direction as wheel." />
                                </TextBlock>
                                <TextBlock FontSize="9" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" Margin="0,3,0,0">
                                    <Run Text="Verdict:" FontWeight="Bold" Foreground="#FF00BCD4" />
                                    <Run Text=" Most dots green and at corners = normal driving. Red on straights = check FFB code." />
                                </TextBlock>

                                <Border Background="#FF333355" Height="1" Margin="0,8,0,8"
                                        Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}" />

                                <StackPanel Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding DiagnosticCoverage, FallbackValue='Coverage: 0%'}" FontSize="10" Foreground="#FF00BCD4" FontWeight="Bold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding DiagnosticSummary, FallbackValue=''}" FontSize="9" Foreground="#FFAAAAAA" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding DiagnosticVerdict, FallbackValue=''}" FontSize="11" Foreground="#FFE67E22" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBlock Text="Last Event:" FontSize="9" Foreground="#FF888888" Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding LastEventInfo, FallbackValue=''}" FontSize="9" Foreground="#FFFF8A65" FontFamily="Consolas" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FF151525" CornerRadius="6">
                            <Canvas x:Name="TrackMapCanvas" ClipToBounds="True" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Background="#FF1A1A2E" CornerRadius="4" Padding="8,4" Margin="0,4,0,0"
