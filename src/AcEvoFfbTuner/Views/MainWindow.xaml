<Window x:Class="AcEvoFfbTuner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
        xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
        Title="AC Evo FFB Tuner" Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0D0D"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#FF1A1A2E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="22" FontWeight="Black" Foreground="#FFFF4500" Margin="0,0,8,0" />
                    <TextBlock Text="FFB TUNER" FontSize="22" FontWeight="Light" Foreground="#FFE0E0E0" VerticalAlignment="Bottom" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="ProductName" Width="220" Margin="8,0" />
                    <Button Content="Connect" Command="{Binding ConnectDeviceCommand}" Margin="4,0" />
                    <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" Margin="4,0" Style="{StaticResource OutlinedButton}" />
                    <ToggleButton IsChecked="{Binding IsRunning}" Command="{Binding ToggleTelemetryCommand}"
                                  Margin="12,0,4,0" x:Name="StartStopToggle">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="START" />
                                <Setter Property="Background" Value="#FF2A2A45" />
                                <Setter Property="Foreground" Value="#FFE0E0E0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="#FF555555" />
                                <Setter Property="Padding" Value="20,6" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Content" Value="STOP" />
                                        <Setter Property="Background" Value="#FFFF4500" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button Content="PANIC" Command="{Binding PanicStopCommand}" Margin="4,0" Style="{StaticResource PanicButton}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" Width="200" Margin="4,0" />
                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" Margin="2,0" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="FFB Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Tyre Related Settings -->
                        <StackPanel Grid.Column="0">

                            <!-- TYRE FORCES -->
                            <TextBlock Text="TYRE FORCES" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>

                                    <TextBlock Text="Front Axle" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding MzFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Mz (Self-Align)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MzFrontGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Core steering feel from front tires" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FxFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fx (Longitudinal)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FxFrontGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Braking and acceleration forces" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FyFrontEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fy (Lateral)" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FyFrontGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyFrontGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Cornering loads from front tires" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Text="Rear Axle" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding MzRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Mz Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MzRearGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FxRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fx Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FxRearGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FyRearEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Fy Rear" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FyRearGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyRearGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>

                                    <TextBlock Text="Other" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding FinalFfEnabled}" Margin="0,0,12,0" />
                                                <TextBlock Text="Game FFB Output" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding FinalFfGain, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FinalFfGain}" Minimum="-10" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Wheel Load Weighting" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding WheelLoadWeighting, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding WheelLoadWeighting}" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="How much tire load influences channel mixing" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Text="Normalization Scales" Style="{StaticResource SubSectionHeader}" Margin="0,10,0,2" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Mz Scale (Aligning)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding MzScale, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding MzScale}" Minimum="1" Maximum="500" TickFrequency="0.5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Raw Mz divisor (25 = baseline)" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Fx Scale (Longitudinal)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FxScale, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FxScale}" Minimum="100" Maximum="20000" TickFrequency="100" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Raw Fx divisor (5000 = baseline)" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Fy Scale (Lateral)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FyScale, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FyScale}" Minimum="100" Maximum="20000" TickFrequency="100" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Raw Fy divisor (5000 = baseline)" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- TYRE SLIP -->
                            <TextBlock Text="TYRE SLIP" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Ratio Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipRatioGain, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipRatioGain}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Amplifies FFB during wheelspin" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Angle Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipAngleGain, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipAngleGain}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Amplifies FFB during oversteer" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Slip Threshold" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SlipThreshold, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SlipThreshold}" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Minimum slip before enhancement activates" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <DockPanel Margin="0,6">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding SlipUseFrontOnly}" Margin="0,0,12,0" />
                                            <TextBlock Text="Front Wheels Only" FontSize="13" />
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- DAMPING & FRICTION -->
                            <TextBlock Text="DAMPING &amp; FRICTION" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Speed Damping" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding SpeedDamping, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding SpeedDamping}" Minimum="0" Maximum="25" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Reduces FFB at high speeds" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Friction" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding FrictionLevel, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding FrictionLevel}" Minimum="0" Maximum="20" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Constant resistance to wheel movement" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Inertia" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding InertiaWeight, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding InertiaWeight}" Minimum="0" Maximum="20" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Weight for rapid direction changes" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Damping Speed Ref (km/h)" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding DampingSpeedReference, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding DampingSpeedReference}" Minimum="50" Maximum="500" TickFrequency="5" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed where damping is max" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Damp Boost" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedDampingBoost, StringFormat='{}{0:F1}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedDampingBoost}" Minimum="0" Maximum="10" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Extra damping at low speed to prevent wheel hunting" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Low Speed Threshold" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding LowSpeedThreshold, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding LowSpeedThreshold}" Minimum="0" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Speed (km/h) below which boost fades in" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DYNAMIC EFFECTS -->
                            <TextBlock Text="DYNAMIC EFFECTS" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Cornering Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CorneringForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CorneringForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="FFB from cornering G-forces" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Accel/Braking Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding AccelerationBrakingForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding AccelerationBrakingForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="FFB from acceleration/braking G" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Road Feel" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding RoadFeel, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding RoadFeel}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Suspension movement feedback" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Car Rotation Force" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding CarRotationForce, StringFormat='{}{0:F2}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding CarRotationForce}" Minimum="0" Maximum="5" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="FFB from car rotation" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column: Output & Processing -->
                        <StackPanel Grid.Column="2">

                            <!-- OUTPUT & PROCESSING -->
                            <TextBlock Text="OUTPUT &amp; PROCESSING" Style="{StaticResource GroupHeader}" />
                            <Border Background="#FF22223A" CornerRadius="6" Padding="16,10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="Mix Mode" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton Content="Replace" GroupName="MixMode" Margin="0,0,20,0" FontSize="13">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Replace" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                        <RadioButton Content="Overlay" GroupName="MixMode" FontSize="13">
                                            <RadioButton.IsChecked>
                                                <Binding Path="SelectedMixMode" Converter="{StaticResource EnumToBoolConverter}" ConverterParameter="Overlay" Mode="TwoWay" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </StackPanel>

                                    <TextBlock Text="Signal" Style="{StaticResource SubSectionHeader}" />
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Output Gain" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding OutputGainNmText}" Width="120" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" TextAlignment="Right" />
                                            <Slider Value="{Binding OutputGain}" Minimum="0" Maximum="20" TickFrequency="0.1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Master FFB volume" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Force Sensitivity" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding ForceSensitivity, StringFormat='{}{0:F0}'}" Width="50" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" />
                                            <Slider Value="{Binding ForceSensitivity}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Scales telemetry to usable range" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="Max Force Limit" Width="140" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding MaxForceLimitNmText}" Width="120" VerticalAlignment="Center" FontSize="13" DockPanel.Dock="Right" Margin="8,0,0,0" TextAlignment="Right" />
                                            <Slider Value="{Binding MaxForceLimit}" Minimum="0.1" Maximum="1.0" TickFrequency="0.01" IsSnapToTickEnabled="True" />
                                        </DockPanel>
                                        <TextBlock Text="Soft clip threshold" Style="{StaticResource SliderDescription}" Margin="0,0,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,6">
