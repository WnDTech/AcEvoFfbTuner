<Window x:Class="AcEvoFfbTuner.Views.CompactTunerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
        Title="AC Evo FFB Tuner — Compact"
        Width="420" Height="680"
        MinWidth="280" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/wheel.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        Loaded="OnLoaded">

    <Border x:Name="RootBorder" CornerRadius="6" BorderThickness="1"
            BorderBrush="#FF30363D" Background="{StaticResource BgDark}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{StaticResource BgPanel}"
                    CornerRadius="6,6,0,0" Padding="10,6"
                    BorderThickness="0,0,0,1" BorderBrush="#FF30363D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="FFB" FontSize="14" FontWeight="Black" Foreground="{StaticResource AccentBrush}" Margin="0,0,4,0" />
                        <TextBlock Text="COMPACT" FontSize="14" FontWeight="Light" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              FontSize="12" Padding="4,2" Margin="0,0,8,0"
                              VerticalAlignment="Center" MaxWidth="200" />

                    <Button Grid.Column="2" x:Name="BtnPin" ToolTip="Always on top" Click="ToggleTopmost"
                            Width="24" Height="24" Padding="0" Margin="0,0,2,0" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock x:Name="PinIcon" Text="&#x1F513;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button Grid.Column="3" x:Name="BtnMaxRestore" ToolTip="Maximize / Restore" Click="ToggleMaximize"
                            Width="24" Height="24" Padding="0" Margin="0,0,2,0" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock x:Name="MaxIcon" Text="&#x2610;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button Grid.Column="4" ToolTip="Close" Click="CloseWindow"
                            Width="24" Height="24" Padding="0" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock Text="&#x2715;" FontSize="12" Foreground="#FFE53935" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,6,8,8">

                    <!-- Info strip -->
                    <WrapPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <TextBlock Text="CAR" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding DetectedCarModel, FallbackValue='—', TargetNullValue='—'}" FontSize="11" Foreground="#FF79C0FF" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <TextBlock Text="PEAK" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding OutputGainNmText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MIX" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMixMode}" Value="Replace">
                                                <Setter Property="Foreground" Value="#FF79C0FF" />
                                                <Setter Property="Text" Value="Replace" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedMixMode}" Value="Overlay">
                                                <Setter Property="Foreground" Value="#FF56D4A0" />
                                                <Setter Property="Text" Value="Overlay" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </WrapPanel>

                    <!-- MASTER OUTPUT -->
                    <TextBlock Text="MASTER OUTPUT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SectionOutput}" Margin="0,0,0,4" />
                    <controls:LabeledSlider Value="{Binding OutputGain, Mode=TwoWay}" Minimum="0" Maximum="20" TickFrequency="0.001"
                        Label="Output Gain" DisplayText="{Binding OutputGainNmText}" ValueWidth="68" LabelAbove="True"
                        SectionColor="{StaticResource SectionOutput}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding MaxForceLimit, Mode=TwoWay}" Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                        Label="Max Force Limit" DisplayText="{Binding MaxForceLimitNmText}" ValueWidth="68" LabelAbove="True"
                        SectionColor="{StaticResource SectionOutput}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding ForceSensitivity, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1"
                        Label="Sensitivity" StringFormat="{}{0:F0}" IsLogarithmic="True" LabelAbove="True"
                        SectionColor="{StaticResource SectionOutput}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding MaxSlewRate, Mode=TwoWay}" Minimum="0.03" Maximum="0.50" TickFrequency="0.001"
                        Label="Max Slew Rate" StringFormat="{}{0:F4}" LabelAbove="True"
                        SectionColor="{StaticResource SectionOutput}" Margin="0,0,0,2" />

                    <Border Background="{StaticResource BgCard}" CornerRadius="3" Padding="6,4" Margin="0,4,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DockPanel Grid.Column="0">
                                <TextBlock Text="Sign Correction" FontSize="12" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding SignCorrectionEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Invert" FontSize="12" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding ForceInvertEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- TYRE FORCES -->
                    <TextBlock Text="TYRE FORCES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SectionTyreForces}" Margin="0,0,0,4" />
                    <controls:LabeledSlider Value="{Binding MzFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                        Label="Mz (Self-Align)" StringFormat="{}{0:F3}"
                        ShowCheckBox="True" IsChecked="{Binding MzFrontEnabled}"
                        SectionColor="{StaticResource SectionTyreForces}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding FxFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                        Label="Fx (Longitudinal)" StringFormat="{}{0:F3}"
                        ShowCheckBox="True" IsChecked="{Binding FxFrontEnabled}"
                        SectionColor="{StaticResource SectionTyreForces}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding FyFrontGain, Mode=TwoWay}" Minimum="-10" Maximum="10" TickFrequency="0.01"
                        Label="Fy (Lateral)" StringFormat="{}{0:F3}"
                        ShowCheckBox="True" IsChecked="{Binding FyFrontEnabled}"
                        SectionColor="{StaticResource SectionTyreForces}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding MzScale, Mode=TwoWay}" Minimum="1" Maximum="500" TickFrequency="0.5"
                        Label="Mz Scale" StringFormat="{}{0:F0}" IsLogarithmic="True"
                        SectionColor="{StaticResource SectionTyreForces}" Margin="0,0,0,8" />

                    <!-- DAMPING & FRICTION -->
                    <TextBlock Text="DAMPING &amp; FRICTION" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SectionDamping}" Margin="0,0,0,4" />
                    <controls:LabeledSlider Value="{Binding SpeedDamping, Mode=TwoWay}" Minimum="0" Maximum="25" TickFrequency="0.1"
                        Label="Speed Damping" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionDamping}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding FrictionLevel, Mode=TwoWay}" Minimum="0" Maximum="20" TickFrequency="0.1"
                        Label="Friction" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionDamping}" Margin="0,0,0,8" />

                    <!-- VIBRATION -->
                    <TextBlock Text="VIBRATION" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SectionVibration}" Margin="0,0,0,4" />
                    <controls:LabeledSlider Value="{Binding VibrationMasterGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                        Label="Master" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionVibration}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding CurbGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                        Label="Curb" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionVibration}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding SlipGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                        Label="Slip" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionVibration}" Margin="0,0,0,2" />
                    <controls:LabeledSlider Value="{Binding RoadGain, Mode=TwoWay}" Minimum="0" Maximum="10" TickFrequency="0.1"
                        Label="Road" StringFormat="{}{0:F2}"
                        SectionColor="{StaticResource SectionVibration}" Margin="0,0,0,8" />

                    <!-- SIGNAL PROCESSING -->
                    <TextBlock Text="SIGNAL PROCESSING" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SectionTyreSlip}" Margin="0,0,0,4" />
                    <controls:LabeledSlider Value="{Binding CenterSuppressionDegrees, Mode=TwoWay}" Minimum="0" Maximum="30" TickFrequency="0.5"
                        Label="Center Suppress" StringFormat="{}{0:F1}" Suffix="°"
                        SectionColor="{StaticResource SectionTyreSlip}" Margin="0,0,0,8" />

                    <!-- SAVE -->
                    <Border Background="{StaticResource BgPanel}" CornerRadius="4" Padding="8,6" Margin="0,4,0,0">
                        <Button Command="{Binding SaveCurrentProfileCommand}" Cursor="Hand" HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SaveBd" Background="{StaticResource AccentBrush}" CornerRadius="3" Padding="10,6">
                                        <TextBlock Text="SAVE PROFILE" FontWeight="Bold" FontSize="12"
                                                   Foreground="White" HorizontalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SaveBd" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
