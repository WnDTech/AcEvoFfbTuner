<Window x:Class="AcEvoFfbTuner.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AC Evo FFB Tuner"
        Width="620" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">

    <Border Background="#FF0D0D0D" CornerRadius="12" Margin="10"
            BorderBrush="#33E67E22" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#FFE67E22" BlurRadius="30" ShadowDepth="0" Opacity="0.3" />
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid x:Name="WheelContainer" Width="200" Height="200"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="WheelRotation" Angle="0" />
                    </Grid.RenderTransform>
                    <Image Source="pack://application:,,,/Resources/wheel_nobg.png"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Width="200" Height="200" />
                </Grid>
            </Grid>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="36" FontWeight="Black" Foreground="#FFE67E22"
                               FontFamily="Segoe UI" />
                    <TextBlock Text=" FFB TUNER" FontSize="36" FontWeight="Light" Foreground="#FFE0E0E0"
                               FontFamily="Segoe UI" Margin="0,0,0,0" />
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Initializing..."
                           FontSize="16" Foreground="#FF888888" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,6,0,0" />
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,5,0,0">
                <Border Background="#FF333355" Height="3" CornerRadius="1.5" />
                <Border x:Name="ProgressFill" Background="#FFE67E22" Height="3" CornerRadius="1.5"
                        HorizontalAlignment="Left" Width="0" />
            </Grid>
        </Grid>
    </Border>
</Window>
