<Window x:Class="AcEvoFfbTuner.Views.TestingGuideOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFB Tuner — Quick Guide"
        Width="380"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="OnLoaded"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF333355" />
            <Setter Property="Foreground" Value="#FFE0E0E0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" Padding="1"
            Background="#DDE67E22"
            MouseLeftButtonDown="OnDragMove"
            MouseWheel="OnMouseWheel">

        <Border x:Name="ContentBorder" CornerRadius="7" Background="#EB0D0D0D">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF1A1A2E" CornerRadius="7,7,0,0" Padding="12,8"
                        MouseLeftButtonDown="OnDragMove">
                    <Grid>
                        <TextBlock Text="FFB TUNER — QUICK GUIDE" FontSize="13" FontWeight="Black"
                                   Foreground="#FFE67E22" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnTransparency" ToolTip="Toggle transparency"
                                    Width="28" Height="28" FontSize="14" Padding="0" Margin="0,0,4,0"
                                    Click="ToggleTransparency">
                                <TextBlock x:Name="TransparencyIcon" Text="OPQ" FontSize="9" FontWeight="Bold" Foreground="#FFE0E0E0" />
                            </Button>
                            <Button x:Name="BtnClose" ToolTip="Close"
                                    Width="28" Height="28" FontSize="14" Padding="0"
                                    Background="#FF552222" Click="CloseOverlay">
                                <TextBlock Text="X" FontWeight="Bold" Foreground="#FFE0E0E0" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="SET UP AC EVO" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Car: BMW M4 GT3" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Track: ANY track you know" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FF00E676" Text="&#x2713;" /><Run Text=" Mode: Practice | Clear | Optimal grip" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="SET UP FFB TUNER" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Select wheel &#x2192; Connect" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Load the test profile" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" FFB Settings &#x2192; Detect Settings" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="d." /><Run Text=" Telemetry Profiler &#x2192; pick a Snapshot Button" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="e." /><Run Text=" Track Map &#x2192; check Diagnostics checkbox" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="f." /><Run Text=" Click START" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="RECORD TRACK MAP" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Track Map tab &#x2192; Record Lap" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Drive 1 clean lap (no cuts, no spins)" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Complete &amp; Save" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="DRIVE 3-5 LAPS" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#FFE0E0E0" TextWrapping="Wrap"
                                       Text="Push hard. Cover: braking, fast corners, hairpins, kerbs." />
                        </Border>

                        <TextBlock Text="If FFB feels wrong (snap / oscillation / bounce / dead / reversed) take a SNAPSHOT:" FontSize="11" Foreground="#FFFF8A65" FontWeight="Bold" Margin="0,0,0,6" TextWrapping="Wrap" />
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" Text="&#x2022;" /><Run Text=" Press your wheel snapshot button, OR" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" Text="&#x2022;" /><Run Text=" Telemetry Profiler &#x2192; Snapshot" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="5" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="SEND DIAGNOSTICS" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="a." /><Run Text=" Track Map &#x2192; coverage shows " /><Run Foreground="#FF00E676" Text="ready for recommendations" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="b." /><Run Text=" Click " /><Run FontWeight="Bold" Text="Send Diagnostics to Dev" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1" TextWrapping="Wrap">
                                    <Run Foreground="#FFFFD600" FontWeight="Bold" Text="c." /><Run Text=" Wait for " /><Run FontWeight="Bold" Text="Diagnostic pack sent" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#FFE67E22" CornerRadius="10" Width="20" Height="20" Margin="0,0,6,0">
                                <TextBlock Text="6" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="TELL THE DEV" FontSize="12" FontWeight="Bold" Foreground="#FFE67E22" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#FF1A1A2E" CornerRadius="4" Padding="8,6">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FFFFD600" Text="&#x2022;" /><Run Text=" Track / wheel base model" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FFFFD600" Text="&#x2022;" /><Run Text=" What felt wrong &amp; where on track" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#FFE0E0E0" Margin="0,1">
                                    <Run Foreground="#FFFFD600" Text="&#x2022;" /><Run Text=" How many snapshots you took" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#FF1A1A2E" CornerRadius="0,0,7,7" Padding="10,6">
                    <TextBlock FontSize="10" Foreground="#FF666666" VerticalAlignment="Center">
                        <Run Text="Drag to move | Scroll to resize | OPQ = toggle transparency" />
                    </TextBlock>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
