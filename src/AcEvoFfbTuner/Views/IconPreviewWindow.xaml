<Window x:Class="AcEvoFfbTuner.Views.IconPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sidebar Icon Preview — Phase 0" Width="700" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="#FF0F1117" Foreground="#FFE6EDF3" FontFamily="Segoe UI"
        ResizeMode="NoResize" UseLayoutRounding="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Sidebar Icon Preview" FontSize="22" FontWeight="Black" Foreground="#FFF0883E" />
            <TextBlock Text="All 7 navigation icons in both Default and Selected states on dark sidebar background."
                       FontSize="14" Foreground="#FF8B949E" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="IconGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Home -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Home" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,12 L12,4 L20,12 M6,10.5 V19 H18 V10.5"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,12 L12,4 L20,12 M6,10.5 V19 H18 V10.5"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,12 L12,4 L20,12 M6,10.5 V19 H18 V10.5"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- FFB Tuning (Steering Wheel) -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="FFB Tuning" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,4 A8,8,0,1,1,11.99,4 Z M12,12 V6 M7.5,16 L12,12 L16.5,16"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,4 A8,8,0,1,1,11.99,4 Z M12,12 V6 M7.5,16 L12,12 L16.5,16"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,4 A8,8,0,1,1,11.99,4 Z M12,12 V6 M7.5,16 L12,12 L16.5,16"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Equalizer -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Equalizer" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="2" Canvas.Top="10" Width="3" Height="8" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="11" Canvas.Top="8" Width="3" Height="10" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="15.5" Canvas.Top="3" Width="3" Height="16" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="20" Canvas.Top="12" Width="3" Height="6" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="2" Canvas.Top="10" Width="3" Height="8" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="11" Canvas.Top="8" Width="3" Height="10" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="15.5" Canvas.Top="3" Width="3" Height="16" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="20" Canvas.Top="12" Width="3" Height="6" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="2" Canvas.Top="10" Width="3" Height="8" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="11" Canvas.Top="8" Width="3" Height="10" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="15.5" Canvas.Top="3" Width="3" Height="16" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                        <Rectangle Canvas.Left="20" Canvas.Top="12" Width="3" Height="6" RadiusX="1" RadiusY="1" Fill="#FFF0883E" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Track Map -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Track Map" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,18 C5,8 10,4 14,4 C18,4 20,8 20,12 C20,16 16,20 12,20 C8,20 5,18 5,14"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,18 C5,8 10,4 14,4 C18,4 20,8 20,12 C20,16 16,20 12,20 C8,20 5,18 5,14"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,18 C5,8 10,4 14,4 C18,4 20,8 20,12 C20,16 16,20 12,20 C8,20 5,18 5,14"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Telemetry -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Telemetry" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V4 M4,18 H20 M6,14 L9,8 L12,12 L16,6 L20,10"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V4 M4,18 H20 M6,14 L9,8 L12,12 L16,6 L20,10"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V4 M4,18 H20 M6,14 L9,8 L12,12 L16,6 L20,10"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Devices (Gamepad) -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Devices" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M6,9 C6,9 7,14 6,17 C5,20 4,20 3,18 C2,16 3,13 5,10 M18,9 C18,9 17,14 18,17 C19,20 20,20 21,18 C22,16 21,13 19,10 M5,10 C5,10 8,7 12,7 C16,7 19,10 19,10"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M6,9 C6,9 7,14 6,17 C5,20 4,20 3,18 C2,16 3,13 5,10 M18,9 C18,9 17,14 18,17 C19,20 20,20 21,18 C22,16 21,13 19,10 M5,10 C5,10 8,7 12,7 C16,7 19,10 19,10"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M6,9 C6,9 7,14 6,17 C5,20 4,20 3,18 C2,16 3,13 5,10 M18,9 C18,9 17,14 18,17 C19,20 20,20 21,18 C22,16 21,13 19,10 M5,10 C5,10 8,7 12,7 C16,7 19,10 19,10"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Profiles -->
                <Border Background="#FF161B22" CornerRadius="8" Margin="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Profiles" FontSize="16" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,20 V4 H20 V20 Z M12,10 C13.5,10 14.5,8.5 14.5,7.5 C14.5,6.5 13.5,6 12,6 C10.5,6 9.5,6.5 9.5,7.5 C9.5,8.5 10.5,10 12,10 Z M8,16 C8,13 10,12 12,12 C14,12 16,13 16,16"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Default" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                <Viewbox Width="28" Height="28" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,20 V4 H20 V20 Z M12,10 C13.5,10 14.5,8.5 14.5,7.5 C14.5,6.5 13.5,6 12,6 C10.5,6 9.5,6.5 9.5,7.5 C9.5,8.5 10.5,10 12,10 Z M8,16 C8,13 10,12 12,12 C14,12 16,13 16,16"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Selected" FontSize="11" Foreground="#FFF0883E" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40" Margin="0,0,0,6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,20 V4 H20 V20 Z M12,10 C13.5,10 14.5,8.5 14.5,7.5 C14.5,6.5 13.5,6 12,6 C10.5,6 9.5,6.5 9.5,7.5 C9.5,8.5 10.5,10 12,10 Z M8,16 C8,13 10,12 12,12 C14,12 16,13 16,16"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Large" FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <Border Background="#FF21262D" CornerRadius="6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Mockup: Sidebar with icons at actual size" FontSize="14" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,8" />

                    <Border Background="#FF0D1117" CornerRadius="6" Width="240" HorizontalAlignment="Left">
                        <StackPanel Margin="0,8">
                            <!-- Selected item -->
                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="#FFF0883E" CornerRadius="1.5" Margin="0,0,10,0" />
                                <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,12 L12,4 L20,12 M6,10.5 V19 H18 V10.5"
                                              Stroke="#FFF0883E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Home" FontSize="14" Foreground="#FFF0883E" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>

                            <!-- Default items -->
                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="Transparent" Margin="0,0,10,0" />
                                <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,4 A8,8,0,1,1,11.99,4 Z M12,12 V6 M7.5,16 L12,12 L16.5,16"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="FFB Tuning" FontSize="14" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="Transparent" Margin="0,0,10,0" />
                                <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="2" Canvas.Top="10" Width="3" Height="8" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="11" Canvas.Top="8" Width="3" Height="10" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="15.5" Canvas.Top="3" Width="3" Height="16" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                        <Rectangle Canvas.Left="20" Canvas.Top="12" Width="3" Height="6" RadiusX="1" RadiusY="1" Fill="#FF8B949E" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Equalizer" FontSize="14" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="Transparent" Margin="0,0,10,0" />
                                <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,18 C5,8 10,4 14,4 C18,4 20,8 20,12 C20,16 16,20 12,20 C8,20 5,18 5,14"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Track Map" FontSize="14" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="Transparent" Margin="0,0,10,0" />
                                <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V4 M4,18 H20 M6,14 L9,8 L12,12 L16,6 L20,10"
                                              Stroke="#FF8B949E" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Telemetry" FontSize="14" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="12,4">
                                <Border Width="3" Height="28" Background="Transparent" Margin="0,0,10,0" />
