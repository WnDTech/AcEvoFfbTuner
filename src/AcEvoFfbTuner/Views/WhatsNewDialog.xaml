<Window x:Class="AcEvoFfbTuner.Views.WhatsNewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New"
        Width="580"
        Height="620"
        MinWidth="480"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgDark}"
        Foreground="{StaticResource TextBrush}"
        ShowInTaskbar="False"
        Loaded="OnLoaded">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="28,20,28,16"
                BorderBrush="#33E67E22" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="AC EVO" FontSize="28" FontWeight="Black" Foreground="#FFE67E22"
                               FontFamily="Segoe UI" />
                    <TextBlock Text=" FFB TUNER" FontSize="28" FontWeight="Light" Foreground="#FFE0E0E0"
                               FontFamily="Segoe UI" />
                </StackPanel>
                <TextBlock x:Name="VersionLabel" Text="What's New in v1.5.1"
                           FontSize="16" Foreground="#FF888888" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,16,28,8">
            <StackPanel x:Name="ContentPanel" />
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="28,14"
                BorderBrush="#33E67E22" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="ShowOnStartupCheck" Grid.Column="0"
                          Content="Show on startup when there are updates"
                          VerticalAlignment="Center" FontSize="13" Foreground="#FF888888"
                          IsChecked="True" />
                <Button Grid.Column="1" Content="Continue" Width="120" Padding="16,8"
                        Click="OnContinue" IsDefault="True" />
            </Grid>
        </Border>
    </Grid>
</Window>
