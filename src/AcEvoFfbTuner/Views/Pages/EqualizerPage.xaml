<UserControl x:Class="AcEvoFfbTuner.Views.Pages.EqualizerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             xmlns:local="clr-namespace:AcEvoFfbTuner.Views.Pages">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Margin="16,8">
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="FFB EFFECT EQUALIZER" Style="{StaticResource GroupHeader}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Enable" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <CheckBox IsChecked="{Binding EqEnabled}" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
            <TextBlock Text="10-band parametric EQ for the FFB force signal. Boost or cut frequency ranges to shape how forces feel through the wheel." FontSize="13" Foreground="#FF8B949E" Margin="0,0,0,16" TextWrapping="Wrap" />

            <Border Background="#FF1C2128" CornerRadius="8" Padding="12,16" Margin="0,0,0,12">
                <Grid x:Name="EqSliderGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Band 0: Steering Weight (2 Hz) -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="STEER&#x0A;WEIGHT" FontSize="13" FontWeight="Bold" Foreground="#FF90CAF9" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="2 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider0" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand0Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel0" Text="{Binding EqBand0Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF90CAF9" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Heavy resistance,&#x0A;parking effort" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 1: Weight Transfer (4 Hz) -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="WEIGHT&#x0A;TRANSFER" FontSize="13" FontWeight="Bold" Foreground="#FF4FC3F7" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="4 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider1" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand1Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel1" Text="{Binding EqBand1Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF4FC3F7" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Body roll, brake&#x0A;dive, accel squat" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 2: Self-Align Torque (8 Hz) -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="SELF&#x0A;ALIGN" FontSize="13" FontWeight="Bold" Foreground="#FF4DB6AC" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="8 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider2" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand2Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel2" Text="{Binding EqBand2Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF4DB6AC" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Self-centering,&#x0A;grip balance feel" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 3: Steering Precision (12 Hz) -->
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="STEERING&#x0A;PRECISION" FontSize="13" FontWeight="Bold" Foreground="#FF66BB6A" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="12 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider3" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand3Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel3" Text="{Binding EqBand3Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF66BB6A" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Line tracking,&#x0A;small corrections" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 4: Turn-In Response (18 Hz) -->
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="TURN-IN&#x0A;RESPONSE" FontSize="13" FontWeight="Bold" Foreground="#FF9CCC65" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="18 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider4" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand4Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel4" Text="{Binding EqBand4Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FF9CCC65" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Initial bite,&#x0A;direction change" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 5: Road Texture (25 Hz) -->
                    <StackPanel Grid.Column="5" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="ROAD&#x0A;TEXTURE" FontSize="13" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="25 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider5" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand5Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel5" Text="{Binding EqBand5Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Tarmac grain,&#x0A;surface roughness" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 6: Bump Detail (35 Hz) -->
                    <StackPanel Grid.Column="6" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="BUMP&#x0A;DETAIL" FontSize="13" FontWeight="Bold" Foreground="#FFFFB74D" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="35 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider6" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand6Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel6" Text="{Binding EqBand6Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFFB74D" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Patches, seams,&#x0A;road features" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 7: Kerb Strike (50 Hz) -->
                    <StackPanel Grid.Column="7" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="KERB&#x0A;STRIKE" FontSize="13" FontWeight="Bold" Foreground="#FFFF9800" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="50 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider7" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand7Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel7" Text="{Binding EqBand7Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFFF9800" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Kerb hits, potholes,&#x0A;sharp impacts" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 8: Chatter (70 Hz) -->
                    <StackPanel Grid.Column="8" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="WHEEL&#x0A;CHATTER" FontSize="13" FontWeight="Bold" Foreground="#FFEF5350" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="70 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider8" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand8Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel8" Text="{Binding EqBand8Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFEF5350" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="Rapid vibration,&#x0A;wheel buzz" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Band 9: Fine Buzz (100 Hz) -->
                    <StackPanel Grid.Column="9" HorizontalAlignment="Center" Margin="2,0">
                        <TextBlock Text="ABS/TC&#x0A;PULSES" FontSize="13" FontWeight="Bold" Foreground="#FFCE93D8" HorizontalAlignment="Center" Margin="0,0,0,2" TextAlignment="Center" />
                        <TextBlock Text="100 Hz" FontSize="13" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <Slider x:Name="EqSlider9" Style="{StaticResource VerticalEqSlider}" Value="{Binding EqBand9Gain}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" Height="320" Margin="0,0,0,4" ValueChanged="EqSlider_ValueChanged" />
                        <TextBlock x:Name="EqValueLabel9" Text="{Binding EqBand9Gain, StringFormat='{}{0:F1} dB'}" FontSize="14" FontWeight="Bold" Foreground="#FFCE93D8" HorizontalAlignment="Center" Margin="0,2,0,4" />
                        <TextBlock Text="ABS/TC pulsing,&#x0A;finest vibration" FontSize="11" Foreground="#FF777777" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Connecting curve overlay -->
                    <Canvas x:Name="EqCurveCanvas" Grid.ColumnSpan="10" IsHitTestVisible="False" />
                </Grid>
            </Border>

            <Border Background="#FF161B22" CornerRadius="4" Padding="12,8" Margin="0,4,0,0">
                <TextBlock Text="Tip: Start flat (0 dB), then boost/cut one band at a time while driving. The EQ shapes the final force signal right before it reaches the wheel. 10-band parametric at ~333 Hz sample rate." FontSize="12" Foreground="#FF8B949E" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
