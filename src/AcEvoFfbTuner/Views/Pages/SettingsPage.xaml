<UserControl x:Class="AcEvoFfbTuner.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="480" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Settings content -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel HorizontalAlignment="Stretch">

                <TextBlock Text="SETTINGS" FontSize="24" FontWeight="Black" Foreground="#FFF0883E" Margin="0,0,0,4" />
                <TextBlock Text="App configuration and developer tools" FontSize="15" Foreground="#FF8B949E" Margin="0,0,0,16" TextWrapping="Wrap" />
                <Border Background="#FF30363D" Height="1" Margin="0,0,0,24" />

                <!-- APP OPTIONS + STARTUP EFFECT side by side -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- APP OPTIONS -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="APP OPTIONS" FontSize="18" FontWeight="Bold" Foreground="#FFF0883E" Margin="0,0,0,4" />
                        <TextBlock Text="Control how the app behaves on launch." FontSize="14" Foreground="#FF8B949E" Margin="0,0,0,12" TextWrapping="Wrap" />

                        <Border Background="#FF1C2128" CornerRadius="8" Padding="16,14"
                                BorderThickness="1" BorderBrush="#FF30363D">
                            <StackPanel>
                                <CheckBox Content="Start Minimised" IsChecked="{Binding StartMinimised}"
                                          FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Minimise the window to the taskbar on launch instead of showing it." FontSize="12" Foreground="#FF8B949E" Margin="28,0,0,16" TextWrapping="Wrap" />

                                <CheckBox Content="Auto Connect" IsChecked="{Binding AutoConnect}"
                                          FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Automatically connect to the last used FFB device on startup." FontSize="12" Foreground="#FF8B949E" Margin="28,0,0,16" TextWrapping="Wrap" />

                                <CheckBox Content="Auto Start" IsChecked="{Binding AutoStart}"
                                           FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Automatically start telemetry processing after the device connects (requires Auto Connect)." FontSize="12" Foreground="#FF8B949E" Margin="28,0,0,16" TextWrapping="Wrap" />

                                <CheckBox Content="Show Tooltips" IsChecked="{Binding TooltipsEnabled}"
                                           FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Show helpful tooltips when hovering over controls." FontSize="12" Foreground="#FF8B949E" Margin="28,0,0,16" TextWrapping="Wrap" />

                                <CheckBox Content="Auto Upgrade Profiles" IsChecked="{Binding AutoProfileUpgrade}"
                                           FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Automatically upgrade profile data when a new app version requires schema changes. When off, profiles needing an upgrade will show a warning indicator." FontSize="12" Foreground="#FF8B949E" Margin="28,0,0,16" TextWrapping="Wrap" />

                                <TextBlock Text="Default Start Page" FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <ComboBox SelectedIndex="{Binding DefaultStartPageIndex}" FontSize="14" Padding="6,4" Margin="0,0,0,0">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Foreground" Value="#FFE6EDF3" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="Home" />
                                    <ComboBoxItem Content="FFB Tuning" />
                                    <ComboBoxItem Content="Equalizer" />
                                    <ComboBoxItem Content="Track Map" />
                                    <ComboBoxItem Content="Telemetry" />
                                    <ComboBoxItem Content="Devices" />
                                    <ComboBoxItem Content="Profiles" />
                                </ComboBox>
                                <TextBlock Text="Choose which page the app opens to on startup." FontSize="12" Foreground="#FF8B949E" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- STARTUP EFFECT -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="STARTUP EFFECT" FontSize="18" FontWeight="Bold" Foreground="#FFF0883E" Margin="0,0,0,4" />
                        <TextBlock Text="Customize the splash screen and startup sound." FontSize="14" Foreground="#FF8B949E" Margin="0,0,0,12" TextWrapping="Wrap" />

                        <Border Background="#FF1C2128" CornerRadius="8" Padding="16,14"
                                BorderThickness="1" BorderBrush="#FF30363D">
                            <StackPanel>
                                <CheckBox Content="Show splash screen on startup" IsChecked="{Binding SplashScreenEnabled}"
                                          FontSize="15" Foreground="#FFE6EDF3" Margin="0,0,0,12" />

                                <TextBlock Text="Audio Output Device" FontSize="14" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding AudioOutputDevices}"
                                              SelectedItem="{Binding SelectedAudioOutputDevice}"
                                              FontSize="14" Padding="6,4" Margin="0,0,10,0" />
                                    <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRecordingDevicesCommand}"
                                            Padding="10,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="&#xE120;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding StartRecordingCommand}"
                                            Visibility="{Binding IsRecording, Converter={StaticResource InvertBoolToVis}}"
                                            Padding="10,6" FontSize="16" Margin="0,0,6,0"
                                            Background="#FF00C853" Foreground="White" BorderThickness="0"
                                            ToolTip="Start Recording" />
                                    <Button Grid.Column="1" Content="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding StopRecordingCommand}"
                                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"
                                            Padding="10,6" FontSize="16" Margin="0,0,6,0"
                                            Background="#FFFF1744" Foreground="White" BorderThickness="0"
                                            ToolTip="Stop Recording" />
                                    <Button Grid.Column="2" Content="Preview" Command="{Binding PreviewStartupSoundCommand}"
                                            Padding="10,6" FontSize="14" Style="{StaticResource OutlinedButton}" Margin="0,0,6,0"
                                            ToolTip="Preview the startup sound" />
                                    <Button Grid.Column="3" Content="Browse" Command="{Binding BrowseStartupSoundCommand}"
                                            Padding="10,6" FontSize="14" Style="{StaticResource OutlinedButton}"
                                            ToolTip="Browse for a custom startup sound file" />
                                </Grid>

                                <TextBlock Text="{Binding RecordingStatus}" FontSize="14" Foreground="#FF8B949E" Margin="0,0,0,6" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CustomStartupSoundPath, TargetNullValue='Using default engine sound', FallbackValue='Using default engine sound'}"
                                               FontSize="14" Foreground="#FF8B949E" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="Clear" Command="{Binding ClearStartupSoundCommand}"
                                            Padding="8,2" FontSize="13" Style="{StaticResource OutlinedButton}"
                                            Visibility="{Binding CustomStartupSoundPath, Converter={StaticResource NullToVis}}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Records audio from your selected output device (speakers/headphones). Start recording, then play the game engine sound you want to capture. Or use Browse to pick an existing audio file." Style="{StaticResource SliderDescription}" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <!-- THEME -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="THEME" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Choose the app color scheme. Changes apply immediately." FontSize="14" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="16,14"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <ComboBox SelectedItem="{Binding ThemeMode, Mode=TwoWay}" FontSize="14" Padding="6,4" MinWidth="200" HorizontalAlignment="Left">
                            <ComboBox.ItemsSource>
                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                    <sys:String>Onyx</sys:String>
                                    <sys:String>Slate</sys:String>
                                    <sys:String>Obsidian</sys:String>
                                    <sys:String>Graphite</sys:String>
                                    <sys:String>Amber</sys:String>
                                    <sys:String>Crimson</sys:String>
                                    <sys:String>Jade</sys:String>
                                    <sys:String>Cobalt</sys:String>
                                    <sys:String>Rose</sys:String>
                                    <sys:String>Charcoal</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- VOICE -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="VOICE" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Spoken announcements for key events." FontSize="14" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="16,14"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel>
                            <CheckBox Content="Enable voice announcements" IsChecked="{Binding VoiceEnabled}"
                                      FontSize="15" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />

                            <TextBlock Text="Engine" FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding VoiceEngine}" FontSize="13" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,12" />

                            <TextBlock Text="Voice Pack" FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding VoiceCacheStatus}" FontSize="13" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <Button Content="Open Voice Pack Folder" Command="{Binding OpenVoiceCacheFolderCommand}"
                                    Padding="10,6" FontSize="13" Style="{StaticResource OutlinedButton}"
                                    HorizontalAlignment="Left" Margin="0,0,0,12" />

                            <TextBlock Text="Voice (SAPI)" FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AvailableVoices}" SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                                      FontSize="14" Padding="6,4" Margin="0,0,0,8"
                                      IsEnabled="{Binding VoiceEnabled}" />
                            <StackPanel Margin="0,0,0,12" Visibility="{Binding VoiceEnabled, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="For higher quality voices, install Windows Natural Voices." FontSize="13" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <Button Content="Open Speech Settings" Command="{Binding OpenVoiceSettingsCommand}"
                                        Padding="10,6" FontSize="13" Style="{StaticResource OutlinedButton}"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                            <TextBlock Text="Volume" FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                            <Slider Minimum="0" Maximum="100" Value="{Binding VoiceVolume, Mode=TwoWay}"
                                    TickFrequency="10" TickPlacement="BottomRight"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,0,4" />
                            <TextBlock Text="{Binding VoiceVolume, StringFormat='{}{0}%'}"
                                       FontSize="13" Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Divider -->
        <Border Grid.Column="1" Background="#FF30363D" Width="1" Margin="0,16,0,16" />

        <!-- RIGHT: System Log + Debug Tools -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="0,20,16,16">
            <StackPanel>
                <!-- SYSTEM LOG -->
                <TextBlock Text="SYSTEM LOG" FontSize="14" FontWeight="Bold" Foreground="#FFF0883E" Margin="8,0,0,8" />
                <Border Background="#FF161B22" CornerRadius="8" BorderThickness="1" BorderBrush="#FF30363D" Margin="0,0,0,20">
                    <ListBox x:Name="SystemLogList"
                             ItemsSource="{Binding SystemLogEntries}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#FFE6EDF3" FontFamily="Consolas" FontSize="12"
                             Padding="4" Height="200"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="OnSystemLogSelectionChanged" />
                </Border>

                <!-- DEBUG TOOLS -->
                <TextBlock Text="DEBUG TOOLS" FontSize="14" FontWeight="Bold" Foreground="#FFF0883E" Margin="8,0,0,8" />
                <TextBlock Text="Raw telemetry data from shared memory and the FFB pipeline." FontSize="12" Foreground="#FF8B949E" Margin="8,0,0,8" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Margin="8,0,0,8">
                    <Button Content="Copy All" x:Name="CopyDebugBtn"
                            Click="OnCopyDebugToClipboard" Padding="10,6" FontSize="13"
                            Background="#FF21262D" Foreground="#FFE6EDF3" BorderThickness="0" Margin="0,0,6,0"
                            ToolTip="Copy debug telemetry data to clipboard" />
                    <Button Content="Testing Guide" x:Name="OpenGuideBtn"
                            Click="OnOpenTestingGuide" Padding="10,6" FontSize="13"
                            Background="#FF21262D" Foreground="#FFE6EDF3" BorderThickness="0" Margin="0,0,6,0"
                            ToolTip="Open the FFB testing guide overlay" />
                    <Button Content="Calibration" x:Name="OpenCalBtn"
                            Click="OnOpenCalibrationWizard" Padding="10,6" FontSize="13"
                            Background="#FF21262D" Foreground="#FFE6EDF3" BorderThickness="0"
                            ToolTip="Open the wheel calibration wizard" />
                </StackPanel>

                <Border Background="#FF161B22" CornerRadius="8" BorderThickness="1" BorderBrush="#FF30363D" Margin="0,0,0,0">
                    <ScrollViewer MaxHeight="300" Padding="12">
                        <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 Foreground="#FFE6EDF3" FontFamily="Consolas" FontSize="12"
                                 Text="{Binding DebugSnapshot, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
