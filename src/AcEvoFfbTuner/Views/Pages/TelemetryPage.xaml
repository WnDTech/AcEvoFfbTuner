<UserControl x:Class="AcEvoFfbTuner.Views.Pages.TelemetryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF0F1117"
             Foreground="#FFE6EDF3"
             FontFamily="Segoe UI"
             UseLayoutRounding="True">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1C2128" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="Pop Out Overlay" Click="OpenProfilerOverlay" Padding="12,4" FontSize="14" Margin="0,0,6,0" FontWeight="Bold" ToolTip="Open a floating telemetry profiler overlay" />
                    <Button Content="Snapshot" Click="ProfilerSnapshot" Padding="12,4" FontSize="14" Margin="0,0,6,0" ToolTip="Save a telemetry snapshot of the current data" />
                    <Button Content="Export Analysis" Click="ProfilerExportAnalysis" Padding="12,4" FontSize="14" Margin="0,0,6,0" FontWeight="Bold" ToolTip="Export detailed analysis as a text file" />
                    <Button Content="Export CSV" Click="ProfilerExportCsv" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" ToolTip="Export raw data as CSV for external analysis" />
                    <Button Content="Clear" Click="ProfilerClear" Padding="12,4" FontSize="14" Style="{StaticResource OutlinedButton}" ToolTip="Clear the telemetry graph data" />
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#FF30363D" Margin="8,0" />

                <StackPanel Grid.Column="3" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Speed" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfSpeed" Text="-- km/h" FontSize="16" FontWeight="Bold" Foreground="#FFFFD600" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Force Out" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfForce" Text="--" FontSize="16" FontWeight="Bold" Foreground="#FFF0883E" />
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Throttle" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfGas" Text="--%" FontSize="16" FontWeight="Bold" Foreground="#FF4CAF50" />
                </StackPanel>
                <StackPanel Grid.Column="6" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Brake" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfBrake" Text="--%" FontSize="16" FontWeight="Bold" Foreground="#FFE53935" />
                </StackPanel>
                <StackPanel Grid.Column="7" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Clipping" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfClipPct" Text="0.0%" FontSize="16" FontWeight="Bold" Foreground="#FF00E676" />
                </StackPanel>
                <StackPanel Grid.Column="8" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Min / Max" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfMinMax" Text="-- / --" FontSize="15" Foreground="#FF00BCD4" />
                </StackPanel>
                <StackPanel Grid.Column="9" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Avg Force" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfAvg" Text="--" FontSize="16" Foreground="#FF9C27B0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF1C2128" CornerRadius="6" Padding="6,3" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="6,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Steering" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfSteer" Text="--°" FontSize="15" FontWeight="Bold" Foreground="#FFE6EDF3" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Raw FF" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfRawFF" Text="--" FontSize="15" Foreground="#FF00E676" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="6,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Peak Mz/Fx/Fy" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfPeakChannels" Text="--/--/--" FontSize="15" Foreground="#FFE6EDF3" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="6,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Time" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="ProfTimeWindow" Text="0.0s / 30s" FontSize="15" Foreground="#FF00BCD4" />
                </StackPanel>

                <Border Grid.Column="4" Width="1" Background="#FF30363D" Margin="4,0" />

                <CheckBox x:Name="ShowOutput" Grid.Column="5" Content="Output" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FFF0883E" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowRaw" Grid.Column="6" Content="Raw FF" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FF00E676" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowCompress" Grid.Column="7" Content="Compress" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FF00BCD4" VerticalAlignment="Center" />
                 <CheckBox x:Name="ShowDamping" Grid.Column="8" Content="Gain Out" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FF9C27B0" VerticalAlignment="Center" />
                 <CheckBox x:Name="ShowSlip" Grid.Column="9" Content="Post Damp" IsChecked="False" Margin="4,0" FontSize="14" Foreground="#FFFF5722" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowSpeed" Grid.Column="10" Content="Speed" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FF666666" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowDynamic" Grid.Column="11" Content="Dynamic" IsChecked="False" Margin="4,0" FontSize="14" Foreground="#FF795548" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowSteer" Grid.Column="12" Content="Steer°" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FFFFD600" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowGas" Grid.Column="13" Content="Throttle" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FF4CAF50" VerticalAlignment="Center" />
                <CheckBox x:Name="ShowBrake" Grid.Column="14" Content="Brake" IsChecked="True" Margin="4,0" FontSize="14" Foreground="#FFE53935" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="CHANNELS" FontSize="14" Foreground="#FF00E676" FontWeight="Bold" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FFF0883E" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Output" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF00E676" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Raw FF" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF00BCD4" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Compress" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF9C27B0" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Gain Out" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FFFF5722" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Post Damp" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF795548" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Dynamic" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#FF333355" Height="1" Margin="0,6,0,6" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FFFFD600" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Steering°" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF555555" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Speed" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#FF333355" Height="1" Margin="0,6,0,6" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FF4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Throttle" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="10" Height="10" Fill="#FFE53935" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Brake" FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#FF333355" Height="1" Margin="0,6,0,6" />

                    <TextBlock Text="WINDOW" FontSize="12" Foreground="#FF8B949E" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Scrolling 30-second" FontSize="12" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" />
                    <TextBlock x:Name="ProfSampleRate" Text="~30 Hz sample rate" FontSize="12" Foreground="#FF999999" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FF151525" CornerRadius="6">
                <Grid>
                    <Canvas x:Name="ProfilerCanvas" ClipToBounds="True" />
                    <Canvas x:Name="ProfilerOverlayCanvas" ClipToBounds="True" IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#FF1C2128" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="MzFront" FontSize="13" Foreground="#FF4CAF50" FontFamily="Consolas" VerticalAlignment="Center" />
                <Rectangle Grid.Column="1" x:Name="BarMz" Fill="#804CAF50" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" x:Name="BarMzVal" Text="--" FontSize="13" Foreground="#FF4CAF50" FontFamily="Consolas" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="FxFront" FontSize="13" Foreground="#FF8BC34A" FontFamily="Consolas" VerticalAlignment="Center" />
                <Rectangle Grid.Column="4" x:Name="BarFx" Fill="#808BC34A" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" x:Name="BarFxVal" Text="--" FontSize="13" Foreground="#FF8BC34A" FontFamily="Consolas" VerticalAlignment="Center" />
                <TextBlock Grid.Column="6" Text="FyFront" FontSize="13" Foreground="#FFCDDC39" FontFamily="Consolas" VerticalAlignment="Center" />
                <Rectangle Grid.Column="7" x:Name="BarFy" Fill="#80CDDC39" Height="14" RadiusX="2" RadiusY="2" VerticalAlignment="Center" />
                <TextBlock Grid.Column="8" x:Name="BarFyVal" Text="--" FontSize="13" Foreground="#FFCDDC39" FontFamily="Consolas" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
