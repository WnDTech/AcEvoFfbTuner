<UserControl x:Class="AcEvoFfbTuner.Views.Pages.DevicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: VERTICAL DEVICE TABS (COLLAPSIBLE) ═══ -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel x:Name="SidebarContent" Grid.Row="0" Margin="0,20,0,0">
                    <TextBlock x:Name="HeaderLabel" Text="DEVICES" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" Margin="16,0,0,12" />

                    <RadioButton x:Name="LedTab" GroupName="DeviceTab" IsChecked="True"
                                 Checked="OnTabChecked" Cursor="Hand" ToolTip="LED Effects">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="TabBd" Background="Transparent" Padding="12,10" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💡" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock x:Name="TabLabel" Text="LED Effects" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#1AFFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#0DFFFFFF" />
                                        <Setter TargetName="TabBd" Property="BorderBrush" Value="#FF79C0FF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <RadioButton x:Name="HapticTab" GroupName="DeviceTab"
                                 Checked="OnTabChecked" Cursor="Hand" ToolTip="Haptic Pad">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="TabBd" Background="Transparent" Padding="12,10" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📳" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock x:Name="TabLabel" Text="Haptic Pad" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#1AFFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#0DFFFFFF" />
                                        <Setter TargetName="TabBd" Property="BorderBrush" Value="#FFD2A8FF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <RadioButton x:Name="ButtonsTab" GroupName="DeviceTab"
                                 Checked="OnTabChecked" Cursor="Hand" ToolTip="Buttons">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="TabBd" Background="Transparent" Padding="12,10" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock x:Name="TabLabel" Text="Buttons" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#1AFFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#0DFFFFFF" />
                                        <Setter TargetName="TabBd" Property="BorderBrush" Value="#FFE3B341" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </StackPanel>

                <Button x:Name="CollapseBtn" Grid.Row="2" Click="OnToggleCollapse" Cursor="Hand"
                        HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0"
                        Padding="12,8" Margin="0,0,0,8" ToolTip="Collapse sidebar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CbBd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="CollapseArrow" Text="◂" FontSize="14" Foreground="#FF8B949E"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock x:Name="CollapseLabel" Text="Collapse" FontSize="12" Foreground="#FF8B949E"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CbBd" Property="Background" Value="#1AFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ RIGHT: CONTENT PANELS ═══ -->
        <Grid Grid.Column="1">

            <!-- ═══════════════════════════════════════════ -->
            <!-- PANEL 1: LED EFFECTS                      -->
            <!-- ═══════════════════════════════════════════ -->
            <ScrollViewer x:Name="LedPanel" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="{Binding LedSupportedInfo}" FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                    <!-- LED Strip Preview -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,14" Margin="0,0,0,16"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel>
                            <TextBlock Text="LED PREVIEW" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />
                            <StackPanel x:Name="LedPreviewBar" Orientation="Horizontal" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Two columns -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Flash + Brightness -->
                        <StackPanel Grid.Column="0">

                            <!-- BRIGHTNESS -->
                            <StackPanel Visibility="{Binding LedBrightnessVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="BRIGHTNESS" FontSize="12" FontWeight="Bold" Foreground="#FF79C0FF" Margin="0,0,0,8" />
                                <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                    <controls:LabeledSlider Value="{Binding LedBrightness, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                        Label="Brightness" StringFormat="{}{0}" Suffix="%"
                                        Description="LED brightness (SDK-connected wheels only)"
                                        SectionColor="#FF79C0FF" />
                                </Border>
                            </StackPanel>

                            <!-- FLASH EFFECTS -->
                            <TextBlock Text="FLASH EFFECTS" FontSize="12" FontWeight="Bold" Foreground="#FF79C0FF" Margin="0,0,0,8" />
                            <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,12"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="Shift / Limiter Flash" FontSize="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                        <CheckBox IsChecked="{Binding LedShiftLimiterFlashEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <TextBlock Text="All LEDs flash at redline" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />

                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="Pit Limiter Flash" FontSize="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                        <CheckBox IsChecked="{Binding LedPitLimiterFlashEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <TextBlock Text="Alternating outer LEDs when pit limiter active" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />

                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="ABS Flash" FontSize="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                        <CheckBox IsChecked="{Binding LedAbsFlashEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <TextBlock Text="First &amp; last LED when ABS active" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />

                                    <StackPanel Visibility="{Binding LedFlagIndicatorsVisible, Converter={StaticResource BoolToVis}}">
                                        <DockPanel Margin="0,4">
                                            <TextBlock Text="Race Flag Indicators" FontSize="14" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                            <CheckBox IsChecked="{Binding LedFlagIndicatorsEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </DockPanel>
                                        <TextBlock Text="Yellow, red, blue flags on LEDs" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />
                                    </StackPanel>

                                    <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                                        <controls:LabeledSlider Value="{Binding LedFlashRate, Mode=TwoWay}" Minimum="2" Maximum="60" TickFrequency="1"
                                            Label="Flash Speed" StringFormat="{}{0}"
                                            Description="Lower = faster (2=very fast, 60=slow)"
                                            SectionColor="#FF79C0FF" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- COLOR SCHEME -->
                            <StackPanel Visibility="{Binding LedColorSchemeVisible, Converter={StaticResource BoolToVis}}" Margin="0,16,0,0">
                                <TextBlock Text="COLOR SCHEME" FontSize="12" FontWeight="Bold" Foreground="#FF79C0FF" Margin="0,0,0,8" />
                                <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,12"
                                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Color Preset" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <TextBlock Text="For wheels with per-LED RGB control" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8" />
                                        <ComboBox SelectedIndex="{Binding LedColorSchemeIndex}" Width="240" FontSize="14" Padding="6,4" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Traffic Light (Green/Yellow/Red)" />
                                            <ComboBoxItem Content="Blue Gradient" />
                                            <ComboBoxItem Content="Red Hot" />
                                            <ComboBoxItem Content="Monochrome" />
                                            <ComboBoxItem Content="Custom" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: RPM Thresholds -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="RPM THRESHOLDS" FontSize="12" FontWeight="Bold" Foreground="#FF79C0FF" Margin="0,0,0,8" />
                            <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,12"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="Preset" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <ComboBox SelectedIndex="{Binding LedRpmPresetIndex}" Width="240" FontSize="14" Padding="6,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <ComboBoxItem Content="Default (50-100%)" />
                                        <ComboBoxItem Content="Early (30-100%)" />
                                        <ComboBoxItem Content="Late (70-100%)" />
                                        <ComboBoxItem Content="Linear (10-100%)" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>

                                    <Expander Style="{StaticResource SectionExpander}" Header="Individual RPM Thresholds" IsExpanded="True">
                                        <StackPanel>
                                            <TextBlock Text="Each LED lights up when RPM reaches its threshold (% of redline)" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold1, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 1" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold1Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold2, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 2" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold2Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold3, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 3" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold3Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold4, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 4" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold4Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold5, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 5" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold5Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold6, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 6" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold6Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold7, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 7" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold7Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold8, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 8" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold8Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold9, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 9" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold9Visible, Converter={StaticResource BoolToVis}}" />
                                            <controls:LabeledSlider Value="{Binding LedRpmThreshold10, Mode=TwoWay}" Minimum="5" Maximum="100" TickFrequency="1"
                                                Label="LED 10" LabelWidth="60" StringFormat="{}{0}" Suffix="%" ValueWidth="52"
                                                SectionColor="#FF79C0FF"
                                                Visibility="{Binding LedRpmThreshold10Visible, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="Select a preset first, then switch to Custom to fine-tune" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════ -->
            <!-- PANEL 2: HAPTIC PAD (HF8)                 -->
            <!-- ═══════════════════════════════════════════ -->
            <ScrollViewer x:Name="HapticPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                <StackPanel>

                    <!-- Connection Status -->
                    <TextBlock Text="{Binding Hf8ConnectionStatus}" FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <TextBlock Text="Map telemetry sources (suspension, slip, kerbs, G-force, engine) to individual seat and back motor zones."
                               FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                    <!-- MASTER CONTROLS BAR -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20,16" Margin="0,0,0,20"
                            BorderThickness="1" BorderBrush="#33D2A8FF">
                        <StackPanel>
                            <DockPanel VerticalAlignment="Center" Margin="0,0,0,12">
                                <CheckBox IsChecked="{Binding Hf8Enabled}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Haptic Output" FontSize="16" FontWeight="Bold" Foreground="#FFD2A8FF" VerticalAlignment="Center" />
                            </DockPanel>
                            <controls:LabeledSlider Value="{Binding Hf8MasterGain, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                Label="Master Gain" StringFormat="{}{0:F2}" LabelWidth="110"
                                Description="Overall intensity for all motor zones"
                                SectionColor="#FFD2A8FF" />
                            <controls:LabeledSlider Value="{Binding Hf8OutputRateHz, Mode=TwoWay}" Minimum="15" Maximum="120" TickFrequency="1"
                                Label="Output Rate" StringFormat="{}{0}" Suffix=" Hz" LabelWidth="110"
                                Description="75 Hz for HF8 Pro, 15 Hz for original HF8"
                                SectionColor="#FFD2A8FF" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- MOTOR LAYOUT: 4 rows x 2 cols (Left | Right) -->

                    <!-- ROW 1: SEAT FRONT — M8 FL (left) | M7 FR (right) -->
                    <TextBlock Text="SEAT FRONT" FontSize="12" FontWeight="Bold" Foreground="#FF79C0FF" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#3379C0FF">
                            <StackPanel>
                                <TextBlock Text="Seat Front Left" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain1, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FF79C0FF" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled1}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp1, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip1, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb1, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG1, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine1, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#3379C0FF">
                            <StackPanel>
                                <TextBlock Text="Seat Front Right" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain0, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FF79C0FF" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled0}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp0, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip0, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb0, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG0, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine0, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF79C0FF" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ROW 2: SEAT REAR — M6 RL (left) | M5 RR (right) -->
                    <TextBlock Text="SEAT REAR" FontSize="12" FontWeight="Bold" Foreground="#FF56D4A0" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#3356D4A0">
                            <StackPanel>
                                <TextBlock Text="Seat Rear Left" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain3, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FF56D4A0" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled3}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp3, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip3, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb3, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG3, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine3, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#3356D4A0">
                            <StackPanel>
                                <TextBlock Text="Seat Rear Right" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain2, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FF56D4A0" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled2}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp2, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip2, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb2, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG2, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine2, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FF56D4A0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ROW 3: BACK LOWER — M4 LL (left) | M3 LR (right) -->
                    <TextBlock Text="BACK LOWER" FontSize="12" FontWeight="Bold" Foreground="#FFE08040" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#33E08040">
                            <StackPanel>
                                <TextBlock Text="Back Lower Left" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain5, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FFE08040" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled5}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp5, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip5, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb5, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG5, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine5, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#33E08040">
                            <StackPanel>
                                <TextBlock Text="Back Lower Right" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain4, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FFE08040" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled4}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp4, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip4, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb4, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG4, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine4, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFE08040" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ROW 4: BACK UPPER — M2 UL (left) | M1 UR (right) -->
                    <TextBlock Text="BACK UPPER" FontSize="12" FontWeight="Bold" Foreground="#FFF0883E" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#33F0883E">
                            <StackPanel>
                                <TextBlock Text="Back Upper Left" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain7, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FFF0883E" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled7}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp7, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip7, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb7, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG7, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine7, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12"
                                BorderThickness="1" BorderBrush="#33F0883E">
                            <StackPanel>
                                <TextBlock Text="Back Upper Right" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9D1D9" Margin="0,0,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8ZoneGain6, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01"
                                    Label="Zone Intensity" StringFormat="{}{0:F2}" ValueWidth="52" SectionColor="#FFF0883E" />
                                <CheckBox IsChecked="{Binding Hf8ZoneEnabled6}" Content="Enabled" FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,4" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSusp6, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Suspension" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcSlip6, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Tire Slip" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcKerb6, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Kerbs" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcLatG6, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Lateral G" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                                <controls:LabeledSlider Value="{Binding Hf8SrcEngine6, Mode=TwoWay}" Minimum="0" Maximum="3" TickFrequency="0.05"
                                    Label="Engine RPM" StringFormat="{}{0:F2}" ValueWidth="48" SectionColor="#FFF0883E" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- MOTOR TEST BUTTON -->
                    <Button Content="&#x2699; Test Motors"
                            Click="OnOpenMotorTest"
                            Background="#FF333355" Foreground="#FFFF9800" BorderThickness="0"
                            Padding="16,10" FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            HorizontalAlignment="Left" Margin="0,0,0,16"
                            ToolTip="Test individual haptic pad motors">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        BorderThickness="1" BorderBrush="#44FF9800">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#44FF9800" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- CONNECTION INFO PANEL -->
                    <Border Background="#FF1A1A2E" CornerRadius="6" Padding="14,10" Margin="0,0,0,0"
                            BorderThickness="1" BorderBrush="#333355">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="USB" FontSize="11" FontWeight="Bold" Foreground="#FF6666AA" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FF9999CC" VerticalAlignment="Center">
                                <Run Text="Connect the HF8 / HF8 Pro via USB. Close the NLR HFS software before use — it holds exclusive HID access." />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════ -->
            <!-- PANEL 3: BUTTON ASSIGNMENTS               -->
            <!-- ═══════════════════════════════════════════ -->
            <ScrollViewer x:Name="ButtonsPanel" VerticalScrollBarVisibility="Auto" Padding="24,20" Visibility="Collapsed">
                <StackPanel>

                    <TextBlock Text="Configure wheel and button box inputs for in-app actions." FontSize="14" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,20" TextWrapping="Wrap" />

                    <!-- Snapshot Button Card -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                            BorderThickness="1" BorderBrush="#33E3B341">
                        <StackPanel>
                            <TextBlock Text="SNAPSHOT BUTTON" FontSize="12" FontWeight="Bold" Foreground="#FFE3B341" Margin="0,0,0,4" />
                            <TextBlock Text="Press while driving to auto-save a telemetry snapshot" FontSize="13" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Button:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding SnapshotButtonNames}" SelectedIndex="{Binding SnapshotButtonComboIndex}" FontSize="14" Padding="6,4" Margin="0,0,6,0" />
                                <Button Grid.Column="2" Content="Assign" Command="{Binding AssignSnapshotButtonCommand}" Padding="12,6" FontSize="14" Style="{StaticResource OutlinedButton}" ToolTip="Listen for a button press to assign as snapshot trigger" />
                            </Grid>
                            <TextBlock Text="{Binding SnapshotAssignStatus}" FontSize="13" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding SnapshotAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                            <TextBlock Text="{Binding ButtonDetectionText}" FontSize="13" Foreground="#FFFFD600" FontWeight="Bold" />
                            <TextBlock Text="Uses your FFB wheel device. Select a button easy to reach while driving." FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Panic Stop Button Card -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                            BorderThickness="1" BorderBrush="#33FF7B72">
                        <StackPanel>
                            <TextBlock Text="PANIC STOP BUTTON" FontSize="12" FontWeight="Bold" Foreground="#FFFF7B72" Margin="0,0,0,4" />
                            <TextBlock Text="Assign a button on a SEPARATE device (e.g. button box) as hardware panic stop. Immediately zeros all FFB output." FontSize="13" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Device:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding PanicDevices}" SelectedItem="{Binding SelectedPanicDevice}" FontSize="14" Padding="6,4" Margin="0,0,10,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProductName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshDevicesCommand}" Padding="12,6" FontSize="14" Style="{StaticResource OutlinedButton}" ToolTip="Refresh the list of connected devices" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Button:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding PanicButtonNames}" SelectedIndex="{Binding PanicButtonComboIndex}" FontSize="14" Padding="6,4" Margin="0,0,6,0" />
                                <Button Grid.Column="2" Content="Assign" Command="{Binding AssignPanicButtonCommand}" Padding="12,6" FontSize="14" Style="{StaticResource OutlinedButton}" ToolTip="Listen for a button press to assign as panic stop" />
                            </Grid>

                            <TextBlock Text="{Binding PanicAssignStatus}" FontSize="13" Foreground="#FFFFD600" FontWeight="Bold" Visibility="{Binding PanicAssignStatus, Converter={StaticResource NotEmptyToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- Panic Info -->
                    <Border Background="#FF1A1A2E" CornerRadius="6" Padding="14,10"
                            BorderThickness="1" BorderBrush="#333355">
                        <TextBlock Text="The panic device is opened in non-exclusive mode, so it won't conflict with the game or your FFB wheel." FontSize="13" Foreground="#FF9999CC" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
