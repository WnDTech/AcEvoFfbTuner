<UserControl x:Class="AcEvoFfbTuner.Views.Pages.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="PROFILES" FontSize="24" FontWeight="Black" Foreground="#FFF0883E" Margin="0,0,0,4" />
            <TextBlock Text="Manage your FFB profiles for different cars and wheel setups" FontSize="15" Foreground="#FF8B949E" Margin="0,0,0,16" />
            <Border Background="#FF333355" Height="1" Margin="0,0,0,16" />

            <TextBlock Text="Current Profile" Style="{StaticResource SubSectionHeader}" />
            <Border Background="#FF1C2128" CornerRadius="6" Padding="16,10" Margin="0,4,0,16">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Active Profile" Width="100" VerticalAlignment="Center" FontSize="15" />
                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name" Width="280" HorizontalAlignment="Left" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Car Match" Width="100" VerticalAlignment="Center" FontSize="15" />
                        <TextBox Text="{Binding ProfileCarMatch, UpdateSourceTrigger=PropertyChanged}"
                                 Width="195" HorizontalAlignment="Left" FontSize="14"
                                 ToolTip="AC EVO car model name for auto-loading this profile. Click 'Use Detected' to auto-fill." />
                        <Button Content="Use Detected" Command="{Binding SetCarMatchFromDetectedCommand}"
                                Padding="8,3" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"
                                ToolTip="Fill from detected car model" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Detected" Width="100" VerticalAlignment="Center" FontSize="15" Foreground="#FF8B949E" />
                        <TextBlock VerticalAlignment="Center" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF66BB6A" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DetectedCarModel}" Value="">
                                            <Setter Property="Foreground" Value="#FF8B949E" />
                                            <Setter Property="Text" Value="Start a session in AC EVO to detect car model" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="DetectedCarModel" />
                            </TextBlock.Text>
                        </TextBlock>
                    </DockPanel>
                    <CheckBox Content="Auto-load profile when car changes" IsChecked="{Binding IsPerCarAutoLoadEnabled}"
                              Margin="100,4,0,4" FontSize="13" Foreground="#FFE6EDF3" />
                </StackPanel>
            </Border>

            <TextBlock Text="Actions" Style="{StaticResource SubSectionHeader}" />
            <Border Background="#FF1C2128" CornerRadius="6" Padding="16,10" Margin="0,4">
                <StackPanel>
                    <Button Content="Save Current Profile" Command="{Binding SaveCurrentProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="ToolTip" Value="Save current profile" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBuiltInProfileSelected}" Value="True">
                                        <Setter Property="Content" Value="Save Current Profile (Built-in → Save As)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Save As New Profile..." Command="{Binding SaveAsNewProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left" />
                    <Button Content="Rename Profile" Command="{Binding RenameProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource OutlinedButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBuiltInProfileSelected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="ToolTip" Value="Built-in profiles cannot be renamed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Delete Profile" Command="{Binding DeleteProfileCommand}" Margin="0,4" Padding="16,6" HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBuiltInProfileSelected}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="ToolTip" Value="Built-in profiles cannot be deleted" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Text="Import / Export" Style="{StaticResource SubSectionHeader}" Margin="0,12,0,0" />
            <Border Background="#FF1C2128" CornerRadius="6" Padding="16,10" Margin="0,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Export Profile" Command="{Binding ExportProfileCommand}" Margin="0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                    <Button Content="Import Profile" Command="{Binding ImportProfileCommand}" Margin="8,4,0,4" Padding="16,6" Style="{StaticResource OutlinedButton}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
