<UserControl x:Class="AcEvoFfbTuner.Views.Pages.LiveTrackMapPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             Background="#FF0F1117"
             Foreground="#FFE6EDF3"
             FontFamily="Segoe UI"
             UseLayoutRounding="True">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Track info bar -->
        <Border Grid.Row="0" Background="#FF1C2128" CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="TRACK" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="TrackName" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FFE6EDF3" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="SPEED" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="SpeedValue" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FF00E676" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="SECTOR" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="SectorValue" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="CORNER" FontSize="11" Foreground="#FF8B949E" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="CornerNumber" Text="--" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" />
                        <TextBlock x:Name="CornerName" Text="" FontSize="13" Foreground="#FF79C0FF" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="LAP" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="LapValue" Text="--" FontSize="14" Foreground="#FFE6EDF3" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="POSITION" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="PositionValue" Text="--" FontSize="12" Foreground="#FF79C0FF" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="6" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="PIT" FontSize="11" Foreground="#FF8B949E" />
                    <TextBlock x:Name="PitStatus" Text="-" FontSize="14" Foreground="#FF8B949E" FontFamily="Consolas" />
                </StackPanel>

                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="SatelliteToggle" Content="Satellite" Padding="10,4" FontSize="13"
                                  IsChecked="True" Checked="OnSatelliteToggled" Unchecked="OnSatelliteToggled"
                                  Background="#FF2E7D32" Foreground="#FFE6EDF3" BorderThickness="0" Margin="4,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: OSM status bar -->
        <Border Grid.Row="1" Background="#FF161B22" CornerRadius="4" Padding="6,3" Margin="0,0,0,4"
                Height="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="OsmStatusText" Text="Initializing..." FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" x:Name="OsmDataCount" Text="" FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Row 2: Map area -->
        <Grid Grid.Row="2">
            <controls:MapsuiMapControl x:Name="MapCtrl" />
        </Grid>

        <!-- Row 3: Bottom status bar -->
        <Border Grid.Row="3" Background="#FF1C2128" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="ProgressValue" Text="" FontSize="12" Foreground="#FF00BCD4" FontFamily="Consolas" Margin="0,0,16,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SRC:" FontSize="12" Foreground="#FF8B949E" Margin="0,0,4,0" />
                    <TextBlock x:Name="DataSourceLabel" Text="--" FontSize="12" Foreground="#FFFFD600" FontWeight="Bold" Margin="0,0,12,0" />
                    <TextBlock Text="Data:" FontSize="12" Foreground="#FF8B949E" Margin="0,0,4,0" />
                    <TextBlock x:Name="OsmDetail" Text="idle" FontSize="12" Foreground="#FF79C0FF" />
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="StatusDetail" Text="Ready" FontSize="12" Foreground="#FF8B949E" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center" />
                <Button Grid.Column="3" x:Name="RefreshDataBtn" Content="⟳ Refresh Data" Padding="8,3" FontSize="11"
                        Background="#FF3A3F4B" Foreground="#FFE6EDF3" BorderThickness="0" Margin="4,0,0,0"
                        Click="OnRefreshData" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
