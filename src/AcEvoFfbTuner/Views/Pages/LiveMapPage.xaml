<UserControl x:Class="AcEvoFfbTuner.Views.Pages.LiveMapPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             Background="#FF0F1117"
             Foreground="#FFE6EDF3"
             FontFamily="Segoe UI"
             UseLayoutRounding="True">
    <Grid>
        <controls:MapsuiMapControl x:Name="MapCtrl" />

        <Border x:Name="StatusOverlay" Background="#CC1a1a2e"
                CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="24,16" Visibility="Visible"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                <TextBlock Text="LIVE MAP" FontSize="18" FontWeight="Bold"
                           Foreground="#FF79C0FF" HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock x:Name="StatusText" Text="Waiting for track data..."
                           FontSize="14" Foreground="#FF8B949E" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Background="#E0000000" CornerRadius="6"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Padding="12,8" Margin="8"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="LIVE MAP" FontSize="13" FontWeight="Bold"
                           Foreground="#FF79C0FF" Margin="0,0,0,4" />
                <TextBlock x:Name="TrackNameLabel" Text="Track: --"
                           FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" Margin="0,0,0,2" />
                <TextBlock x:Name="AlignmentLabel" Text="Alignment: --"
                           FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" Margin="0,0,0,2" />
                <TextBlock x:Name="CarPosLabel" Text="Car: --"
                           FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" Margin="0,0,0,2" />
                <TextBlock x:Name="GpsPosLabel" Text="GPS: --"
                           FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" Margin="0,0,0,2" />
                <TextBlock x:Name="SpeedLabel" Text="Speed: --"
                           FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" />
            </StackPanel>
        </Border>

        <Border x:Name="ControlsPanel" Background="#E0000000" CornerRadius="6"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Padding="12,8" Margin="8">
            <StackPanel>
                <TextBlock Text="CONTROLS" FontSize="11" FontWeight="Bold"
                           Foreground="#FF79C0FF" Margin="0,0,0,4" />
                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#FF8B949E" MaxWidth="180">
                    <Run Text="Scroll" FontWeight="Bold" Foreground="#FFE6EDF3" />
                    <Run Text=" — zoom in/out" /><LineBreak />
                    <Run Text="Drag" FontWeight="Bold" Foreground="#FFE6EDF3" />
                    <Run Text=" — pan map" />
                </TextBlock>
                <Border Background="#FF333355" Height="1" Margin="0,6" />
                <Button x:Name="CalibrateBtn" Content="Calibrate Position" Padding="8,4"
                        FontSize="11" FontWeight="Bold" Background="#FF444444"
                        Foreground="#FFE6EDF3" BorderThickness="0" Margin="0,0,0,4"
                        Click="OnCalibrate" />
                <Button x:Name="CenterOnCarBtn" Content="Center on Car" Padding="8,4"
                        FontSize="11" Background="#FF444444"
                        Foreground="#FFE6EDF3" BorderThickness="0"
                        Click="OnCenterOnCar" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
