<UserControl x:Class="AcEvoFfbTuner.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24">
        <StackPanel>

            <!-- Update Available Banner (prominent — top priority) -->
            <Border Background="#55FFD600" CornerRadius="8" Padding="16,12" Margin="0,0,0,8"
                    BorderThickness="1" BorderBrush="#88FFD600"
                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="#FFFFD600">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏫ Update available" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                            <Setter Property="Text" Value="⏬ Downloading update..." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding UpdateStatusText}" FontSize="12" Foreground="#FFE6EDF3" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding LatestVersionText, StringFormat='Install {0}'}"
                            Command="{Binding DownloadAndInstallUpdateCommand}" Cursor="Hand"
                            FontSize="13" FontWeight="Bold" Padding="18,8" Margin="12,0,0,0"
                            Background="#FF0D1117" Foreground="#FFFFD600" BorderThickness="0"
                            ToolTip="Download the latest version" />
                </Grid>
            </Border>

            <!-- ═══ GLASS COCKPIT PFD ═══ (seamless instrument panel) -->
            <Border Background="#FF0D1117" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="#FF30363D">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Top strip: speed + status -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SpeedKmh, StringFormat='{}{0:F0}'}"
                                       FontSize="40" FontWeight="Black" Foreground="#FFFFD600" />
                            <TextBlock Text="km/h" FontSize="13" Foreground="#FF8B949E" Margin="6,8,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="IDLE" />
                                        <Setter Property="Foreground" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="RUNNING" />
                                                <Setter Property="Foreground" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding PacketsPerSecond, StringFormat='  {0} pkt/s'}" FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="14,0,0,0" />
                            <Ellipse Width="3" Height="3" Fill="#FF30363D" Margin="8,0" VerticalAlignment="Center" />
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                <Setter Property="Fill" Value="#FFFF7B72" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FF8B949E">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OK" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                <Setter Property="Text" Value="CLIP" />
                                                <Setter Property="Foreground" Value="#FFFF7B72" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="1" Grid.RowSpan="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Height="1" Background="#FF21262D" Margin="0,0,0,12" />

                    <!-- Main 3-column instrument panel (equal widths) -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <Style TargetType="Border" x:Key="PanelBorder">
                                <Setter Property="Background" Value="#FF0D1117" />
                                <Setter Property="BorderBrush" Value="#FF21262D" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="CornerRadius" Value="6" />
                                <Setter Property="Padding" Value="16,12" />
                            </Style>
                        </Grid.Resources>

                        <!-- LEFT: G-Force instrument (fills the box) -->
                        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,6,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Stretch="Uniform" MaxWidth="160" Margin="0,0,0,8">
                                    <Grid Width="100" Height="100">
                                        <Line X1="50" Y1="4" X2="50" Y2="96" Stroke="#FF21262D" StrokeThickness="1" />
                                        <Line X1="4" Y1="50" X2="96" Y2="50" Stroke="#FF21262D" StrokeThickness="1" />
                                        <Ellipse Width="82" Height="82" Stroke="#FF21262D" StrokeThickness="1" />
                                        <TextBlock Text="G" FontSize="12" Foreground="#FF484F58"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Ellipse x:Name="GForceDot" Width="10" Height="10" Fill="#FF79C0FF"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top" />
                                        <Ellipse Width="14" Height="14" Stroke="#3379C0FF" StrokeThickness="2"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                                 Margin="43,43,0,0" IsHitTestVisible="False" />
                                    </Grid>
                                </Viewbox>
                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                        <TextBlock Text="LAT" FontSize="9" Foreground="#FF8B949E" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LatG, StringFormat='{}{0:F2}'}" FontSize="12" Foreground="#FF79C0FF" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="LNG" FontSize="9" Foreground="#FF8B949E" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LongG, StringFormat='{}{0:F2}'}" FontSize="12" Foreground="#FF79C0FF" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- CENTER: Force instrument (vertically centered) -->
                        <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="3,0">
                            <Grid VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="FORCE" FontSize="9" FontWeight="Bold" Foreground="#FF8B949E"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding CurrentForceOutput, StringFormat='{}{0:F2}'}"
                                               FontSize="44" FontWeight="Black" Foreground="#FFE6EDF3" />
                                    <TextBlock Text="Nm" FontSize="16" Foreground="#FF8B949E" Margin="6,12,0,0" />
                                </StackPanel>
                                <Border Grid.Row="2" Background="#FF161B22" CornerRadius="3"
                                        Height="20" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#FF21262D">
                                    <Border x:Name="ForceBarFill" Background="#F0883E" CornerRadius="3"
                                            HorizontalAlignment="Left" Width="0" />
                                </Border>
                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CurrentRawForce, StringFormat='raw {0:F2}'}"
                                               FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Left" />
                                    <Ellipse Grid.Column="1" Width="4" Height="4" Fill="#FF30363D" Margin="4,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Ellipse Width="6" Height="6" Margin="0,0,4,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#FF484F58" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                            <Setter Property="Fill" Value="#FFFF7B72" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="OK" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                            <Setter Property="Text" Value="CLIP" />
                                                            <Setter Property="Foreground" Value="#FFFF7B72" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Steering instrument -->
                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="STEERING" FontSize="9" FontWeight="Bold" Foreground="#FF8B949E"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                                <Viewbox Stretch="Uniform" MaxWidth="100" MaxHeight="100" Margin="0,0,0,10">
                                    <Image x:Name="DashboardWheelImage"
                                           Source="pack://application:,,,/Resources/splash-wheels/MOZA-KS-PRO_1.png"
                                           Width="80" Height="80" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <RotateTransform Angle="{Binding SteerAngle}" />
                                        </Image.RenderTransform>
                                    </Image>
                                </Viewbox>
                                <TextBlock Text="{Binding SteerAngle, StringFormat='{}{0:F1}°'}"
                                           FontSize="20" FontWeight="Bold" Foreground="#FFE6EDF3"
                                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="steering angle" FontSize="9" Foreground="#FF8B949E"
                                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="#F0883E" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                                        <Setter Property="Text" Value="{Binding WheelMaxTorqueNm, StringFormat='{}{0:F0}° lock'}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- Bottom annunciator strip -->
                    <Border Grid.Row="2" Background="#FF0D1117" CornerRadius="4"
                            BorderThickness="1" BorderBrush="#FF21262D" Padding="14,8" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF484F58" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF7EE787" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding GameDisplayName}" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF484F58" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF79C0FF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding DeviceName}" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="6" Height="6" Fill="#F0883E" Margin="0,0,5,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue='No Profile'}" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF484F58" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHalHapticEngineActive}" Value="True">
                                                    <Setter Property="Fill" Value="#FF7EE787" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="HAPT" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF484F58" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHalSdkConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#FF7EE787" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="SDK" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="6" Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF484F58" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHalPeripheralSynced}" Value="True">
                                                    <Setter Property="Fill" Value="#FF7EE787" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="PERIPH" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- ═══ SETUP WIZARD ═══ -->
            <Border x:Name="SetupWizardCard"
                    CornerRadius="10" Padding="28,22"
                    BorderThickness="2" BorderBrush="#FFF0883E" Margin="0,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF2D1F00" Offset="0" />
                        <GradientStop Color="#FF1C2128" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                            Background="#33F0883E" CornerRadius="20" Width="56" Height="56"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="&#x26A1;" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="SETUP WIZARD" FontSize="12" FontWeight="Bold" Foreground="#FFF0883E" Margin="0,0,0,2" />
                        <TextBlock Text="Guided FFB Tuning for AC EVO, RaceRoom, Assetto Corsa &amp; Le Mans Ultimate" FontSize="20" FontWeight="Black" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FF8B949E" MaxWidth="400">
                            Step-by-step wheel setup · Works with your game running · Tune, test, and save profiles
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                            x:Name="LaunchSetupWizardBtn"
                            Content="&#x26A1;  LAUNCH WIZARD"
                            FontSize="16" FontWeight="Bold" Cursor="Hand"
                            Padding="28,14" VerticalAlignment="Center"
                            ToolTip="Open the guided Setup Wizard overlay"
                            Click="OnLaunchSetupWizard">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFF0883E" />
                                <Setter Property="Foreground" Value="#FF1C2128" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFE6B800" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFCC8800" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ ZONE 3: THE GARAGE ═══ -->
            <StackPanel>

                <!-- Hardware Insight Strip -->
                <Border Background="#FF1C2128" CornerRadius="8" Padding="16,10" Margin="0,0,0,8"
                        BorderThickness="1" BorderBrush="#FF30363D">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="HARDWARE" FontSize="9" FontWeight="Bold" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding HalProviderName}" FontSize="12" FontWeight="SemiBold" Foreground="#FFF0883E" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <Ellipse Width="6" Height="6" Margin="0,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalSdkConnected}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="SDK" FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <Ellipse Width="6" Height="6" Margin="0,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalHapticEngineActive}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Haptics" FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Ellipse Width="6" Height="6" Margin="0,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalPeripheralSynced}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Peripheral" FontSize="11" Foreground="#FF8B949E" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Command="{Binding TestBuzzCommand}" Cursor="Hand"
                                Content="Test Buzz" FontSize="11" FontWeight="SemiBold" Padding="12,5"
                                Background="#33F0883E" Foreground="#FFE6EDF3" BorderBrush="#33F0883E"
                                BorderThickness="1"
                                ToolTip="Play a 500ms diagnostic vibration on your wheel">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="True">
                                                    <TextBlock Text="{TemplateBinding Content}"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               FontSize="{TemplateBinding FontSize}"
                                                               FontWeight="{TemplateBinding FontWeight}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#55F0883E" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF161B22" />
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF30363D" />
                                                        <Setter Property="Foreground" Value="#FF484F58" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestBuzzRunning}" Value="True">
                                            <Setter Property="Content" Value="Buzzing..." />
                                            <Setter Property="Foreground" Value="#FFFFD600" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border Background="#FF1C2128" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="#FF30363D"
                        Visibility="{Binding StatusText, Converter={StaticResource NotEmptyToVis}}">
                    <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="#FF8B949E" TextWrapping="Wrap" />
                </Border>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>