<UserControl x:Class="AcEvoFfbTuner.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24">
        <StackPanel>

            <!-- QUICK START — Horizontal stepper, auto-hide when connected -->
            <Border x:Name="QuickStartCard" Background="#FF1C2128" CornerRadius="8" Padding="24,18"
                    BorderThickness="1" BorderBrush="#FF30363D" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="QUICK START" FontSize="15" FontWeight="Bold" Foreground="#FFF0883E" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Dismiss" Click="OnDismissQuickStart"
                                Padding="8,4" FontSize="12" Background="Transparent" Foreground="#FF8B949E" BorderThickness="0" Cursor="Hand" />
                    </DockPanel>

                    <!-- Horizontal stepper: 1 → 2 → 3 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Step 1 -->
                        <Border Grid.Column="0" Background="#FF21262D" CornerRadius="6" Padding="16,14">
                            <StackPanel>
                                <Border Background="#FFF0883E" CornerRadius="12" Width="24" Height="24" Margin="0,0,0,8" HorizontalAlignment="Left">
                                    <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Close Other Apps" FontSize="14" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Moza Pit House, Logitech G HUB, Fanatec driver, SimHub, vJoy" FontSize="12" Foreground="#FF8B949E" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Arrow 1→2 -->
                        <TextBlock Grid.Column="1" Text="&#x276F;" FontSize="18" Foreground="#FF30363D" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Step 2 -->
                        <Border Grid.Column="2" Background="#FF21262D" CornerRadius="6" Padding="16,14">
                            <StackPanel>
                                <Border Background="#FFF0883E" CornerRadius="12" Width="24" Height="24" Margin="0,0,0,8" HorizontalAlignment="Left">
                                    <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Set In-Game FFB = 0" FontSize="14" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="AC EVO Settings > Controls > FFB Gain = 0, restart game" FontSize="12" Foreground="#FF8B949E" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Arrow 2→3 -->
                        <TextBlock Grid.Column="3" Text="&#x276F;" FontSize="18" Foreground="#FF30363D" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Step 3 -->
                        <Border Grid.Column="4" Background="#FF21262D" CornerRadius="6" Padding="16,14">
                            <StackPanel>
                                <Border Background="#FFF0883E" CornerRadius="12" Width="24" Height="24" Margin="0,0,0,8" HorizontalAlignment="Left">
                                    <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Connect &amp; Start" FontSize="14" FontWeight="SemiBold" Foreground="#FFE6EDF3" Margin="0,0,0,4" />
                                <TextBlock Text="Select wheel, Connect, load a profile, then START" FontSize="12" Foreground="#FF8B949E" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="Use the sidebar to navigate: FFB Tuning, Equalizer, Track Map, Telemetry, Devices, Profiles"
                               FontSize="12" Foreground="#FF8B949E" Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- HERO STATUS BAR — Game + Device + Profile in one row -->
            <Border Background="#FF1C2128" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="#FF30363D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Game Status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF8B949E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                            <Setter Property="Fill" Value="#FF7EE787" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="GAME" FontSize="12" FontWeight="Bold" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Not Connected" />
                                    <Setter Property="Foreground" Value="#FF8B949E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameConnected}" Value="True">
                                            <Setter Property="Text" Value="Connected" />
                                            <Setter Property="Foreground" Value="#FF7EE787" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding PacketsPerSecond, StringFormat=' · {0} pkt/s'}" FontSize="12" Foreground="#FF8B949E" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="1" Width="1" Background="#FF30363D" VerticalAlignment="Stretch" Margin="0,2" />

                    <!-- Device Status -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF8B949E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                            <Setter Property="Fill" Value="#FF79C0FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="DEVICE" FontSize="12" FontWeight="Bold" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" FontSize="14" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Foreground="#FF8B949E" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                            <Setter Property="Text" Value="{Binding WheelMaxTorqueNm, StringFormat=' · {0:F1} Nm'}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Grid.Column="3" Width="1" Background="#FF30363D" VerticalAlignment="Stretch" Margin="0,2" />

                    <!-- Profile Status -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF8B949E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="PROFILE" FontSize="12" FontWeight="Bold" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue='None'}" FontWeight="SemiBold" FontSize="14" Foreground="#FFF0883E" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ProfileCarMatch, FallbackValue=''}" FontSize="12" Foreground="#FF8B949E" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- UPDATE AVAILABLE BANNER -->
            <Border Background="#33FFD600" CornerRadius="8" Padding="20,14" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="#55FFD600"
                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="UPDATE AVAILABLE" FontSize="14" FontWeight="Bold" Foreground="#FFFFD600" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding UpdateStatusText}" FontSize="13" Foreground="#FFE6EDF3" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding DownloadAndInstallUpdateCommand}" Cursor="Hand" VerticalAlignment="Center"
                            Margin="16,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="UpdateBtnBorder" Background="#FFFFD600" CornerRadius="6" Padding="20,10" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding LatestVersionText, StringFormat='Install {0}'}" FontSize="14" FontWeight="Bold" Foreground="#FF1C2128" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="UpdateBtnBorder" Property="Background" Value="#FFE6B800" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTROL CENTER — Start (hero) + Auto Setup + Panic -->
            <Border Background="#FF1C2128" CornerRadius="8" Padding="28,24" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="#FF30363D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Auto Setup (secondary, left) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                        <Button Content="AUTO SETUP" Command="{Binding AutoSetupCommand}" IsEnabled="{Binding IsAutoSetupAvailable}"
                                FontSize="14" FontWeight="Bold" Cursor="Hand" Padding="20,12"
                                ToolTip="Auto-configure all FFB settings for your connected wheelbase">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF21262D" />
                                    <Setter Property="Foreground" Value="#FF79C0FF" />
                                    <Setter Property="BorderBrush" Value="#FF30363D" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF30363D" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF161B22" />
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF21262D" />
                                                        <Setter Property="Foreground" Value="#FF484F58" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="160" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Auto-configure all FFB settings for your wheelbase torque rating" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutoSetupAvailable}" Value="True">
                                            <Setter Property="Text" Value="{Binding AutoSetupStatus}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- START / STOP (hero button, center) -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ToggleButton IsChecked="{Binding IsRunning}" Command="{Binding ToggleTelemetryCommand}"
                                      x:Name="HomeStartToggle">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Content" Value="&#x25B6;  START" />
                                    <Setter Property="Background" Value="#FF2E7D32" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="BorderBrush" Value="#FF4CAF50" />
                                    <Setter Property="Padding" Value="48,16" />
                                    <Setter Property="FontSize" Value="22" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FF388E3C" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Content" Value="&#x25A0;  STOP" />
                                            <Setter Property="Background" Value="#FFF0883E" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="#FFFF9800" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <TextBlock Text="Toggle telemetry processing" FontSize="12" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,6,0,0" />
                    </StackPanel>

                    <!-- Panic (muted, right) -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="24,0,0,0">
                        <Button Content="PANIC" Command="{Binding PanicStopCommand}"
                                FontSize="14" FontWeight="Bold" Cursor="Hand" Padding="20,12"
                                Style="{StaticResource PanicButton}" />
                        <TextBlock FontSize="11" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="140" TextAlignment="Center"
                                   Text="Zero all FFB · Assignable in Devices page" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LIVE TELEMETRY — Force bar + Signal Monitor + Steering + Hardware Insight -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <!-- Force Output Meter (wider, with peak marker) -->
                <Border Grid.Column="0" Background="#FF1C2128" CornerRadius="8" Padding="10"
                        BorderThickness="1" BorderBrush="#FF30363D">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="FORCE" FontSize="10" FontWeight="Bold" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <Grid Width="50" Height="160" Margin="0,0,0,4">
                            <!-- Background track -->
                            <Border Background="#FF21262D" CornerRadius="4" />
                            <!-- Force fill bar -->
                            <Border VerticalAlignment="Bottom" CornerRadius="4" Height="{Binding ForceBarFillHeight, FallbackValue=0}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFF0883E" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                <Setter Property="Background" Value="#FFFF7B72" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CurrentForceOutput, StringFormat='{}{0:F3}'}" FontSize="13" FontWeight="Bold" Foreground="#FFE6EDF3" HorizontalAlignment="Center" Margin="0,0,0,1" />
                        <TextBlock Text="{Binding CurrentRawForce, StringFormat='Raw {0:F3}'}" FontSize="10" Foreground="#FF8B949E" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Live Telemetry: Signal Monitor + Steering -->
                <Border Grid.Column="2" Background="#FF1C2128" CornerRadius="8" Padding="20,16"
                        BorderThickness="1" BorderBrush="#FF30363D">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="LIVE TELEMETRY" FontSize="11" FontWeight="Bold" Foreground="#FF8B949E" Margin="0,0,0,12" />

                        <!-- Signal Monitor (replaces Speed Gauge) -->
                        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="SIGNAL MONITOR" FontSize="10" FontWeight="Bold" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <Border Background="#FF21262D" CornerRadius="4" Width="260" Height="80">
                                <Canvas Width="260" Height="80" ClipToBounds="True">
                                    <!-- Center line -->
                                    <Line X1="0" Y1="40" X2="260" Y2="40" Stroke="#FF30363D" StrokeThickness="1" StrokeDashArray="4,4" />
                                    <!-- Low-Freq Torque line -->
                                    <Polyline Points="{Binding SignalMonitorLowFreq}" Stroke="#FFF0883E" StrokeThickness="1.5" Fill="Transparent" />
                                    <!-- High-Freq Haptics line -->
                                    <Polyline Points="{Binding SignalMonitorHighFreq}" Stroke="#FF79C0FF" StrokeThickness="1.5" Fill="Transparent" />
                                </Canvas>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Ellipse Width="8" Height="8" Fill="#FFF0883E" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Low-Freq Torque" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Ellipse Width="8" Height="8" Fill="#FF79C0FF" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="High-Freq Haptics" FontSize="10" Foreground="#FF8B949E" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Racing Wheel (rotates with steering input) -->
                        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="STEERING" FontSize="10" FontWeight="Bold" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <Border Width="130" Height="130" ClipToBounds="False" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/wheel_nobg.png"
                                       Width="90" Height="90" Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="{Binding SteerAngle}" />
                                    </Image.RenderTransform>
                                </Image>
                            </Border>
                            <TextBlock Text="{Binding SteerAngle, StringFormat='{}{0:F1}°'}" FontSize="16" FontWeight="Bold" Foreground="#FFE6EDF3" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Status row -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="#FF8B949E" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock FontWeight="Bold" FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Idle" />
                                        <Setter Property="Foreground" Value="#FF8B949E" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Running" />
                                                <Setter Property="Foreground" Value="#FF7EE787" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsClipping}" Value="True">
                                                <Setter Property="Text" Value="&#x26A0; Clipping" />
                                                <Setter Property="Foreground" Value="#FFFF7B72" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hardware Insight Panel -->
                <Border Grid.Column="4" Background="#FF1C2128" CornerRadius="8" Padding="16"
                        BorderThickness="1" BorderBrush="#FF30363D">
                    <StackPanel>
                        <TextBlock Text="HARDWARE INSIGHT" FontSize="11" FontWeight="Bold" Foreground="#FF8B949E" Margin="0,0,0,12" />

                        <!-- Active Provider -->
                        <TextBlock Text="Active Provider" FontSize="10" Foreground="#FF8B949E" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding HalProviderName}" FontSize="14" FontWeight="Bold" Foreground="#FFF0883E" Margin="0,0,0,14" TextWrapping="Wrap" />

                        <!-- SDK Connection LED -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalSdkConnected}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="SDK Connection" FontSize="12" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Haptic Engine LED -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalHapticEngineActive}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Haptic Engine" FontSize="12" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Peripheral Sync LED -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF484F58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHalPeripheralSynced}" Value="True">
                                                <Setter Property="Fill" Value="#FF7EE787" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Peripheral Sync" FontSize="12" Foreground="#FFE6EDF3" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Test Buzz Button -->
                        <Button Command="{Binding TestBuzzCommand}" Cursor="Hand" HorizontalAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1AF0883E" />
                                    <Setter Property="Foreground" Value="#FFF0883E" />
                                    <Setter Property="BorderBrush" Value="#FFF0883E" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BuzzBd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="12,8" SnapsToDevicePixels="True">
                                                    <TextBlock x:Name="BuzzText" Text="Test Buzz" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BuzzBd" Property="Background" Value="#33F0883E" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="BuzzBd" Property="Background" Value="#FF161B22" />
                                                        <Setter TargetName="BuzzBd" Property="BorderBrush" Value="#FF21262D" />
                                                        <Setter TargetName="BuzzText" Property="Foreground" Value="#FF484F58" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestBuzzRunning}" Value="True">
                                            <Setter Property="Content" Value="Buzzing..." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="500ms diagnostic vibration" FontSize="10" Foreground="#FF8B949E" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- STATUS MESSAGE -->
            <Border Background="#FF1C2128" CornerRadius="8" Padding="16,10" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="#FF30363D"
                    Visibility="{Binding StatusText, Converter={StaticResource NotEmptyToVis}}">
                <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#FF8B949E" TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>