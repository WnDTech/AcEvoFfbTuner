<UserControl x:Class="AcEvoFfbTuner.Views.Pages.TrackMapPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AcEvoFfbTuner.Converters"
             xmlns:controls="clr-namespace:AcEvoFfbTuner.Controls"
             Background="#FF0F1117"
             Foreground="#FFE6EDF3"
             FontFamily="Segoe UI"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1C2128" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="Pop Out Map" Click="OpenTrackMapPopout" Padding="12,4" FontSize="14" FontWeight="Bold" Margin="0,0,6,0" />
                    <Button Content="Record Lap" Command="{Binding StartTrackMapRecordingCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" />
                    <Button Content="Stop" Command="{Binding StopTrackMapRecordingCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                    <Button Content="Complete &amp; Save" Command="{Binding CompleteAndSaveTrackMapCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                    <Button Content="Export" Command="{Binding ExportTrackProfileCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                    <Button Content="Import" Command="{Binding ImportTrackProfileCommand}" Padding="12,4" FontSize="14" Margin="0,0,6,0" Style="{StaticResource OutlinedButton}" />
                    <Button Content="Clear" Command="{Binding ClearTrackMapCommand}" Padding="12,4" FontSize="14" Style="{StaticResource OutlinedButton}" />
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#FF30363D" Margin="8,0" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF555555" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                        <Setter Property="Fill" Value="#FFF0883E" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                        <Setter Property="Fill" Value="#FF00E676" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="14" Foreground="#FF8B949E" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="No Map" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTrackMapRecording}" Value="True">
                                        <Setter Property="Text" Value="Recording..." />
                                        <Setter Property="Foreground" Value="#FFF0883E" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTrackMapAvailable}" Value="True">
                                        <Setter Property="Text" Value="Map Ready" />
                                        <Setter Property="Foreground" Value="#FF00E676" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="4" Width="1" Background="#FF30363D" Margin="8,0" />

                <StackPanel Grid.Column="5" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Track" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock Text="{Binding DetectedTrackName, FallbackValue='--'}" FontSize="14" FontWeight="Bold" Foreground="#FF00E676" MaxWidth="120" />
                </StackPanel>

                <StackPanel Grid.Column="6" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Progress" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="TrackMapProgress" Text="--" FontSize="16" FontWeight="Bold" Foreground="#FFFFD600" />
                </StackPanel>
                <StackPanel Grid.Column="7" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Dist from Center" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="TrackMapDistance" Text="-- m" FontSize="16" FontWeight="Bold" Foreground="#FF00BCD4" />
                </StackPanel>
                <StackPanel Grid.Column="8" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="Track Status" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="TrackMapOnTrack" Text="--" FontSize="16" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF555555" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnTrackMap}" Value="True">
                                        <Setter Property="Text" Value="ON TRACK" />
                                        <Setter Property="Foreground" Value="#FF00E676" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsOnTrackMap}" Value="False">
                                        <Setter Property="Text" Value="OFF TRACK" />
                                        <Setter Property="Foreground" Value="#FFF0883E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                 <StackPanel Grid.Column="9" Margin="8,0" VerticalAlignment="Center">
                     <TextBlock Text="Waypoints" FontSize="12" Foreground="#FF8B949E" />
                     <TextBlock x:Name="TrackMapWaypoints" Text="--" FontSize="16" Foreground="#FFE6EDF3" />
                 </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF1C2128" CornerRadius="6" Padding="6,3" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Corner" FontSize="12" Foreground="#FF8B949E" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TrackMapCorner" Text="--" FontSize="15" FontWeight="Bold" Foreground="#FFFFD600" />
                        <TextBlock x:Name="TrackMapCornerName" Text="" FontSize="13" Foreground="#FF79C0FF" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Sector" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock x:Name="TrackMapSector" Text="--" FontSize="15" FontWeight="Bold" Foreground="#FF00BCD4" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Corners" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock Text="{Binding CornerCount, FallbackValue=0}" FontSize="15" Foreground="#FFE6EDF3" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="6,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Laps" FontSize="12" Foreground="#FF8B949E" />
                    <TextBlock Text="{Binding CompletedLapCount, FallbackValue=0}" FontSize="15" Foreground="#FFE6EDF3" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="6,0,12,0" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF555555" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInPit}" Value="True">
                                        <Setter Property="Fill" Value="#FFFFD600" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text=" PIT" FontSize="13" Foreground="#FF8B949E" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="6" Margin="6,0,6,0" VerticalAlignment="Center">
                     <CheckBox Content="Heatmap" IsChecked="{Binding ShowForceHeatmap}" Foreground="#FF8B949E" FontSize="14" />
                 </StackPanel>
                 <StackPanel Grid.Column="7" Margin="6,0,6,0" VerticalAlignment="Center">
                     <CheckBox Content="Edges" IsChecked="{Binding ShowTrackEdges}" Foreground="#FF8B949E" FontSize="14" />
                 </StackPanel>
                 <StackPanel Grid.Column="5" Margin="6,0,6,0" VerticalAlignment="Center" Visibility="{Binding IsTrackMapAvailable, Converter={StaticResource BoolToVis}}">
                      <CheckBox Content="Diagnostics" IsChecked="{Binding ShowDiagnostics}" Foreground="#FFFF8A65" FontSize="14" />
                  </StackPanel>
                 <StackPanel Grid.Column="8" Margin="6,0,6,0" VerticalAlignment="Center">
                      <CheckBox Content="Satellite" IsChecked="{Binding ShowSatelliteMap}" Foreground="#FF79C0FF" FontSize="14" FontWeight="SemiBold" />
                  </StackPanel>
                  <StackPanel Grid.Column="9" Margin="6,0,6,0" VerticalAlignment="Center">
                       <Button x:Name="CalibrateBtn" Content="Calibrate" Padding="10,3" FontSize="13"
                               Click="ToggleCalibration" FontWeight="SemiBold" />
                   </StackPanel>
                  <StackPanel Grid.Column="10" Margin="6,0,6,0" VerticalAlignment="Center">
                       <Button x:Name="LiveModeBtn" Content="Live Mode" Padding="10,3" FontSize="13"
                               Click="ToggleLiveMode" FontWeight="Bold" Background="#FF2E7D32" Foreground="#FFE6EDF3" BorderThickness="0" />
                   </StackPanel>
            </Grid>
        </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="FfbDiagnosticsPanel" Grid.Column="0" Background="#FF161B22" CornerRadius="4" Padding="10,8" Margin="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="FFB DIAGNOSTICS" FontSize="14" Foreground="#FF00E676" FontWeight="Bold" Margin="0,0,0,8" />

                        <TextBlock Text="LEGEND" FontSize="12" Foreground="#FF8B949E" FontWeight="Bold" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Fill="#FF00E676" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center">
                                <Run Text="Expected" FontWeight="Bold" Foreground="#FF00E676" /><Run Text=" - Normal forces" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Fill="#FFFFD600" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center">
                                <Run Text="Notable" FontWeight="Bold" Foreground="#FFFFD600" /><Run Text=" - Event, not susp." />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="10" Height="10" Fill="#FFFF0000" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" Foreground="#FFE6EDF3" VerticalAlignment="Center">
                                <Run Text="Suspicious" FontWeight="Bold" Foreground="#FFFF0000" /><Run Text=" - Code issue?" />
                            </TextBlock>
                        </StackPanel>

                        <Border Background="#FF333355" Height="1" Margin="0,4,0,8" />

                        <TextBlock Text="INTERPRETATION" FontSize="12" Foreground="#FF8B949E" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock FontSize="12" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14">
                            <Run Text="Expected:" FontWeight="Bold" Foreground="#FF00E676" />
                            <Run Text=" Snap at corner entry/exit, understeer/oversteer, braking weight transfer." />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" Margin="0,3,0,0">
                            <Run Text="Suspicious:" FontWeight="Bold" Foreground="#FFFF0000" />
                            <Run Text=" Snap on a straight, oscillation with no steering, force pushing same direction as wheel." />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#FF999999" TextWrapping="Wrap" LineHeight="14" Margin="0,3,0,0">
                            <Run Text="Verdict:" FontWeight="Bold" Foreground="#FF00BCD4" />
                            <Run Text=" Most dots green and at corners = normal driving. Red on straights = check FFB code." />
                        </TextBlock>

                        <Border Background="#FF333355" Height="1" Margin="0,8,0,8"
                                Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}" />

                        <StackPanel Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DiagnosticCoverage, FallbackValue='Coverage: 0%'}" FontSize="13" Foreground="#FF00BCD4" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DiagnosticSummary, FallbackValue=''}" FontSize="12" Foreground="#FF8B949E" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DiagnosticVerdict, FallbackValue=''}" FontSize="14" Foreground="#FFF0883E" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="Last Event:" FontSize="12" Foreground="#FF8B949E" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding LastEventInfo, FallbackValue=''}" FontSize="12" Foreground="#FFFF8A65" FontFamily="Consolas" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Border Background="#FF151525" CornerRadius="6" x:Name="VectorMapBorder">
                        <Canvas x:Name="TrackMapCanvas" ClipToBounds="True" />
                    </Border>
                    <controls:MapsuiMapControl x:Name="SatelliteMapCtrl" Visibility="Collapsed" />

                    <!-- Status overlay when no map data -->
                    <Border x:Name="MapStatusOverlay" Background="#CC1a1a2e"
                            CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Padding="24,16" Visibility="Visible" IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                            <TextBlock Text="TRACK MAP" FontSize="18" FontWeight="Bold"
                                       Foreground="#FF79C0FF" HorizontalAlignment="Center" Margin="0,0,0,10" />
                            <TextBlock x:Name="MapStatusText" Text="Drive a full lap to record the track layout..."
                                       FontSize="14" Foreground="#FF8B949E" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

        <Border Grid.Row="3" x:Name="RecommendationsPanel" Background="#FF161B22" CornerRadius="4" Padding="8,4" Margin="0,4,0,0"
                Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Apply Profile Changes" Command="{Binding ApplyRecommendationsCommand}"
                        Padding="10,4" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Top"
                        Background="#FF2E7D32" Foreground="#FFE6EDF3" BorderThickness="0" />
                <StackPanel>
                    <TextBlock Text="RECOMMENDATIONS" FontSize="13" Foreground="#FF00E676" FontWeight="Bold" Margin="0,0,0,2" />
                    <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                             Foreground="#FFE6EDF3" FontFamily="Consolas" FontSize="14"
                             Text="{Binding RecommendationsText, Mode=OneWay}"
                             TextWrapping="Wrap" MaxHeight="100"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="4" Background="#FF1C2128" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="X:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapCarX" Text="--" FontSize="14" Foreground="#FFE6EDF3" FontFamily="Consolas" Margin="0,0,16,0" />
                        <TextBlock Text="Z:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapCarZ" Text="--" FontSize="14" Foreground="#FFE6EDF3" FontFamily="Consolas" Margin="0,0,16,0" />
                        <TextBlock Text="Speed:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapSpeed" Text="--" FontSize="14" Foreground="#FF00E676" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,16,0" />
                        <TextBlock Text="GPS:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapGpsPos" Text="--" FontSize="14" Foreground="#FF79C0FF" FontFamily="Consolas" Margin="0,0,16,0" />
                        <TextBlock Text="Rot:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapAlignment" Text="--" FontSize="14" Foreground="#FFFFD600" FontFamily="Consolas" Margin="0,0,16,0" />
                        <TextBlock Text="Sector Stats:" FontSize="14" Foreground="#FF8B949E" Margin="0,0,4,0" />
                        <TextBlock x:Name="TrackMapSectorStats" Text="--" FontSize="14" Foreground="#FFE6EDF3" FontFamily="Consolas" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock x:Name="TrackMapOsmStatus" Text="" FontSize="11" Foreground="#FF8B949E" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="TrackMapAlignmentStatus" Text="" FontSize="12" Foreground="#FF79C0FF" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button x:Name="CenterOnCarBtn" Content="Center on Car" Padding="8,3" FontSize="12"
                                Background="#FF444444" Foreground="#FFE6EDF3" BorderThickness="0"
                                Click="OnCenterOnCar" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
