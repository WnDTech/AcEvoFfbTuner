<UserControl x:Class="AcEvoFfbTuner.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcEvoFfbTuner.ViewModels"
             x:Name="Root"
             Width="200" MinWidth="60">

    <UserControl.Resources>
        <vm:NavPage x:Key="NavHome">Home</vm:NavPage>
        <vm:NavPage x:Key="NavTuning">FfbTuning</vm:NavPage>
        <vm:NavPage x:Key="NavEq">Equalizer</vm:NavPage>
        <vm:NavPage x:Key="NavMap">TrackMap</vm:NavPage>
        <vm:NavPage x:Key="NavTelemetry">Telemetry</vm:NavPage>
        <vm:NavPage x:Key="NavDevices">Devices</vm:NavPage>
        <vm:NavPage x:Key="NavProfiles">Profiles</vm:NavPage>
        <vm:NavPage x:Key="NavOverlays">Overlays</vm:NavPage>
    </UserControl.Resources>

    <Grid Background="#FF0D1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.RowSpan="2" Margin="0,0">

            <RadioButton x:Name="NavHomeBtn" GroupName="SidebarNav" Content="Home" Margin="4,0,4,1"
                         Tag="{x:Static vm:NavPage.Home}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Home — status and quick start">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,9,12,8" Margin="0,0">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,12 L12,4 L20,12 M6,10.5 V19 H18 V10.5"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavTuningBtn" GroupName="SidebarNav" Content="FFB Tuning" Margin="4,1"
                         Tag="{x:Static vm:NavPage.FfbTuning}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="FFB Tuning — all force effect parameters">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,4 A8,8,0,1,1,11.99,4 Z M12,12 V6 M7.5,16 L12,12 L16.5,16"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavEqBtn" GroupName="SidebarNav" Content="Equalizer" Margin="4,1"
                         Tag="{x:Static vm:NavPage.Equalizer}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Equalizer — 10-band FFB frequency shaping">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="2" Canvas.Top="10" Width="3" Height="8" RadiusX="1" RadiusY="1"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                        <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1" RadiusY="1"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                        <Rectangle Canvas.Left="11" Canvas.Top="8" Width="3" Height="10" RadiusX="1" RadiusY="1"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                        <Rectangle Canvas.Left="15.5" Canvas.Top="3" Width="3" Height="16" RadiusX="1" RadiusY="1"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                        <Rectangle Canvas.Left="20" Canvas.Top="12" Width="3" Height="6" RadiusX="1" RadiusY="1"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavMapBtn" GroupName="SidebarNav" Content="Track Map" Margin="4,1"
                         Tag="{x:Static vm:NavPage.TrackMap}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Track Map — track layout, FFB diagnostics, and live satellite view with GPS">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,18 C5,8 10,4 14,4 C18,4 20,8 20,12 C20,16 16,20 12,20 C8,20 5,18 5,14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavLiveMapBtn" GroupName="SidebarNav" Content="Live Map" Margin="4,1"
                         Tag="{x:Static vm:NavPage.LiveTrackMap}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Live Map — OSM track data with satellite view">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M3,17 L3,7 L21,7 L21,17 Z M7,12 A3,3,0,1,0 13,12 A3,3,0,1,0 7,12 M15,9 L19,9 M15,12 L19,12 M15,15 L17,15"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavTelemetryBtn" GroupName="SidebarNav" Content="Telemetry" Margin="4,1"
                         Tag="{x:Static vm:NavPage.Telemetry}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Telemetry — live profiler and signal analysis">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V4 M4,18 H20 M6,14 L9,8 L12,12 L16,6 L20,10"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <!-- Nav: FFB Coach -->
            <RadioButton x:Name="NavCoachBtn" GroupName="SidebarNav" Content="FFB Coach" Margin="4,1"
                         Tag="{x:Static vm:NavPage.FfbCoach}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="FFB Coach — interactive tuning assistant using telemetry data">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 L22,22 L22,12 C22,6.48 17.52,2 12,2 Z M12,18 C11.45,18 11,17.55 11,17 C11,16.45 11.45,16 12,16 C12.55,16 13,16.45 13,17 C13,17.55 12.55,18 12,18 Z M13,14 L11,14 L11,8 L13,8 L13,14 Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavDevicesBtn" GroupName="SidebarNav" Content="Devices" Margin="4,1"
                         Tag="{x:Static vm:NavPage.Devices}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Devices — LED effects, haptic pad, button assignments">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M6,9 C6,9 7,14 6,17 C5,20 4,20 3,18 C2,16 3,13 5,10 M18,9 C18,9 17,14 18,17 C19,20 20,20 21,18 C22,16 21,13 19,10 M5,10 C5,10 8,7 12,7 C16,7 19,10 19,10"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavProfilesBtn" GroupName="SidebarNav" Content="Profiles" Margin="4,1"
                         Tag="{x:Static vm:NavPage.Profiles}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Profiles — manage and import/export FFB profiles">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,20 V4 H20 V20 Z M12,10 C13.5,10 14.5,8.5 14.5,7.5 C14.5,6.5 13.5,6 12,6 C10.5,6 9.5,6.5 9.5,7.5 C9.5,8.5 10.5,10 12,10 Z M8,16 C8,13 10,12 12,12 C14,12 16,13 16,16"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>

            <RadioButton x:Name="NavOverlaysBtn" GroupName="SidebarNav" Content="Overlays" Margin="4,1"
                         Tag="{x:Static vm:NavPage.Overlays}" Click="OnNavClick" Cursor="Hand"
                         ToolTip="Overlays — OBS browser sources and telemetry overlays">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4" Padding="12,8" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M3,5 H21 V19 H3 Z M12,8 L8,14 L12,12 L16,16"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Path Data="M17,11 A1.5,1.5,0,1,0 17,10.99"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="ItemLabel" Text="{TemplateBinding Content}" FontSize="20"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1AF0883E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
                <RadioButton.Style>
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="#FF8B949E" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFF0883E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <Border Background="#FF30363D" Height="1" Margin="12,4" />
            <Button x:Name="SettingsBtn" Content="Settings" Click="OnSettingsClick" Cursor="Hand" HorizontalAlignment="Stretch"
                    Background="Transparent" Foreground="#FF8B949E" BorderThickness="0" Padding="12,6" FontSize="18" Margin="4,1"
                    ToolTip="App settings and debug tools">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                    <Canvas Width="24" Height="24">
